---
import MobileLayout from '../layouts/MobileLayout.astro';
import HeaderActions from '../components/HeaderActions.astro';
import EmptyState from '../components/EmptyState.astro';
import ArticleSkeleton from '../components/ArticleSkeleton.astro';

// Fetch articles and categories from the Backend API for SSR
let exploreArticles = [];
let topicCategories = [];
const backendUrl = import.meta.env.PUBLIC_BACKEND_URL || 'https://pexih-api.vercel.app';
try {
  const [artRes, catRes] = await Promise.all([
    fetch(`${backendUrl}/api/articles`),
    fetch(`${backendUrl}/api/categories`)
  ]);
  
  if (artRes.ok) {
    const data = await artRes.json();
    // Sort by views if possible, else just take top 4
    exploreArticles = data
      .sort((a, b) => (Number(b.views) || 0) - (Number(a.views) || 0))
      .slice(0, 4);
  }
  
  if (catRes.ok) {
    topicCategories = await catRes.json();
  }
} catch (e) {
  console.error("Failed to fetch data from API", e);
}

// Fallback to dummy data if API fails or returns empty
if (exploreArticles.length === 0) {
  exploreArticles = [1, 2, 3, 4].map((post) => ({
    id: String(post),
    title: `Understanding Minimalist Interfaces in Modern Apps ${post}`,
    content: "An in-depth look at how modern technology is reshaping our daily lives.",
    author: { name: "Alex Rivers" },
    img: `https://images.unsplash.com/photo-${1550000000000 + post}?auto=format,compress&fit=crop&w=600&q=80`,
    category: "Design",
    readTime: "5 min read",
    views: "1.2k"
  }));
}

const featuredPost = exploreArticles[0];
const trendingPosts = exploreArticles.slice(1);
---
<MobileLayout title="Explore">
  <div class="fixed top-0 w-full max-w-[400px] z-50 bg-white dark:bg-gray-900" transition:name="mobile-header">
    <div class="w-full" style="height: env(safe-area-inset-top);"></div>
    <div class="pt-3 pb-2 px-5 border-b border-gray-100 dark:border-gray-800 h-[53px]">
      <!-- Standard Header View -->
      <div id="header-standard-view" class="h-full flex items-center justify-between w-full">
        <h1 class="text-[16px] font-bold text-gray-900 dark:text-white" data-i18n="nav.explore">Explore</h1>
        <div class="flex items-center gap-1">
          <button id="toggle-search-btn" class="w-8 h-8 rounded-full bg-gray-50 dark:bg-gray-800 flex items-center justify-center text-gray-600 dark:text-gray-300 hover:text-orange-600 dark:hover:text-orange-500 transition-colors cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </button>
          <HeaderActions />
        </div>
      </div>

      <!-- Active Search Header View -->
      <div id="header-search-view" class="hidden h-full flex items-center gap-2 w-full relative">
        <button id="close-search-btn" class="w-8 h-8 rounded-full flex items-center justify-center text-gray-500 hover:text-orange-600 dark:text-gray-400 transition-colors cursor-pointer shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <div class="relative flex-1">
          <input type="text" id="mobile-explore-search" data-i18n="header.search" placeholder="Cari artikel, kategori..." class="w-full pl-8 pr-3 py-1.5 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-300 dark:border-gray-700 text-[11px] font-medium focus:outline-none focus:ring-1 focus:ring-orange-500 focus:bg-white dark:focus:bg-gray-800 transition-all dark:text-white" autocomplete="off" />
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        
        <!-- Suggestion dropdown for mobile search -->
        <div id="mobile-search-suggestions-dropdown" class="absolute left-0 right-0 top-full mt-2 bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-lg shadow-xl z-[100] max-h-60 overflow-y-auto hidden divide-y divide-gray-50 dark:divide-gray-750"></div>
      </div>
    </div>
  </div>

  <!-- Spacer to prevent overlap with fixed header -->
  <div class="shrink-0" style="height: calc(53px + env(safe-area-inset-top));"></div>

  <div class="px-4 py-2 space-y-4">
    <!-- Categories -->
    <div class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide">
      <button class="px-4 py-1.5 rounded-full bg-orange-600 text-white text-[10px] font-bold whitespace-nowrap" data-i18n="explore.allTopics">All Topics</button>
      {topicCategories.length > 0 ? (
        topicCategories.map(cat => (
          <button class="px-4 py-1.5 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-[10px] font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700" data-i18n={`category.${cat.slug || cat.title.toLowerCase().replace(/\s+/g, '-')}`}>{cat.title}</button>
        ))
      ) : (
        <>
          <button class="px-4 py-1.5 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-[10px] font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700" data-i18n="category.technology">Technology</button>
          <button class="px-4 py-1.5 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-[10px] font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700" data-i18n="category.design">Design</button>
          <button class="px-4 py-1.5 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-[10px] font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700" data-i18n="category.lifestyle">Lifestyle</button>
        </>
      )}
    </div>

    <div class="article-transition-wrapper">
      <div class="skeleton-container hidden space-y-4">
        <div class="w-full aspect-[16/9] rounded-xl bg-gray-200 dark:bg-gray-800 animate-pulse"></div>
        <ArticleSkeleton count={3} />
      </div>
      
      <div class="actual-content-container">
        {exploreArticles.length > 0 ? (
          <>
            <!-- Featured Post -->
            <a href={`/article/${featuredPost.id}`} class="block rounded-xl overflow-hidden border border-gray-100 dark:border-gray-800 shadow-sm relative mb-4 animate-fade-in" style="animation-delay: 0ms">
              <div class="aspect-[16/9] pexih-placeholder bg-gray-200 dark:bg-gray-800 w-full relative">
                <img 
                  src={featuredPost.img || "https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format,compress&fit=crop&w=600&q=80"} 
                  alt={`Featured Post: ${featuredPost.title}`} 
                  width="600"
                  height="337"
                  class="w-full h-full object-cover aspect-[16/9] transition-opacity duration-300 opacity-0" 
                  onload="this.classList.remove('opacity-0')"
                  loading="eager" 
                  fetchpriority="high"
                  decoding="async"
                  referrerpolicy="no-referrer" 
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
                <div class="absolute bottom-3 left-3 right-3 text-white">
                  <span class="bg-orange-600 text-white text-[8px] font-bold px-2 py-0.5 rounded uppercase tracking-wider mb-1.5 inline-block">{featuredPost.category || 'Featured'}</span>
                  <h2 class="text-[14px] font-bold leading-tight line-clamp-2">{featuredPost.title}</h2>
                </div>
              </div>
            </a>
            
            <!-- List Posts -->
            <div class="space-y-3 list-posts-wrapper">
              <h3 class="text-[12px] font-bold text-gray-900 dark:text-white mb-2">Trending Now</h3>
              
              {trendingPosts.map((item, index) => (
                <a href={`/article/${item.id}`} class="flex gap-3 items-center group article-item animate-fade-in" style={`animation-delay: ${(index + 1) * 75}ms`}>
                  <div class="w-20 h-20 rounded-lg overflow-hidden pexih-placeholder bg-gray-100 dark:bg-gray-800 shrink-0 aspect-square">
                    <img 
                      src={item.img || `https://images.unsplash.com/photo-${1550000000000 + index}?auto=format,compress&fit=crop&w=200&q=80`} 
                      alt={`Thumbnail for ${item.title}`} 
                      width="80"
                      height="80"
                      class="w-full h-full object-cover aspect-square transition-opacity duration-300 opacity-0" 
                      onload="this.classList.remove('opacity-0')"
                      loading="lazy" 
                      decoding="async"
                      referrerpolicy="no-referrer" 
                    />
                  </div>
                  <div class="flex-1 min-w-0">
                    <span class="text-[9px] text-orange-600 dark:text-orange-500 font-bold uppercase tracking-wider">{item.category || 'Trending'}</span>
                    <h4 class="text-[12px] font-bold text-gray-900 dark:text-white leading-tight mt-0.5 mb-1 group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors line-clamp-2">{item.title}</h4>
                    <p class="text-[9px] text-gray-500 dark:text-gray-400">{item.createdAt ? new Date(Number(item.createdAt)).toLocaleDateString() : 'Recent'} • {item.readTime || '5 min read'}</p>
                  </div>
                  <button aria-label="Bookmark" class="bookmark-btn absolute right-2 top-1/2 -translate-y-1/2 p-2 text-gray-400 hover:text-orange-600 dark:text-gray-500 dark:hover:text-orange-500 transition-colors z-10"
                    data-bookmark-id={item.id} 
                    data-bookmark-title={item.title} 
                    data-bookmark-category={item.category || 'General'} 
                    data-bookmark-img={item.img || `https://images.unsplash.com/photo-${1550000000000 + index}?auto=format,compress&fit=crop&w=200&q=80`} 
                    data-bookmark-author={item.author?.name || 'Author Name'}
                    onclick="event.preventDefault(); event.stopPropagation();">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="bookmark-icon"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
                  </button>
                </a>
              ))}
            </div>
          </>
        ) : (
          <EmptyState 
            title="No Content Yet" 
            description="We are preparing awesome content for you. Check back soon for the latest updates."
            icon={`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-600"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>`}
          />
        )}
      </div>
      
      <!-- Empty state for search/filter -->
      <div class="search-empty-state hidden">
        <EmptyState 
          title="No Results Found" 
          titleI18n="empty.noResults"
          description="We couldn't find any articles matching your search. Try different keywords or categories."
          descriptionI18n="empty.noResultsDesc"
          icon={`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-600"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`}
        />
      </div>
      
      <!-- Infinite Scroll Sentinel -->
      <div id="mobile-explore-sentinel" data-backend-url={backendUrl} class="py-4 w-full opacity-0 transition-opacity">
        <div class="flex gap-3 items-center animate-pulse">
          <div class="w-20 h-20 rounded-lg bg-gray-200 dark:bg-gray-800 shrink-0"></div>
          <div class="flex-1 space-y-2">
            <div class="w-16 h-2 bg-gray-200 dark:bg-gray-800 rounded"></div>
            <div class="w-full h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
            <div class="w-3/4 h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</MobileLayout>

<script>
  // Handle client-side category filtering and real-time search
  document.addEventListener('astro:page-load', () => {
    const categoryBtns = document.querySelectorAll('.scrollbar-hide button');
    const skeleton = document.querySelector('.skeleton-container');
    const content = document.querySelector('.actual-content-container');
    const searchEmptyState = document.querySelector('.search-empty-state');
    const listPostsWrapper = document.querySelector('.list-posts-wrapper');
    const sentinel = document.getElementById('mobile-explore-sentinel');
    const backendUrl = sentinel?.getAttribute('data-backend-url') || '';
    
    // Hide Featured Post when searching/filtering
    const featuredPostEl = content?.querySelector('a.block.rounded-xl');
    const listTitle = listPostsWrapper?.querySelector('h3');

    // Remove old items
    function clearList() {
      if (!listPostsWrapper) return;
      const items = listPostsWrapper.querySelectorAll('.article-item');
      items.forEach(item => item.remove());
    }

    function renderArticlesMobile(articles: any[], isSearch = false) {
      if (!listPostsWrapper) return;
      clearList();
      
      if (articles.length === 0) {
        if (content) content.classList.add('hidden');
        if (searchEmptyState) searchEmptyState.classList.remove('hidden');
        if (sentinel) sentinel.classList.add('hidden');
        return;
      }

      if (content) content.classList.remove('hidden');
      if (searchEmptyState) searchEmptyState.classList.add('hidden');

      articles.forEach((item, index) => {
        const articleHtml = `
          <a href="/article/${item.id}" class="flex gap-3 items-center group article-item animate-fade-in" style="animation-delay: ${index * 50}ms">
            <div class="w-20 h-20 rounded-lg overflow-hidden pexih-placeholder bg-gray-100 dark:bg-gray-800 shrink-0 aspect-square">
              <img 
                src="${item.img || `https://images.unsplash.com/photo-${1550000000000 + index}?auto=format,compress&fit=crop&w=200&q=80`}" 
                alt="Thumbnail" 
                width="80" height="80"
                class="w-full h-full object-cover aspect-square transition-opacity duration-300 opacity-0" 
                onload="this.classList.remove('opacity-0')"
                loading="lazy" referrerpolicy="no-referrer" 
              />
            </div>
            <div class="flex-1 min-w-0">
              <span class="text-[9px] text-orange-600 dark:text-orange-500 font-bold uppercase tracking-wider">${item.category || 'Article'}</span>
              <h4 class="text-[12px] font-bold text-gray-900 dark:text-white leading-tight mt-0.5 mb-1 group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors line-clamp-2">${item.title}</h4>
              <p class="text-[9px] text-gray-500 dark:text-gray-400">${item.author?.name || 'Author'} • ${item.readTime || '5 min read'}</p>
            </div>
          </a>
        `;
        listPostsWrapper.insertAdjacentHTML('beforeend', articleHtml);
      });
    }

    let isFiltering = false;
    let currentCategory = 'All Topics';

    async function performFilter(query: string, category: string) {
      if (skeleton && content && searchEmptyState) {
        content.classList.add('hidden');
        searchEmptyState.classList.add('hidden');
        skeleton.classList.remove('hidden');
        if (sentinel) sentinel.classList.add('hidden');
      }

      try {
        let url = `${backendUrl}/api/articles?limit=100`; // Fetch all and filter locally for simplicity and speed
        const cacheKey = 'pexih_all_articles_cache';
        let allData = JSON.parse(sessionStorage.getItem(cacheKey) || 'null');
        
        if (!allData) {
          const res = await fetch(url);
          if (res.ok) {
            allData = await res.json();
            sessionStorage.setItem(cacheKey, JSON.stringify(allData));
          } else {
            allData = [];
          }
        }

        let filtered = allData;
        
        if (category !== 'All Topics') {
          filtered = filtered.filter((a: any) => a.category?.toLowerCase() === category.toLowerCase());
        }
        
        if (query && query.length >= 2) {
          const q = query.toLowerCase();
          filtered = filtered.filter((a: any) => 
            a.title?.toLowerCase().includes(q) || 
            a.category?.toLowerCase().includes(q) || 
            a.author?.name?.toLowerCase().includes(q)
          );
        }

        if (skeleton) skeleton.classList.add('hidden');
        
        // UI updates
        isFiltering = (category !== 'All Topics' || (query && query.length >= 2));
        
        if (featuredPostEl) {
          if (isFiltering) featuredPostEl.classList.add('hidden');
          else featuredPostEl.classList.remove('hidden');
        }

        if (listTitle) {
          if (query && query.length >= 2) {
            listTitle.textContent = `Search Results for "${query}"`;
          } else if (category !== 'All Topics') {
            listTitle.textContent = `${category} Articles`;
          } else {
            listTitle.textContent = 'Trending Now';
          }
        }

        if (isFiltering) {
          renderArticlesMobile(filtered, true);
        } else {
          // Reset to default 4 trending
          renderArticlesMobile(filtered.slice(1, 5), false); // skipping 1st as it's featured
          if (sentinel && hasMore) sentinel.classList.remove('hidden');
        }

      } catch (err) {
        console.error(err);
        if (skeleton) skeleton.classList.add('hidden');
      }
    }

    // Category click
    categoryBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        categoryBtns.forEach(b => {
          b.className = 'px-4 py-1.5 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-[10px] font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700';
        });
        const target = e.target as HTMLElement;
        target.className = 'px-4 py-1.5 rounded-full bg-orange-600 text-white text-[10px] font-bold whitespace-nowrap';
        
        currentCategory = target.textContent?.trim() || 'All Topics';
        const searchInput = document.getElementById('mobile-explore-search') as HTMLInputElement;
        performFilter(searchInput ? searchInput.value.trim() : '', currentCategory);
      });
    });

    // Real-time Mobile Search integration
    const toggleSearchBtn = document.getElementById('toggle-search-btn');
    const closeSearchBtn = document.getElementById('close-search-btn');
    const headerStandardView = document.getElementById('header-standard-view');
    const headerSearchView = document.getElementById('header-search-view');
    const mobileSearchInput = document.getElementById('mobile-explore-search') as HTMLInputElement;

    if (toggleSearchBtn && closeSearchBtn && headerStandardView && headerSearchView) {
      toggleSearchBtn.addEventListener('click', () => {
        headerStandardView.classList.add('hidden');
        headerSearchView.classList.remove('hidden');
        if (mobileSearchInput) mobileSearchInput.focus();
      });

      closeSearchBtn.addEventListener('click', () => {
        headerSearchView.classList.add('hidden');
        headerStandardView.classList.remove('hidden');
        if (mobileSearchInput) {
          mobileSearchInput.value = '';
          performFilter('', currentCategory);
        }
      });
    }

    if (mobileSearchInput) {
      let debounceTimeout: any = null;
      mobileSearchInput.addEventListener('input', () => {
        clearTimeout(debounceTimeout);
        debounceTimeout = setTimeout(() => {
          performFilter(mobileSearchInput.value.trim(), currentCategory);
        }, 400);
      });
    }

    // Infinite Scrolling Logic
    let currentPage = 1;
    let isLoading = false;
    let hasMore = true;
    
    if (sentinel && listPostsWrapper) {
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && !isLoading && hasMore && !isFiltering) {
          loadMoreArticles();
        }
      }, { rootMargin: '100px' });
      
      observer.observe(sentinel);
      
      async function loadMoreArticles() {
        isLoading = true;
        sentinel?.classList.remove('opacity-0');
        
        try {
          currentPage++;
          const cacheKey = `pexih_explore_page_${currentPage}`;
          const cachedData = sessionStorage.getItem(cacheKey);
          let newArticles;
          
          if (cachedData) {
            newArticles = JSON.parse(cachedData);
          } else {
            const res = await fetch(`${backendUrl}/api/articles?page=${currentPage}&limit=5`); 
            if (!res.ok) throw new Error('Failed');
            newArticles = await res.json();
            sessionStorage.setItem(cacheKey, JSON.stringify(newArticles));
          }
          
          if (newArticles.length === 0) {
            hasMore = false;
            if (sentinel) sentinel.classList.add('hidden');
            return;
          }
          
          newArticles.forEach((item: any, index: number) => {
            const articleHtml = `
              <a href="/article/${item.id}" class="flex gap-3 items-center group article-item animate-fade-in" style="animation-delay: ${index * 75}ms">
                <div class="w-20 h-20 rounded-lg overflow-hidden pexih-placeholder bg-gray-100 dark:bg-gray-800 shrink-0 aspect-square">
                  <img 
                    src="${item.img || `https://images.unsplash.com/photo-${1550000000000 + index}?auto=format,compress&fit=crop&w=200&q=80`}" 
                    alt="Thumbnail" 
                    width="80" height="80"
                    class="w-full h-full object-cover aspect-square transition-opacity duration-300 opacity-0" 
                    onload="this.classList.remove('opacity-0')"
                    loading="lazy" referrerpolicy="no-referrer" 
                  />
                </div>
                <div class="flex-1 min-w-0">
                  <span class="text-[9px] text-orange-600 dark:text-orange-500 font-bold uppercase tracking-wider">${item.category || 'Trending'}</span>
                  <h4 class="text-[12px] font-bold text-gray-900 dark:text-white leading-tight mt-0.5 mb-1 group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors line-clamp-2">${item.title}</h4>
                  <p class="text-[9px] text-gray-500 dark:text-gray-400">${item.createdAt ? new Date(Number(item.createdAt)).toLocaleDateString() : 'Recent'} • ${item.readTime || '5 min read'}</p>
                </div>
              </a>
            `;
            listPostsWrapper.insertAdjacentHTML('beforeend', articleHtml);
          });
        } catch (e) {
          console.error("Failed to load more", e);
        } finally {
          isLoading = false;
          if (sentinel && hasMore) sentinel.classList.add('opacity-0');
        }
      }
    }
  });
</script>

