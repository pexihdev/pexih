---
import AdminMobileLayout from '../../layouts/AdminMobileLayout.astro';
---
<AdminMobileLayout title="Settings" showBottomNav={false}>
  <div class="fixed top-0 w-full max-w-[400px] z-50" transition:name="mobile-header">
    <div class="w-full bg-white dark:bg-gray-900" style="height: env(safe-area-inset-top);"></div>
    <div class="bg-white dark:bg-gray-900 pt-3 pb-2 px-5 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between h-[53px]">
      <button onclick="history.back()" aria-label="Back" class="w-8 h-8 flex items-center justify-start text-gray-900 dark:text-white hover:text-orange-500 transition-colors z-10">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <h1 class="text-[16px] font-bold absolute left-1/2 -translate-x-1/2 w-[60%] text-center truncate">Settings</h1>
      <button class="bg-orange-600 text-white px-3 py-1.5 rounded text-[10px] font-bold hover:bg-orange-700 transition-colors z-10">
        Save
      </button>
    </div>
  </div>

  <div class="shrink-0" style="height: calc(53px + env(safe-area-inset-top));"></div>
  <div class="p-4 space-y-4">
    <!-- Global SEO Metadata -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 shadow-sm p-4 space-y-4">
      <h2 class="text-[12px] font-bold text-gray-900 dark:text-white mb-2">Global SEO Metadata</h2>
      
      <div>
        <label class="block text-[10px] font-bold text-gray-700 dark:text-gray-300 mb-1.5 uppercase tracking-wider">Site Name</label>
        <input type="text" value="PEXIH" class="w-full px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[12px] focus:outline-none focus:border-orange-500 transition-colors dark:text-white" />
      </div>
      
      <div>
        <label class="block text-[10px] font-bold text-gray-700 dark:text-gray-300 mb-1.5 uppercase tracking-wider">Meta Description</label>
        <textarea class="w-full px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[12px] focus:outline-none focus:border-orange-500 transition-colors resize-none min-h-[60px] dark:text-white">A modern publishing platform built with Astro and Node.js.</textarea>
      </div>
    </div>

    <!-- Social Media URLs -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 shadow-sm p-4 space-y-4">
      <h2 class="text-[12px] font-bold text-gray-900 dark:text-white mb-2">Social Media</h2>
      
      <div>
        <label class="block text-[10px] font-bold text-gray-700 dark:text-gray-300 mb-1.5 uppercase tracking-wider">Twitter URL</label>
        <input type="url" placeholder="https://twitter.com/..." class="w-full px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[12px] focus:outline-none focus:border-orange-500 transition-colors dark:text-white" />
      </div>

      <div>
        <label class="block text-[10px] font-bold text-gray-700 dark:text-gray-300 mb-1.5 uppercase tracking-wider">Instagram URL</label>
        <input type="url" placeholder="https://instagram.com/..." class="w-full px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[12px] focus:outline-none focus:border-orange-500 transition-colors dark:text-white" />
      </div>
    </div>

    <!-- System Control -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 shadow-sm p-4">
      <h2 class="text-[12px] font-bold text-gray-900 dark:text-white mb-3">System Control</h2>
      
      <div class="flex flex-col gap-4 mb-4 pb-4 border-b border-gray-100 dark:border-gray-800">
        <div>
          <label class="block text-[10px] font-bold text-gray-700 dark:text-gray-300 mb-1.5 uppercase tracking-wider">Admin Language</label>
          <select id="admin-language-select" class="w-full px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[12px] focus:outline-none focus:border-orange-500 transition-colors dark:text-white">
            <option value="en">🇺🇸 English</option>
            <option value="id">🇮🇩 Bahasa Indonesia</option>
            <option value="es">🇪🇸 Español</option>
            <option value="fr">🇫🇷 Français</option>
            <option value="de">🇩🇪 Deutsch</option>
            <option value="zh-CN">🇨🇳 中文 (Simplified)</option>
            <option value="ja">🇯🇵 日本語 (Japanese)</option>
            <option value="ru">🇷🇺 Русский</option>
            <option value="ar">🇸🇦 العربية (Arabic)</option>
            <option value="hi">🇮🇳 हिन्दी (Hindi)</option>
            <option value="bn">🇧🇩 বাংলা (Bengali)</option>
            <option value="pt">🇵🇹 Português</option>
            <option value="ur">🇵🇰 اردو (Urdu)</option>
            <option value="ko">🇰🇷 한국어 (Korean)</option>
            <option value="it">🇮🇹 Italiano (Italian)</option>
          </select>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <div class="flex items-center justify-between">
          <p class="text-[12px] font-bold text-gray-900 dark:text-white">Maintenance Mode</p>
          <label class="relative inline-flex items-center cursor-pointer">
            <input aria-label="Maintenance Mode" type="checkbox" value="" class="sr-only peer">
            <div class="w-9 h-5 bg-gray-200 dark:bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-orange-600"></div>
          </label>
        </div>
        <p class="text-[9px] text-gray-500 dark:text-gray-400 leading-relaxed">
          Forces frontend mobile & desktop offline for repair. Admin panel remains accessible.
        </p>
      </div>
    </div>
    
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 shadow-sm overflow-hidden">
      <button class="w-full flex items-center justify-between p-4 text-left hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
        <span class="text-[12px] font-bold text-gray-900 dark:text-white">API Keys Configuration</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <div class="border-t border-gray-100 dark:border-gray-800"></div>
      <button class="w-full flex items-center justify-between p-4 text-left hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
        <span class="text-[12px] font-bold text-gray-900 dark:text-white">Admin Roles & Permissions</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>

    <!-- Danger Zone -->
    <button id="admin-logout-btn" class="w-full flex items-center justify-between p-4 bg-white dark:bg-gray-900 rounded-xl border border-red-100 dark:border-red-900/30 shadow-sm hover:bg-red-50 dark:hover:bg-red-950/20 transition-colors group mt-4">
      <span class="text-[12px] font-bold text-red-600 dark:text-red-500">Sign Out Admin</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-400 group-hover:text-red-500"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
    </button>
  </div>
  
  <script>
    document.addEventListener('astro:page-load', () => {
      const logoutBtn = document.getElementById('admin-logout-btn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', async () => {
          try {
            const res = await fetch('/api/auth/logout', { method: 'POST' });
            if (res.ok) {
              window.location.href = '/admin/login';
            }
          } catch (e) {
            console.error(e);
            window.toast('Logout failed');
          }
        });
      }

      const select = document.getElementById('admin-language-select') as HTMLSelectElement;
      if (select) {
        const currentLang = localStorage.getItem('admin_language') || 'en';
        select.value = currentLang;

        select.addEventListener('change', (e) => {
          const newLang = (e.target as HTMLSelectElement).value;
          localStorage.setItem('admin_language', newLang);
          window.toast('Language updated');
          
          function setCookie(name: string, value: string) {
					  const host = location.hostname;
            document.cookie = name + '=' + value + '; path=/; max-age=31536000; SameSite=Lax';
            document.cookie = name + '=' + value + '; domain=' + host + '; path=/; max-age=31536000; SameSite=Lax';
            document.cookie = name + '=' + value + '; domain=.' + host + '; path=/; max-age=31536000; SameSite=Lax';
          }
          if (newLang !== 'en') {
            setCookie('googtrans', '/en/' + newLang);
          } else {
            document.cookie = 'googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
            document.cookie = 'googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; domain=' + location.hostname + '; path=/;';
            document.cookie = 'googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; domain=.' + location.hostname + '; path=/;';
          }
          setTimeout(() => {
            window.location.reload();
          }, 1000);
        });
      }
    });
  </script>
</AdminMobileLayout>
