---
import AdminMobileLayout from '../../layouts/AdminMobileLayout.astro';

// Fetch initially for SSR speed
let initialCategories = [];
try {
  const backendUrl = import.meta.env.PUBLIC_BACKEND_URL || 'http://localhost:8080';
  const res = await fetch(`${backendUrl}/api/categories`);
  if (res.ok) {
    initialCategories = await res.json();
  }
} catch (e) {
  console.error("Failed to fetch categories", e);
}
---
<AdminMobileLayout title="Categories" showBottomNav={false}>
  <!-- Top Header Navbar -->
  <div class="fixed top-0 w-full max-w-[400px] z-50">
    <div class="w-full h-[max(env(safe-area-inset-top),16px)] bg-gray-900"></div>
    <div class="bg-gray-900 text-white pt-3 pb-2 px-5 border-b border-gray-800 flex items-center justify-between">
      <button aria-label="Back" onclick="history.back()" class="text-gray-400 hover:text-white transition-colors cursor-pointer p-1 rounded-lg">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <h1 class="text-[14px] font-bold">PE<span class="text-orange-600">X</span>IH Categories</h1>
      <button id="add-category-btn" aria-label="Add Category" class="bg-orange-600 hover:bg-orange-700 text-white p-1 rounded-lg transition-colors cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
      </button>
    </div>
  </div>

  <div class="" style="height: calc(52px + max(env(safe-area-inset-top), 16px));"></div>
  <div class="p-4 pb-12 space-y-4">
    <!-- Search -->
    <div class="relative">
      <input type="text" id="category-search" placeholder="Search categories..." class="w-full pl-9 pr-4 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[11px] focus:outline-none focus:ring-2 focus:ring-orange-500 transition-colors dark:text-white" />
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    </div>

    <!-- Category Cards List -->
    <div class="space-y-3" id="categories-list">
      {initialCategories.map((cat) => (
        <div data-id={cat.id} data-title={cat.title.toLowerCase()} class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-3.5 shadow-sm space-y-2.5 transition-all">
          <div class="flex items-start justify-between">
            <div class="flex items-center gap-2.5">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white" style={`background-color: ${cat.color || '#FF6B00'}`}>
                <span class="text-[12px] font-bold uppercase">{cat.title.substring(0, 2)}</span>
              </div>
              <div>
                <h3 class="text-[12px] font-bold text-gray-900 dark:text-white">{cat.title}</h3>
                <span class="text-[8px] font-bold uppercase tracking-wider text-orange-600">{cat.count || '0'} Articles</span>
              </div>
            </div>
            
            <div class="flex items-center gap-1.5">
              <button class="edit-cat-btn text-gray-400 hover:text-orange-600 p-1 rounded-md hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors cursor-pointer" data-id={cat.id} data-title={cat.title} data-desc={cat.desc} data-color={cat.color} data-icon={cat.iconName} data-count={cat.count}>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
              </button>
              <button class="delete-cat-btn text-gray-400 hover:text-red-600 p-1 rounded-md hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors cursor-pointer" data-id={cat.id} data-title={cat.title}>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
              </button>
            </div>
          </div>
          
          <p class="text-[10px] text-gray-500 dark:text-gray-400 leading-relaxed bg-gray-50 dark:bg-gray-800/40 p-2 rounded-lg">{cat.desc || 'No description provided.'}</p>
        </div>
      ))}
    </div>

    <!-- Empty State -->
    <div id="categories-empty" class="hidden text-center py-12">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-gray-300 dark:text-gray-700 mb-3"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
      <p class="text-[12px] font-bold text-gray-900 dark:text-white">No categories found</p>
      <p class="text-[10px] text-gray-500 dark:text-gray-400 mt-1">Create a new category to get started.</p>
    </div>
  </div>

  <!-- Category Editor Sheet (Dialog) -->
  <div id="category-editor-modal" class="fixed inset-0 z-[60] bg-black/50 backdrop-blur-sm hidden items-end sm:items-center justify-center">
    <div class="bg-white dark:bg-gray-900 w-full max-w-[400px] sm:max-w-[340px] rounded-t-2xl sm:rounded-2xl shadow-2xl p-5 transform translate-y-full sm:scale-95 sm:translate-y-0 transition-all duration-300" id="editor-modal-content">
      <div class="flex items-center justify-between mb-4 pb-2 border-b border-gray-100 dark:border-gray-800">
        <h3 id="editor-modal-title" class="text-[13px] font-bold text-gray-900 dark:text-white">Add Category</h3>
        <button id="editor-modal-close" class="text-gray-400 hover:text-gray-900 dark:hover:text-white p-1 rounded-lg transition-colors cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      
      <form id="category-form" class="space-y-3.5">
        <input type="hidden" id="form-cat-id" />
        
        <div>
          <label class="block text-[10px] font-bold text-gray-700 dark:text-gray-300 mb-1">Title</label>
          <input type="text" id="form-cat-title" required placeholder="e.g. Minimalism" class="w-full px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[11px] focus:outline-none focus:ring-2 focus:ring-orange-500 transition-colors dark:text-white" />
        </div>

        <div>
          <label class="block text-[10px] font-bold text-gray-700 dark:text-gray-300 mb-1">Description</label>
          <textarea id="form-cat-desc" required placeholder="A short description of this category..." rows="3" class="w-full px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[11px] focus:outline-none focus:ring-2 focus:ring-orange-500 transition-colors dark:text-white resize-none"></textarea>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[10px] font-bold text-gray-700 dark:text-gray-300 mb-1">Color Accent</label>
            <div class="flex gap-2">
              <input type="color" id="form-cat-color" value="#FF6B00" class="w-8 h-8 rounded border-0 p-0 cursor-pointer overflow-hidden" />
              <input type="text" id="form-cat-color-text" value="#FF6B00" class="flex-1 px-2.5 py-1.5 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[10px] font-mono focus:outline-none focus:ring-2 focus:ring-orange-500 transition-colors dark:text-white uppercase" />
            </div>
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-700 dark:text-gray-300 mb-1">Articles Count</label>
            <input type="text" id="form-cat-count" placeholder="0" class="w-full px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[11px] focus:outline-none focus:ring-2 focus:ring-orange-500 transition-colors dark:text-white" />
          </div>
        </div>

        <div>
          <label class="block text-[10px] font-bold text-gray-700 dark:text-gray-300 mb-1">Icon Identifier</label>
          <input type="text" id="form-cat-icon" placeholder="Hash" class="w-full px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[11px] focus:outline-none focus:ring-2 focus:ring-orange-500 transition-colors dark:text-white" />
        </div>

        <div class="pt-2 flex gap-3">
          <button type="button" id="form-cancel" class="flex-1 py-2 rounded-lg border border-gray-200 dark:border-gray-700 text-[11px] font-bold text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors cursor-pointer">
            Cancel
          </button>
          <button type="submit" class="flex-1 py-2 rounded-lg bg-orange-600 hover:bg-orange-700 text-white text-[11px] font-bold transition-colors cursor-pointer">
            Save
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="delete-confirm-modal" class="fixed inset-0 z-[60] bg-black/50 backdrop-blur-sm hidden items-center justify-center p-4">
    <div class="bg-white dark:bg-gray-900 w-full max-w-[320px] rounded-xl shadow-2xl p-5 transform scale-95 opacity-0 transition-all duration-200" id="delete-modal-content">
      <div class="w-12 h-12 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center text-red-600 dark:text-red-500 mb-4 mx-auto">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
      </div>
      <h3 class="text-[14px] font-bold text-gray-900 dark:text-white text-center mb-2">Delete Category</h3>
      <p id="delete-desc" class="text-[10px] text-gray-500 dark:text-gray-400 text-center mb-6 leading-relaxed">Are you sure you want to permanently delete this category? This action cannot be undone.</p>
      
      <div class="flex gap-3">
        <button id="delete-modal-cancel" class="flex-1 py-2.5 rounded-lg border border-gray-200 dark:border-gray-700 text-[10px] font-bold text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors cursor-pointer">
          Cancel
        </button>
        <button id="delete-modal-confirm" class="flex-1 py-2.5 rounded-lg bg-red-600 text-white text-[10px] font-bold hover:bg-red-700 transition-colors cursor-pointer">
          Yes, Delete
        </button>
      </div>
    </div>
  </div>

  <script>
    let activeDeleteId = null;

    document.addEventListener('astro:page-load', () => {
      const searchInput = document.getElementById('category-search');
      const categoriesList = document.getElementById('categories-list');
      const emptyState = document.getElementById('categories-empty');
      
      // Real-time search handler
      if (searchInput && categoriesList) {
        searchInput.addEventListener('input', (e) => {
          const query = e.target.value.toLowerCase().trim();
          const items = categoriesList.querySelectorAll('[data-id]');
          let visibleCount = 0;
          
          items.forEach((item) => {
            const title = item.getAttribute('data-title') || '';
            if (title.includes(query)) {
              item.classList.remove('hidden');
              visibleCount++;
            } else {
              item.classList.add('hidden');
            }
          });
          
          if (visibleCount === 0) {
            emptyState?.classList.remove('hidden');
          } else {
            emptyState?.classList.add('hidden');
          }
        });
      }

      // Modals setup
      const editorModal = document.getElementById('category-editor-modal');
      const editorModalContent = document.getElementById('editor-modal-content');
      const editorTitle = document.getElementById('editor-modal-title');
      const categoryForm = document.getElementById('category-form');
      const addBtn = document.getElementById('add-category-btn');
      
      const formId = document.getElementById('form-cat-id');
      const formTitle = document.getElementById('form-cat-title');
      const formDesc = document.getElementById('form-cat-desc');
      const formColor = document.getElementById('form-cat-color');
      const formColorText = document.getElementById('form-cat-color-text');
      const formCount = document.getElementById('form-cat-count');
      const formIcon = document.getElementById('form-cat-icon');

      const closeEditor = () => {
        if (!editorModalContent || !editorModal) return;
        editorModalContent.classList.add('translate-y-full', 'sm:scale-95', 'sm:translate-y-0');
        setTimeout(() => {
          editorModal.classList.add('hidden');
          editorModal.classList.remove('flex');
          categoryForm?.reset();
          formId.value = '';
        }, 300);
      };

      const openEditor = (isEdit = false, data = {}) => {
        if (!editorModalContent || !editorModal) return;
        editorTitle.textContent = isEdit ? 'Edit Category' : 'Add Category';
        
        if (isEdit) {
          formId.value = data.id || '';
          formTitle.value = data.title || '';
          formDesc.value = data.desc || '';
          formColor.value = data.color || '#FF6B00';
          formColorText.value = data.color || '#FF6B00';
          formCount.value = data.count || '0';
          formIcon.value = data.icon || 'Hash';
        } else {
          formId.value = '';
          formTitle.value = '';
          formDesc.value = '';
          formColor.value = '#FF6B00';
          formColorText.value = '#FF6B00';
          formCount.value = '0';
          formIcon.value = 'Hash';
        }

        editorModal.classList.remove('hidden');
        editorModal.classList.add('flex');
        void editorModal.offsetWidth;
        editorModalContent.classList.remove('translate-y-full', 'sm:scale-95');
      };

      // Sync color picker with text input
      if (formColor && formColorText) {
        formColor.addEventListener('input', (e) => {
          formColorText.value = e.target.value.toUpperCase();
        });
        formColorText.addEventListener('input', (e) => {
          if (e.target.value.startsWith('#') && e.target.value.length === 7) {
            formColor.value = e.target.value;
          }
        });
      }

      // Event Listeners for actions
      if (addBtn) {
        addBtn.addEventListener('click', () => openEditor(false));
      }
      
      const closeEditorBtn = document.getElementById('editor-modal-close');
      if (closeEditorBtn) closeEditorBtn.addEventListener('click', closeEditor);
      const cancelFormBtn = document.getElementById('form-cancel');
      if (cancelFormBtn) cancelFormBtn.addEventListener('click', closeEditor);

      // Submit Form
      if (categoryForm) {
        categoryForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const payload = {
            id: formId.value ? Number(formId.value) : undefined,
            title: formTitle.value.trim(),
            desc: formDesc.value.trim(),
            color: formColorText.value.trim(),
            count: formCount.value.trim() || '0',
            iconName: formIcon.value.trim() || 'Hash'
          };

          try {
            const method = payload.id ? 'PUT' : 'POST';
            const url = payload.id ? `/api/categories?id=${payload.id}` : '/api/categories';
            
            const res = await fetch(url, {
              method,
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload)
            });

            if (!res.ok) throw new Error('Failed to save category');
            
            window.toast(payload.id ? 'Category updated' : 'Category added');
            closeEditor();
            
            // Refresh screen to reflect DB state
            setTimeout(() => {
              window.location.reload();
            }, 500);
          } catch (err) {
            window.toast('Error: ' + err.message);
          }
        });
      }

      // Delegate edit and delete clicks in list
      document.addEventListener('click', (e) => {
        const target = e.target;
        
        // Edit button
        const editBtn = target.closest('.edit-cat-btn');
        if (editBtn) {
          const data = {
            id: editBtn.getAttribute('data-id'),
            title: editBtn.getAttribute('data-title'),
            desc: editBtn.getAttribute('data-desc'),
            color: editBtn.getAttribute('data-color'),
            icon: editBtn.getAttribute('data-icon'),
            count: editBtn.getAttribute('data-count')
          };
          openEditor(true, data);
          return;
        }

        // Delete button
        const deleteBtn = target.closest('.delete-cat-btn');
        if (deleteBtn) {
          activeDeleteId = deleteBtn.getAttribute('data-id');
          const title = deleteBtn.getAttribute('data-title');
          
          const delModal = document.getElementById('delete-confirm-modal');
          const delContent = document.getElementById('delete-modal-content');
          const delDesc = document.getElementById('delete-desc');
          
          if (delModal && delContent) {
            delDesc.textContent = `Are you sure you want to permanently delete category "${title}"? This action cannot be undone.`;
            delModal.classList.remove('hidden');
            delModal.classList.add('flex');
            void delModal.offsetWidth;
            delContent.classList.remove('scale-95', 'opacity-0');
            delContent.classList.add('scale-100', 'opacity-100');
          }
        }
      });

      // Cancel Delete
      const cancelDelBtn = document.getElementById('delete-modal-cancel');
      const delModal = document.getElementById('delete-confirm-modal');
      const delContent = document.getElementById('delete-modal-content');

      const closeDeleteModal = () => {
        if (!delContent || !delModal) return;
        delContent.classList.remove('scale-100', 'opacity-100');
        delContent.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
          delModal.classList.add('hidden');
          delModal.classList.remove('flex');
          activeDeleteId = null;
        }, 200);
      };

      if (cancelDelBtn) cancelDelBtn.addEventListener('click', closeDeleteModal);

      // Confirm Delete
      const confirmDelBtn = document.getElementById('delete-modal-confirm');
      if (confirmDelBtn) {
        confirmDelBtn.addEventListener('click', async () => {
          if (!activeDeleteId) return;
          try {
            const res = await fetch(`/api/categories?id=${activeDeleteId}`, {
              method: 'DELETE'
            });

            if (!res.ok) throw new Error('Failed to delete category');
            
            window.toast('Category deleted');
            closeDeleteModal();
            
            // Remove from list dynamically or reload
            const card = document.querySelector(`[data-id="${activeDeleteId}"]`);
            if (card) {
              card.remove();
              // Check empty state
              const list = document.getElementById('categories-list');
              if (list && list.children.length === 0) {
                document.getElementById('categories-empty')?.classList.remove('hidden');
              }
            } else {
              window.location.reload();
            }
          } catch (err) {
            window.toast('Error: ' + err.message);
          }
        });
      }
    });
  </script>
</AdminMobileLayout>
