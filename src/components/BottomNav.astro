---
const currentPath = Astro.url.pathname;
---

<div class="fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-[400px] z-50">
  <nav class="w-full h-[52px] bg-white/90 dark:bg-gray-900/90 backdrop-blur-md border-t border-gray-100 dark:border-gray-800 flex items-center justify-around px-2">
    <a href="/" class={`flex flex-col items-center justify-center w-12 h-full gap-1 transition-all duration-200 active:scale-95 ease-out ${currentPath === '/' ? 'text-orange-600' : 'text-gray-400 hover:text-gray-600'}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span class="text-[8px] font-medium" data-i18n="nav.home">Home</span>
    </a>
    <a href="/explore" class={`flex flex-col items-center justify-center w-12 h-full gap-1 transition-all duration-200 active:scale-95 ease-out ${currentPath.startsWith('/explore') ? 'text-orange-600' : 'text-gray-400 hover:text-gray-600'}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <span class="text-[8px] font-medium" data-i18n="nav.explore">Explore</span>
    </a>
    <a href="/writer" aria-label="Create Post" class="flex flex-col items-center justify-center w-12 h-full relative -top-3 transition-all duration-200 active:scale-95 ease-out">
      <div class="w-10 h-10 rounded-full bg-orange-600 text-white flex items-center justify-center shadow-lg shadow-orange-600/30">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
      </div>
    </a>
    <a href="/bookmarks" class={`flex flex-col items-center justify-center w-12 h-full gap-1 transition-all duration-200 active:scale-95 ease-out ${currentPath.startsWith('/bookmarks') ? 'text-orange-600' : 'text-gray-400 hover:text-gray-600'}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
      <span class="text-[8px] font-medium" data-i18n="nav.bookmark">Saved</span>
    </a>
    <a href="/profile" class={`flex flex-col items-center justify-center w-12 h-full gap-1 transition-all duration-200 active:scale-95 ease-out ${currentPath.startsWith('/profile') ? 'text-orange-600' : 'text-gray-400 hover:text-gray-600'}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      <span class="text-[8px] font-medium" data-i18n="nav.profile">Profile</span>
    </a>
  </nav>
  <div class="w-full bg-white/90 dark:bg-gray-900/90 backdrop-blur-md" style="height: env(safe-area-inset-bottom);"></div>
</div>
