---
import Layout from './Layout.astro';

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
}

const { title, description, keywords } = Astro.props;
const currentPath = Astro.url.pathname;
---

<Layout title={title} description={description} keywords={keywords}>
	<div class="flex h-screen overflow-hidden bg-gray-50 dark:bg-gray-900 w-full" style="padding-top: env(safe-area-inset-top); padding-bottom: env(safe-area-inset-bottom);">
		<aside id="desktop-sidebar" class="w-64 bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800 sticky top-0 h-full flex flex-col shrink-0 transition-all duration-300">
			<script is:inline>
				(function() {
					if (localStorage.getItem('desktop-sidebar-collapsed') === 'true') {
						const aside = document.currentScript.parentElement;
						aside.classList.remove('w-64');
						aside.classList.add('w-[70px]');
					}
				})();
			</script>
			<div class="p-5 flex items-center justify-between border-b border-gray-100 dark:border-gray-800">
				<div class="flex items-center gap-2 overflow-hidden brand-container">
					<div class="w-8 h-8 rounded-lg bg-orange-600 text-white flex items-center justify-center font-bold shrink-0">P</div>
					<span class="font-bold text-gray-900 dark:text-white whitespace-nowrap sidebar-text">PE<span class="text-orange-600">X</span>IH Desktop</span>
				</div>
				<button id="toggle-sidebar" class="p-1 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors cursor-pointer" aria-label="Toggle Sidebar">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg>
				</button>
			</div>
			
			<nav class="flex-1 py-4 px-3 space-y-1">
				<a href="/desktop" class={`flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 active:scale-95 ease-out ${currentPath === '/desktop' ? 'bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-500 font-medium' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'}`}>
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
					<span class="text-sm sidebar-text" data-i18n="nav.home">Home</span>
				</a>
				<a href="/desktop/explore" class={`flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 active:scale-95 ease-out ${currentPath.startsWith('/desktop/explore') ? 'bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-500 font-medium' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'}`}>
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
					<span class="text-sm sidebar-text" data-i18n="nav.explore">Explore</span>
				</a>
				<a href="/desktop/writer" class={`flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 active:scale-95 ease-out ${currentPath.startsWith('/desktop/writer') ? 'bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-500 font-medium' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'}`}>
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
					<span class="text-sm sidebar-text">Create Post</span>
				</a>
				<a href="/desktop/bookmarks" class={`flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 active:scale-95 ease-out ${currentPath.startsWith('/desktop/bookmarks') ? 'bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-500 font-medium' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'}`}>
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
					<span class="text-sm sidebar-text" data-i18n="nav.bookmark">Saved</span>
				</a>
				<a href="/desktop/profile" class={`flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 active:scale-95 ease-out ${currentPath.startsWith('/desktop/profile') ? 'bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-500 font-medium' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'}`}>
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
					<span class="text-sm sidebar-text" data-i18n="nav.profile">Profile</span>
				</a>
			</nav>
			
			<div class="p-4 border-t border-gray-100 dark:border-gray-800">
				<a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
					<span class="text-sm sidebar-text">Switch to Mobile</span>
				</a>
			</div>
		</aside>

		<style is:global>
			/* When sidebar is collapsed */
			aside.w-\[70px\] {
				width: 70px !important;
			}
			aside.w-\[70px\] .sidebar-text {
				display: none !important;
			}
			aside.w-\[70px\] .brand-container {
				justify-content: center !important;
			}
			aside.w-\[70px\] .p-5 {
				padding-left: 0.5rem !important;
				padding-right: 0.5rem !important;
				flex-direction: column !important;
				align-items: center !important;
				justify-content: center !important;
				gap: 0.75rem !important;
			}
			aside.w-\[70px\] .p-4 {
				padding-left: 0.5rem !important;
				padding-right: 0.5rem !important;
			}
			aside.w-\[70px\] .p-4 a {
				justify-content: center !important;
				padding-left: 0.5rem !important;
				padding-right: 0.5rem !important;
				gap: 0 !important;
			}
			aside.w-\[70px\] nav {
				padding-left: 0.5rem !important;
				padding-right: 0.5rem !important;
			}
			aside.w-\[70px\] nav a {
				justify-content: center !important;
				padding-left: 0.5rem !important;
				padding-right: 0.5rem !important;
				gap: 0 !important;
			}
		</style>

		<script>
			function setupSidebarToggle() {
				const aside = document.getElementById('desktop-sidebar');
				const toggleBtn = document.getElementById('toggle-sidebar');
				if (!aside || !toggleBtn) return;

				// Restore state from localStorage
				const isCurrentlyCollapsed = localStorage.getItem('desktop-sidebar-collapsed') === 'true';
				if (isCurrentlyCollapsed) {
					aside.classList.remove('w-64');
					aside.classList.add('w-[70px]');
				} else {
					aside.classList.remove('w-[70px]');
					aside.classList.add('w-64');
				}

				toggleBtn.addEventListener('click', () => {
					const isCollapsed = aside.classList.contains('w-[70px]');
					if (isCollapsed) {
						aside.classList.remove('w-[70px]');
						aside.classList.add('w-64');
						localStorage.setItem('desktop-sidebar-collapsed', 'false');
					} else {
						aside.classList.remove('w-64');
						aside.classList.add('w-[70px]');
						localStorage.setItem('desktop-sidebar-collapsed', 'true');
					}
				});
			}

			// Run on initial load and on every page navigation
			setupSidebarToggle();
			document.addEventListener('astro:page-load', setupSidebarToggle);
		</script>
		
		<main id="desktop-main-wrapper" class="flex-1 min-h-0 w-full flex flex-col overflow-y-auto bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 relative scroll-smooth">
			<slot />

			<!-- Desktop Scroll To Top FAB -->
			<button 
				id="desktop-scroll-to-top-fab"
				aria-label="Scroll to top" 
				class="fixed bottom-8 right-8 w-12 h-12 bg-orange-600 text-white rounded-full shadow-lg flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300 z-[60] hover:bg-orange-700 active:scale-95"
				style="transform: translateY(20px);"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
			</button>
		</main>

		<script is:inline>
			document.addEventListener('astro:page-load', () => {
				const wrapper = document.getElementById('desktop-main-wrapper');
				const fab = document.getElementById('desktop-scroll-to-top-fab');
				
				if (wrapper && fab) {
					wrapper.addEventListener('scroll', () => {
						if (wrapper.scrollTop > 400) {
							fab.classList.remove('opacity-0', 'pointer-events-none');
							fab.style.transform = 'translateY(0)';
						} else {
							fab.classList.add('opacity-0', 'pointer-events-none');
							fab.style.transform = 'translateY(20px)';
						}
					});

					fab.addEventListener('click', () => {
						wrapper.scrollTo({ top: 0, behavior: 'smooth' });
					});
				}
			});
		</script>
	</div>
</Layout>
