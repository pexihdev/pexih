---
import DesktopLayout from '../../layouts/DesktopLayout.astro';
---
<DesktopLayout title="Analytics">
  <div class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 pt-3 pb-2 px-5 flex items-center justify-between h-[53px] sticky top-0 z-50">
    <div>
      <h1 class="text-xl font-bold text-gray-900 dark:text-white">Analytics</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Detailed view of your platform performance.</p>
    </div>
    <div class="flex items-center gap-3">
      <select aria-label="Time period" class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 px-4 py-2 rounded-lg text-sm font-bold focus:outline-none focus:ring-2 focus:ring-orange-500">
        <option>Last 7 Days</option>
        <option>Last 30 Days</option>
        <option>This Year</option>
      </select>
    </div>
  </div>

  <div class="p-8">
    <!-- Chart Placeholder -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm p-6 mb-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-bold text-gray-900 dark:text-white">Traffic Overview</h2>
        <div class="flex items-center gap-4 text-sm">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-orange-600"></span>
            <span class="text-gray-600 dark:text-gray-400">Desktop</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-gray-300 dark:bg-gray-600"></span>
            <span class="text-gray-600 dark:text-gray-400">Mobile</span>
          </div>
        </div>
      </div>
      <div class="h-64 flex items-end justify-between gap-2 border-b border-l border-gray-100 dark:border-gray-800 pb-2 pl-2">
        {[40, 60, 45, 80, 55, 90, 75].map((h) => (
          <div class="w-full flex justify-center gap-1 h-full items-end group relative">
            <div class={`w-1/2 bg-gray-300 dark:bg-gray-600 rounded-t-sm transition-all group-hover:opacity-80`} style={`height: ${h * 0.4}%`}></div>
            <div class={`w-1/2 bg-orange-600 rounded-t-sm transition-all group-hover:opacity-80`} style={`height: ${h}%`}></div>
          </div>
        ))}
      </div>
      <div class="flex justify-between mt-2 text-xs text-gray-400 dark:text-gray-500 font-medium">
        <span>Mon</span>
        <span>Tue</span>
        <span>Wed</span>
        <span>Thu</span>
        <span>Fri</span>
        <span>Sat</span>
        <span>Sun</span>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm p-6">
        <h2 class="text-base font-bold text-gray-900 dark:text-white mb-4">Top Pages</h2>
        <div class="space-y-4">
          {[
            { path: '/explore/tech', views: '12.4k' },
            { path: '/post/future-of-web', views: '8.2k' },
            { path: '/profile/johndoe', views: '3.1k' }
          ].map((item, i) => (
            <div class="flex items-center justify-between pb-3 border-b border-gray-100 dark:border-gray-800 last:border-0 last:pb-0">
              <div class="flex items-center gap-3">
                <span class="text-sm font-bold text-gray-400 dark:text-gray-500">{i + 1}</span>
                <span class="text-sm text-gray-700 dark:text-gray-300 font-medium">{item.path}</span>
              </div>
              <span class="text-sm font-bold text-gray-900 dark:text-white">{item.views}</span>
            </div>
          ))}
        </div>
      </div>
      
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm p-6">
        <h2 class="text-base font-bold text-gray-900 dark:text-white mb-4">Device Breakdown</h2>
        <div class="space-y-4">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-500 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
            </div>
            <div class="flex-1">
              <div class="flex justify-between mb-1">
                <span class="text-sm font-bold text-gray-900 dark:text-white">Mobile</span>
                <span class="text-sm font-bold text-gray-500 dark:text-gray-400">65%</span>
              </div>
              <div class="h-2 w-full bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden">
                <div class="h-full bg-orange-600 rounded-full" style="width: 65%"></div>
              </div>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-400 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
            </div>
            <div class="flex-1">
              <div class="flex justify-between mb-1">
                <span class="text-sm font-bold text-gray-900 dark:text-white">Desktop</span>
                <span class="text-sm font-bold text-gray-500 dark:text-gray-400">35%</span>
              </div>
              <div class="h-2 w-full bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden">
                <div class="h-full bg-gray-600 dark:bg-gray-500 rounded-full" style="width: 35%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</DesktopLayout>
