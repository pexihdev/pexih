---
import DesktopLayout from '../../layouts/DesktopLayout.astro';
import HeaderActions from '../../components/HeaderActions.astro';
import EmptyState from '../../components/EmptyState.astro';

const savedPosts = [1, 2, 3, 4];
---
<DesktopLayout title="Saved Articles - PEXIH">
  <!-- Header -->
  <div class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 px-8 py-5 flex items-center justify-between sticky top-0 z-50">
    <div>
      <h1 class="text-xl font-bold text-gray-900 dark:text-white" data-i18n="nav.bookmark">Saved</h1>
      <p class="text-sm text-gray-500 mt-1">Manage and read the articles you have saved for later.</p>
    </div>
    <div class="flex items-center gap-3">
      <div class="relative">
        <input type="text" id="desktop-bookmarks-search" placeholder="Search saved posts..." class="w-64 pl-9 pr-4 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:bg-white dark:focus:bg-gray-800 transition-all dark:text-white" />
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </div>
      <HeaderActions />
    </div>
  </div>

  <div class="p-8 max-w-7xl mx-auto space-y-8">
    <!-- Categories Filter Bar -->
    <div class="flex gap-2 pb-2 overflow-x-auto scrollbar-hide border-b border-gray-100 dark:border-gray-800" id="desktop-bookmarks-categories">
      <!-- Generated via JS -->
    </div>

    <!-- Content Area -->
    <div class="bookmarks-content-wrapper">
      <!-- Skeleton Container -->
      <div class="bookmarks-skeleton hidden grid grid-cols-1 md:grid-cols-2 gap-6">
        {[1, 2, 3, 4].map(() => (
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 flex gap-4 animate-pulse">
            <div class="w-24 h-24 rounded-lg bg-gray-200 dark:bg-gray-800 shrink-0"></div>
            <div class="flex-1 space-y-3 py-1">
              <div class="w-3/4 h-4 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-1/2 h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
            </div>
          </div>
        ))}
      </div>

      <!-- Real Content (2-Column Grid for Desktop) -->
      <div class="bookmarks-actual-content">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="desktop-bookmarks-list">
          <!-- Dynamic Bookmarks list loaded via JS -->
        </div>

        <!-- Normal Empty State (hidden by default) -->
        <div id="desktop-normal-empty-state" class="hidden py-8">
          <EmptyState 
            title="No Bookmarks Yet" 
            description="You haven't saved any articles. Explore and save your favorite posts to read them later."
            icon={`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-600"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>`}
          >
            <a href="/desktop/explore" class="mt-4 px-6 py-2.5 bg-orange-600 text-white text-xs font-bold rounded-full hover:bg-orange-700 transition-colors inline-block">
              Explore Articles
            </a>
          </EmptyState>
        </div>
      </div>

      <!-- Empty state for search/filter -->
      <div class="bookmarks-empty-state hidden py-12">
        <EmptyState 
          title="No Results Found" 
          description="We couldn't find any articles matching your search. Try different keywords or categories."
          icon={`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-600"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`}
        />
      </div>
    </div>
  </div>
</DesktopLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const listContainer = document.getElementById('desktop-bookmarks-list');
    const categoriesContainer = document.getElementById('desktop-bookmarks-categories');
    const skeleton = document.querySelector('.bookmarks-skeleton');
    const emptyState = document.querySelector('.bookmarks-empty-state');
    const normalEmptyState = document.getElementById('desktop-normal-empty-state');
    const searchInput = document.getElementById('desktop-bookmarks-search') as HTMLInputElement;

    const currentLang = localStorage.getItem('language') || 'en';

    // Seed data
    const seedBookmarks = [
      {
        id: "1",
        title: "How to build intuitive mobile interfaces in 2026",
        category: "Design",
        img: "https://images.unsplash.com/photo-1507238691740-187a5b1d37b8?auto=format,compress&fit=crop&w=300&q=80",
        author: { name: "Jane Doe" },
        readTime: "10 min read",
        label: currentLang === 'id' ? "Dibaca Nanti" : "Read Later",
        savedAt: Date.now() - 3600000 * 2
      },
      {
        id: "2",
        title: "Exploring the Digital Frontier with Astro & Node.js",
        category: "Technology",
        img: "https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format,compress&fit=crop&w=300&q=80",
        author: { name: "Alex Rivers" },
        readTime: "5 min read",
        label: currentLang === 'id' ? "Penting" : "Important",
        savedAt: Date.now() - 3600000
      },
      {
        id: "3",
        title: "Mastering Fluid Grid Systems & Visual Hierarchy",
        category: "Development",
        img: "https://images.unsplash.com/photo-1531403009284-440f080d1e12?auto=format,compress&fit=crop&w=300&q=80",
        author: { name: "Sarah Conner" },
        readTime: "8 min read",
        label: currentLang === 'id' ? "Referensi" : "Reference",
        savedAt: Date.now()
      }
    ];

    function getSavedBookmarks() {
      try {
        const stored = localStorage.getItem('pexih-bookmarks');
        if (!stored) {
          localStorage.setItem('pexih-bookmarks', JSON.stringify(seedBookmarks));
          return seedBookmarks;
        }
        return JSON.parse(stored);
      } catch (e) {
        return seedBookmarks;
      }
    }

    function saveBookmarks(bookmarks: any[]) {
      localStorage.setItem('pexih-bookmarks', JSON.stringify(bookmarks));
    }

    let bookmarks = getSavedBookmarks();
    let activeFilter = "All";
    let searchQuery = "";

    function renderFilters() {
      if (!categoriesContainer) return;
      const labels = ["All", ...new Set(bookmarks.map(b => b.label))];
      
      categoriesContainer.innerHTML = labels.map(label => {
        const isActive = activeFilter === label;
        const btnClass = isActive 
          ? "px-5 py-2 rounded-full bg-orange-600 text-white text-xs font-bold whitespace-nowrap transition-all duration-200 active:scale-95 ease-out cursor-pointer"
          : "px-5 py-2 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-xs font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 active:scale-95 ease-out cursor-pointer";
        
        let displayName = label;
        if (label === "All") displayName = currentLang === 'id' ? "Semua Koleksi" : "All Collections";
        
        return `<button class="${btnClass}" data-filter="${label}">${displayName}</button>`;
      }).join('');

      // Add listeners
      categoriesContainer.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = e.target as HTMLButtonElement;
          activeFilter = target.getAttribute('data-filter') || 'All';
          
          if (listContainer && skeleton && emptyState) {
            listContainer.classList.add('hidden');
            emptyState.classList.add('hidden');
            skeleton.classList.remove('hidden');
            
            setTimeout(() => {
              skeleton.classList.add('hidden');
              renderBookmarks();
              renderFilters(); // Update styles
            }, 300);
          }
        });
      });
    }

    function renderBookmarks() {
      if (!listContainer) return;

      let filtered = bookmarks;
      
      // Filter by category label
      if (activeFilter !== "All") {
        filtered = filtered.filter(b => b.label === activeFilter);
      }

      // Filter by search query
      if (searchQuery) {
        filtered = filtered.filter(b => b.title.toLowerCase().includes(searchQuery));
      }

      // Toggle display of empty states
      if (bookmarks.length === 0) {
        normalEmptyState?.classList.remove('hidden');
        listContainer.classList.add('hidden');
        emptyState?.classList.add('hidden');
        return;
      } else {
        normalEmptyState?.classList.add('hidden');
      }

      if (filtered.length === 0) {
        emptyState?.classList.remove('hidden');
        listContainer.classList.add('hidden');
        return;
      } else {
        emptyState?.classList.add('hidden');
        listContainer.classList.remove('hidden');
      }

      listContainer.innerHTML = filtered.map((b, index) => {
        let badgeColor = "bg-orange-100 text-orange-600 dark:bg-orange-950/20 dark:text-orange-400 border border-orange-100/50 dark:border-orange-500/10";
        if (b.label === "Penting" || b.label === "Important") badgeColor = "bg-red-100 text-red-600 dark:bg-red-950/20 dark:text-red-400 border border-red-100/50 dark:border-red-500/10";
        else if (b.label === "Dibaca Nanti" || b.label === "Read Later") badgeColor = "bg-blue-100 text-blue-600 dark:bg-blue-950/20 dark:text-blue-400 border border-blue-100/50 dark:border-blue-500/10";
        else if (b.label === "Referensi" || b.label === "Reference") badgeColor = "bg-emerald-100 text-emerald-600 dark:bg-emerald-950/20 dark:text-emerald-400 border border-emerald-100/50 dark:border-emerald-500/10";

        return `
          <div class="flex gap-4 items-center group bg-white dark:bg-gray-900 p-4 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-orange-500 transition-all duration-300 relative animate-fade-in" style="animation-delay: ${index * 75}ms">
            <a href="/desktop/article/${b.id}" class="w-24 h-24 rounded-lg overflow-hidden pexih-placeholder bg-gray-100 dark:bg-gray-800 shrink-0 aspect-square">
              <img 
                src="${b.img}" 
                alt="Thumbnail" 
                width="96"
                height="96"
                class="w-full h-full object-cover aspect-square group-hover:scale-105 transition-all duration-300 opacity-0" 
                onload="this.classList.remove('opacity-0')"
                loading="lazy"
                referrerpolicy="no-referrer" 
              />
            </a>
            <div class="flex-1 min-w-0 pr-6">
              <div class="flex items-center gap-1.5 mb-1.5 flex-wrap">
                <span class="text-[8px] uppercase font-bold text-gray-400 dark:text-gray-500 tracking-wider">${b.category}</span>
                <span class="text-[8px] px-1.5 py-0.5 rounded-full font-bold ${badgeColor}">${b.label}</span>
              </div>
              <a href="/desktop/article/${b.id}" class="block group/link">
                <h4 class="text-sm font-bold text-gray-900 dark:text-white leading-snug mt-1 mb-1.5 group-hover/link:text-orange-600 dark:group-hover/link:text-orange-500 transition-colors line-clamp-2">${b.title}</h4>
              </a>
              <div class="flex items-center gap-2 text-[10px] text-gray-500 dark:text-gray-400">
                <span class="font-semibold text-gray-700 dark:text-gray-300">${b.author?.name || 'Jane Doe'}</span>
                <span>•</span>
                <span>${b.readTime || '5 min read'}</span>
              </div>
            </div>
            <button class="remove-bookmark-btn absolute top-4 right-4 p-2 text-gray-400 hover:text-red-500 dark:text-gray-500 dark:hover:text-red-400 transition-colors cursor-pointer" data-id="${b.id}" aria-label="Remove from saved">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
            </button>
          </div>
        `;
      }).join('');

      // Add listeners to remove buttons
      listContainer.querySelectorAll('.remove-bookmark-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          e.preventDefault();
          const targetId = (e.currentTarget as HTMLButtonElement).getAttribute('data-id');
          bookmarks = bookmarks.filter(b => b.id !== targetId);
          saveBookmarks(bookmarks);
          
          if (window.toast) {
            window.toast(currentLang === 'id' ? "Bookmark dihapus" : "Bookmark removed");
          }
          
          renderFilters();
          renderBookmarks();
        });
      });
    }

    if (searchInput) {
      searchInput.addEventListener('input', () => {
        searchQuery = searchInput.value.toLowerCase().trim();
        renderBookmarks();
      });
    }

    renderFilters();
    renderBookmarks();
  });
</script>
