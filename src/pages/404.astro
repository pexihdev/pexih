---
import Layout from '@/src/layouts/Layout.astro';
---
<Layout>
  <script>
    window.location.replace('/');
  </script>
  <meta http-equiv="refresh" content="0;url=/" slot="head" />
  <div class="flex items-center justify-center min-h-screen bg-white dark:bg-gray-900">
    <div class="text-center p-5">
      <h1 class="text-6xl font-black text-orange-600 dark:text-orange-500 mb-4">404</h1>
      <p class="text-gray-600 dark:text-gray-400 text-[12px] md:text-sm mb-4">Halaman tidak ditemukan. Mengalihkan ke halaman utama...</p>
      <div class="w-6 h-6 border-2 border-orange-600 dark:border-orange-500 border-t-transparent dark:border-t-transparent rounded-full animate-spin mx-auto"></div>
    </div>
  </div>
</Layout>
