---
import DesktopLayout from '../../layouts/DesktopLayout.astro';
import HeaderActions from '../../components/HeaderActions.astro';
import EmptyState from '../../components/EmptyState.astro';

// Fetch articles and categories from the Backend API for SSR
let exploreArticles = [];
let topicCategories = [];
const backendUrl = import.meta.env.PUBLIC_BACKEND_URL || 'https://pexih-api.vercel.app';
try {
  const [artRes, catRes] = await Promise.all([
    fetch(`${backendUrl}/api/articles`),
    fetch(`${backendUrl}/api/categories`)
  ]);
  if (artRes.ok) {
    const data = await artRes.json();
    exploreArticles = data
      .sort((a, b) => (Number(b.views) || 0) - (Number(a.views) || 0))
      .slice(0, 10);
  }
  if (catRes.ok) {
    topicCategories = await catRes.json();
  }
} catch (e) {
  console.error("Failed to fetch data from API", e);
}

// Fallback to dummy data if API fails or returns empty
if (exploreArticles.length === 0) {
  exploreArticles = [1, 2, 3, 4, 5, 6].map((post) => ({
    id: String(post),
    title: `Understanding Minimalist Interfaces in Modern Apps ${post}`,
    content: "An in-depth look at how modern technology is reshaping our daily lives. The combination of design principles and structural minimalism creates highly focused and elegant user experiences.",
    author: { name: "Alex Rivers" },
    img: `https://images.unsplash.com/photo-${1550000000000 + post * 4}?auto=format,compress&fit=crop&w=800&q=80`,
    category: post % 2 === 0 ? "Design" : "Technology",
    readTime: "5 min read",
    views: "1.2k"
  }));
}

const featuredPost = exploreArticles[0];
const trendingPosts = exploreArticles.slice(1);

const cleanMarkdown = (text: string) => {
  if (!text) return "";
  return text.replace(/[#_*~`>\[\]\(\)]/g, '');
};
---
<DesktopLayout title="Explore - PEXIH">
  <!-- Header -->
  <div class="bg-white dark:bg-gray-900 border-b border-gray-100 dark:border-gray-800 pt-3 pb-2 px-5 flex items-center justify-between h-[53px] sticky top-0 z-50" transition:name="desktop-header">
    <div class="flex items-center gap-2">
      <h1 class="text-[16px] font-bold text-gray-900 dark:text-white" data-i18n="nav.explore">Explore</h1>
    </div>
    <div class="flex items-center gap-3">
      <div class="relative">
        <input type="text" id="desktop-explore-search" data-i18n="header.search" placeholder="Search topics..." class="w-64 pl-9 pr-4 py-1.5 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[12px] focus:outline-none focus:ring-2 focus:ring-orange-500 focus:bg-white dark:focus:bg-gray-800 transition-all dark:text-white" autocomplete="off" />
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <div id="search-suggestions-dropdown" class="absolute left-0 right-0 top-full mt-1.5 bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-lg shadow-xl z-[100] max-h-64 overflow-y-auto hidden divide-y divide-gray-50 dark:divide-gray-750"></div>
      </div>
      <HeaderActions />
    </div>
  </div>

  <div class="p-8 max-w-7xl mx-auto space-y-8">
    <!-- Categories Filter Bar -->
    <div class="flex gap-2 pb-2 overflow-x-auto scrollbar-hide border-b border-gray-100 dark:border-gray-800">
      <button class="px-5 py-2 rounded-full bg-orange-600 text-white text-xs font-bold whitespace-nowrap transition-all duration-200 active:scale-95 ease-out" data-i18n="explore.allTopics">All Topics</button>
      {topicCategories.length > 0 ? (
        topicCategories.map(cat => (
          <button class="px-5 py-2 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-xs font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 active:scale-95 ease-out" data-i18n={`category.${cat.slug || cat.title.toLowerCase().replace(/\s+/g, '-')}`}>{cat.title}</button>
        ))
      ) : (
        <>
          <button class="px-5 py-2 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-xs font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 active:scale-95 ease-out" data-i18n="category.technology">Technology</button>
          <button class="px-5 py-2 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-xs font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 active:scale-95 ease-out" data-i18n="category.design">Design</button>
          <button class="px-5 py-2 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-xs font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 active:scale-95 ease-out" data-i18n="category.lifestyle">Lifestyle</button>
        </>
      )}
    </div>

    <!-- Content Area -->
    <div class="explore-content-wrapper">
      <!-- Skeleton Container -->
      <div class="explore-skeleton hidden grid grid-cols-1 md:grid-cols-2 gap-6">
        {[1, 2, 3, 4].map(() => (
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm p-5 space-y-4">
            <div class="w-full aspect-[16/9] rounded-lg bg-gray-200 dark:bg-gray-800 animate-pulse"></div>
            <div class="space-y-3">
              <div class="w-1/3 h-3 bg-gray-200 dark:bg-gray-800 rounded animate-pulse"></div>
              <div class="w-3/4 h-5 bg-gray-200 dark:bg-gray-800 rounded animate-pulse"></div>
              <div class="w-full h-3 bg-gray-200 dark:bg-gray-800 rounded animate-pulse"></div>
            </div>
          </div>
        ))}
      </div>

      <!-- Real Content -->
      <div class="explore-actual-content space-y-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <!-- Left Side: Featured Article (spanning 1 col on lg) -->
          <div class="lg:col-span-1 space-y-4">
            <h3 class="text-sm font-black uppercase text-orange-600 tracking-wider">Featured Story</h3>
            <a href={"/desktop/article/" + featuredPost.id} class="block group bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden hover:border-orange-500 transition-all duration-200 hover:-translate-y-1 hover:shadow-md animate-fade-in" style="animation-delay: 0ms">
              <div class="aspect-[16/9] pexih-placeholder bg-gray-100 dark:bg-gray-800 overflow-hidden">
                <img 
                  src={featuredPost.img || "https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format,compress&fit=crop&w=800&q=80"} 
                  alt={"Featured: " + featuredPost.title} 
                  width="800"
                  height="450"
                  class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300 aspect-[16/9] opacity-0"
                  onload="this.classList.remove('opacity-0')"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  referrerpolicy="no-referrer"
                />
              </div>
              <div class="p-6 space-y-3">
                <span class="bg-orange-600 text-white text-[8px] font-bold px-2 py-0.5 rounded uppercase tracking-wider">{featuredPost.category || 'Featured'}</span>
                <h2 class="text-lg font-bold text-gray-900 dark:text-white group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors line-clamp-2">{featuredPost.title}</h2>
                <p class="text-xs text-gray-600 dark:text-gray-300 line-clamp-3">{featuredPost.content ? cleanMarkdown(featuredPost.content) : "Read this highly insightful article from our community."}</p>
                <p class="text-[10px] text-gray-400 dark:text-gray-500">{featuredPost.author?.name || 'Author'} • {featuredPost.readTime || '5 min read'}</p>
              </div>
              <button aria-label="Save Article" class="bookmark-btn absolute right-4 top-4 p-2.5 bg-white/10 dark:bg-black/20 hover:bg-white/20 dark:hover:bg-black/40 backdrop-blur-sm rounded-full text-white hover:text-orange-400 transition-colors z-10"
                data-bookmark-id={featuredPost.id} 
                data-bookmark-title={featuredPost.title} 
                data-bookmark-category={featuredPost.category || 'Featured'} 
                data-bookmark-img={featuredPost.img || "https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format,compress&fit=crop&w=800&q=80"} 
                data-bookmark-author={featuredPost.author?.name || 'Author'}
                onclick="event.preventDefault(); event.stopPropagation();">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="bookmark-icon"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
              </button>
            </a>
          </div>

          <!-- Right Side: Trending Feed (2-column layout as requested) -->
          <div class="lg:col-span-2 space-y-4">
            <h3 class="text-sm font-black uppercase text-gray-900 dark:text-white tracking-wider">Trending Now</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {trendingPosts.map((item, index) => (
                <a href={"/desktop/article/" + item.id} class="block group bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden hover:border-orange-500 transition-all duration-200 hover:-translate-y-1 hover:shadow-md animate-fade-in" style={`animation-delay: ${(index + 1) * 75}ms`}>
                  <div class="aspect-[16/9] pexih-placeholder bg-gray-100 dark:bg-gray-800 overflow-hidden">
                    <img 
                      src={item.img || "https://images.unsplash.com/photo-" + (1550000000000 + index * 3) + "?auto=format,compress&fit=crop&w=400&q=80"} 
                      alt={"Thumbnail for " + item.title} 
                      width="400"
                      height="225"
                      class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300 aspect-[16/9] opacity-0"
                      onload="this.classList.remove('opacity-0')"
                      loading="lazy"
                      decoding="async"
                      referrerpolicy="no-referrer"
                    />
                  </div>
                  <div class="p-4 space-y-2">
                    <span class="text-[9px] text-orange-600 dark:text-orange-500 font-bold uppercase tracking-wider">{item.category || 'Trending'}</span>
                    <h4 class="text-sm font-bold text-gray-900 dark:text-white line-clamp-2 group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors">{item.title}</h4>
                    <p class="text-[10px] text-gray-500 dark:text-gray-400">{item.author?.name || 'Author'} • {item.readTime || '5 min read'}</p>
                  </div>
                  <button aria-label="Save Article" class="bookmark-btn absolute right-3 top-3 p-2 bg-white/10 dark:bg-black/20 hover:bg-white/20 dark:hover:bg-black/40 backdrop-blur-sm rounded-full text-white hover:text-orange-400 transition-colors z-10"
                    data-bookmark-id={item.id} 
                    data-bookmark-title={item.title} 
                    data-bookmark-category={item.category || 'Trending'} 
                    data-bookmark-img={item.img || "https://images.unsplash.com/photo-" + (1550000000000 + index * 3) + "?auto=format,compress&fit=crop&w=400&q=80"} 
                    data-bookmark-author={item.author?.name || 'Author'}
                    onclick="event.preventDefault(); event.stopPropagation();">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="bookmark-icon"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
                  </button>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Empty state for search/filter -->
      <div class="explore-empty-state hidden py-12">
        <EmptyState 
          title="No Results Found" 
          titleI18n="empty.noResults"
          description="We couldn't find any articles matching your search. Try different keywords or categories."
          descriptionI18n="empty.noResultsDesc"
          icon={`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-600"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`}
        />
      </div>
      
      <!-- Infinite Scroll Sentinel -->
      <div id="desktop-explore-sentinel" data-backend-url={backendUrl} class="py-8 w-full opacity-0 transition-opacity">
        <div class="grid grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden animate-pulse">
            <div class="aspect-[16/9] bg-gray-200 dark:bg-gray-800"></div>
            <div class="p-4 space-y-3">
              <div class="w-16 h-2 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-full h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-3/4 h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-1/2 h-2 bg-gray-100 dark:bg-gray-800 rounded"></div>
            </div>
          </div>
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden animate-pulse">
            <div class="aspect-[16/9] bg-gray-200 dark:bg-gray-800"></div>
            <div class="p-4 space-y-3">
              <div class="w-16 h-2 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-full h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-3/4 h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-1/2 h-2 bg-gray-150 dark:bg-gray-850 rounded"></div>
            </div>
          </div>
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden animate-pulse hidden lg:block">
            <div class="aspect-[16/9] bg-gray-200 dark:bg-gray-800"></div>
            <div class="p-4 space-y-3">
              <div class="w-16 h-2 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-full h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-3/4 h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-1/2 h-2 bg-gray-150 dark:bg-gray-850 rounded"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</DesktopLayout>

<script>
  // Handle client-side category filtering and real-time search
  document.addEventListener('astro:page-load', () => {
    const categoryBtns = document.querySelectorAll('.max-w-7xl button');
    const skeleton = document.querySelector('.explore-skeleton');
    const content = document.querySelector('.explore-actual-content');
    const emptyState = document.querySelector('.explore-empty-state');
    const searchInput = document.getElementById('desktop-explore-search') as HTMLInputElement;
    const sentinel = document.getElementById('desktop-explore-sentinel');
    const backendUrl = sentinel?.getAttribute('data-backend-url') || '';
    
    // Desktop layout specific elements
    const featuredContainer = content?.querySelector('.lg\\:col-span-1');
    const feedContainer = content?.querySelector('.lg\\:col-span-2 .grid');
    const feedTitle = content?.querySelector('.lg\\:col-span-2 h3');

    // Remove old items
    function clearList() {
      if (!feedContainer) return;
      feedContainer.innerHTML = '';
    }

    function renderArticlesDesktop(articles: any[]) {
      if (!feedContainer) return;
      clearList();
      
      if (articles.length === 0) {
        if (content) content.classList.add('hidden');
        if (emptyState) emptyState.classList.remove('hidden');
        if (sentinel) sentinel.classList.add('hidden');
        return;
      }

      if (content) content.classList.remove('hidden');
      if (emptyState) emptyState.classList.add('hidden');

      articles.forEach((item, index) => {
        const articleHtml = `
          <a href="/desktop/article/${item.id}" class="block group bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden hover:border-orange-500 transition-all duration-200 hover:-translate-y-1 hover:shadow-md animate-fade-in" style="animation-delay: ${index * 50}ms">
            <div class="aspect-[16/9] pexih-placeholder bg-gray-100 dark:bg-gray-800 overflow-hidden">
              <img 
                src="${item.img || `https://images.unsplash.com/photo-${1550000000000 + index * 3}?auto=format,compress&fit=crop&w=400&q=80`}" 
                alt="Thumbnail" 
                width="400" height="225"
                class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300 aspect-[16/9] opacity-0"
                onload="this.classList.remove('opacity-0')"
                loading="lazy" referrerpolicy="no-referrer"
              />
            </div>
            <div class="p-4 space-y-2">
              <span class="text-[9px] text-orange-600 dark:text-orange-500 font-bold uppercase tracking-wider">${item.category || 'Article'}</span>
              <h4 class="text-sm font-bold text-gray-900 dark:text-white line-clamp-2 group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors">${item.title}</h4>
              <p class="text-[10px] text-gray-500 dark:text-gray-400">${item.author?.name || 'Author'} • ${item.readTime || '5 min read'}</p>
            </div>
          </a>
        `;
        feedContainer.insertAdjacentHTML('beforeend', articleHtml);
      });
    }

    let isFiltering = false;
    let currentCategory = 'All Topics';

    async function performFilter(query: string, category: string) {
      if (skeleton && content && emptyState) {
        content.classList.add('hidden');
        emptyState.classList.add('hidden');
        skeleton.classList.remove('hidden');
        if (sentinel) sentinel.classList.add('hidden');
      }

      try {
        let url = `${backendUrl}/api/articles?limit=100`; 
        const cacheKey = 'pexih_all_articles_cache';
        let allData = JSON.parse(sessionStorage.getItem(cacheKey) || 'null');
        
        if (!allData) {
          const res = await fetch(url);
          if (res.ok) {
            allData = await res.json();
            sessionStorage.setItem(cacheKey, JSON.stringify(allData));
          } else {
            allData = [];
          }
        }

        let filtered = allData;
        
        if (category !== 'All Topics') {
          filtered = filtered.filter((a: any) => a.category?.toLowerCase() === category.toLowerCase());
        }
        
        if (query && query.length >= 2) {
          const q = query.toLowerCase();
          filtered = filtered.filter((a: any) => 
            a.title?.toLowerCase().includes(q) || 
            a.category?.toLowerCase().includes(q) || 
            a.author?.name?.toLowerCase().includes(q)
          );
        }

        if (skeleton) skeleton.classList.add('hidden');
        
        isFiltering = (category !== 'All Topics' || (query && query.length >= 2));
        
        if (featuredContainer) {
          if (isFiltering) {
            featuredContainer.classList.add('hidden');
            // Expand the grid to full width when featured is hidden
            const mainGrid = content?.querySelector('.grid.grid-cols-1.lg\\:grid-cols-3');
            if (mainGrid) {
              mainGrid.classList.remove('lg:grid-cols-3');
              mainGrid.classList.add('lg:grid-cols-1');
            }
          } else {
            featuredContainer.classList.remove('hidden');
            const mainGrid = content?.querySelector('.grid.grid-cols-1');
            if (mainGrid) {
              mainGrid.classList.remove('lg:grid-cols-1');
              mainGrid.classList.add('lg:grid-cols-3');
            }
          }
        }

        if (feedTitle) {
          if (query && query.length >= 2) {
            feedTitle.textContent = `Search Results for "${query}"`;
          } else if (category !== 'All Topics') {
            feedTitle.textContent = `${category} Articles`;
          } else {
            feedTitle.textContent = 'Trending Now';
          }
        }

        if (isFiltering) {
          // In filtering mode, feedContainer will show grid of 3 cols or 4 instead of 2.
          // Wait, feedContainer is inside lg:col-span-2. When featured is hidden, it becomes lg:col-span-1.
          // We can adjust the grid inside feedContainer to have more columns when full width
          feedContainer?.classList.remove('md:grid-cols-2');
          feedContainer?.classList.add('md:grid-cols-3', 'lg:grid-cols-4');
          renderArticlesDesktop(filtered);
        } else {
          feedContainer?.classList.remove('md:grid-cols-3', 'lg:grid-cols-4');
          feedContainer?.classList.add('md:grid-cols-2');
          // Reset to default
          renderArticlesDesktop(filtered.slice(1, 11)); // skipping 1st as it's featured
          if (sentinel && hasMore) sentinel.classList.remove('hidden');
        }

      } catch (err) {
        console.error(err);
        if (skeleton) skeleton.classList.add('hidden');
      }
    }
    
    categoryBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        categoryBtns.forEach(b => {
          b.className = 'px-5 py-2 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-xs font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 active:scale-95 ease-out';
        });
        const target = e.target as HTMLElement;
        target.className = 'px-5 py-2 rounded-full bg-orange-600 text-white text-xs font-bold whitespace-nowrap transition-all duration-200 active:scale-95 ease-out';
        
        currentCategory = target.textContent?.trim() || 'All Topics';
        performFilter(searchInput ? searchInput.value.trim() : '', currentCategory);
      });
    });

    const suggestionsDropdown = document.getElementById('search-suggestions-dropdown');

    if (searchInput) {
      let debounceTimeout: any = null;

      // Click away closes suggestions
      document.addEventListener('click', (e) => {
        if (suggestionsDropdown && !searchInput.contains(e.target as Node) && !suggestionsDropdown.contains(e.target as Node)) {
          suggestionsDropdown.classList.add('hidden');
        }
      });

      searchInput.addEventListener('input', () => {
        clearTimeout(debounceTimeout);
        // Hide dropdown entirely as we now filter inline
        if (suggestionsDropdown) suggestionsDropdown.classList.add('hidden');

        debounceTimeout = setTimeout(() => {
          performFilter(searchInput.value.trim(), currentCategory);
        }, 400);
      });
    }

    // Infinite Scrolling Logic
    let currentPage = 1;
    let isLoading = false;
    let hasMore = true;
    
    // For infinite scroll we append to feedContainer if not filtering
    if (sentinel && feedContainer) {
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && !isLoading && hasMore && !isFiltering) {
          loadMoreArticles();
        }
      }, { rootMargin: '150px' });
      
      observer.observe(sentinel);
      
      async function loadMoreArticles() {
        isLoading = true;
        sentinel?.classList.remove('opacity-0');
        
        try {
          currentPage++;
          const cacheKey = `pexih_explore_desktop_page_${currentPage}`;
          const cachedData = sessionStorage.getItem(cacheKey);
          let newArticles;
          
          if (cachedData) {
            newArticles = JSON.parse(cachedData);
          } else {
            const res = await fetch(`${backendUrl}/api/articles?page=${currentPage}&limit=9`); 
            if (!res.ok) throw new Error('Failed');
            newArticles = await res.json();
            sessionStorage.setItem(cacheKey, JSON.stringify(newArticles));
          }
          
          if (newArticles.length === 0) {
            hasMore = false;
            if (sentinel) sentinel.classList.add('hidden');
            return;
          }
          
          newArticles.forEach((item: any, index: number) => {
            const articleHtml = `
              <a href="/desktop/article/${item.id}" class="block group bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden hover:border-orange-500 transition-all duration-300 animate-fade-in" style="animation-delay: ${index * 75}ms">
                <div class="aspect-[16/9] pexih-placeholder bg-gray-100 dark:bg-gray-800 overflow-hidden">
                  <img 
                    src="${item.img || `https://images.unsplash.com/photo-${1550000000000 + Math.floor(Math.random() * 100)}?auto=format,compress&fit=crop&w=400&q=80`}" 
                    alt="Thumbnail" 
                    width="400" height="225"
                    class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300 aspect-[16/9] opacity-0"
                    onload="this.classList.remove('opacity-0')"
                    loading="lazy" referrerpolicy="no-referrer"
                  />
                </div>
                <div class="p-4 space-y-2">
                  <span class="text-[9px] text-orange-600 dark:text-orange-500 font-bold uppercase tracking-wider">${item.category || 'Trending'}</span>
                  <h4 class="text-sm font-bold text-gray-900 dark:text-white line-clamp-2 group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors">${item.title}</h4>
                  <p class="text-[10px] text-gray-500 dark:text-gray-400">${item.author?.name || 'Author'} • ${item.readTime || '5 min read'}</p>
                </div>
              </a>
            `;
            feedContainer.insertAdjacentHTML('beforeend', articleHtml);
          });
        } catch (e) {
          console.error("Failed to load more", e);
        } finally {
          isLoading = false;
          if (sentinel && hasMore) sentinel.classList.add('opacity-0');
        }
      }
    }
  });
</script>
