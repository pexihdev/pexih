---
import MobileLayout from '../layouts/MobileLayout.astro';
---
<MobileLayout title="Create Post" showBottomNav={false}>
  <link rel="stylesheet" href="https://unpkg.com/easymde/dist/easymde.min.css">
  <div class="fixed top-0 w-full max-w-[400px] z-50" transition:name="mobile-header">
    <div class="w-full bg-white dark:bg-gray-900" style="height: env(safe-area-inset-top);"></div>
    <div class="bg-white dark:bg-gray-900 pt-3 pb-2 px-5 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between h-[53px] relative">
      <button aria-label="Back" onclick="history.back()" class="text-gray-900 dark:text-white w-8 h-8 flex items-center justify-start hover:text-orange-600 dark:hover:text-orange-500 transition-colors z-10">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <h1 class="text-[16px] font-bold text-gray-900 dark:text-white absolute left-1/2 -translate-x-1/2 w-[60%] text-center truncate">New Post</h1>
      <button id="publish-btn" class="bg-orange-600 text-white px-3 py-1 rounded text-[10px] font-bold hover:bg-orange-700 transition-colors z-10">
        Publish
      </button>
    </div>
  </div>

  <div class="p-5 flex flex-col gap-4 pb-[80px]" style="padding-top: calc(53px + env(safe-area-inset-top));">
    <input id="post-title" type="text" placeholder="Post Title..." class="w-full text-[16px] font-bold text-gray-900 dark:text-white placeholder:text-gray-400 dark:placeholder:text-gray-500 focus:outline-none bg-transparent border-b border-gray-100 dark:border-gray-800 pb-2" />
    
    <div class="flex gap-2">
      <select id="post-category" class="w-1/3 px-3 py-1.5 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[10px] font-medium text-gray-700 dark:text-gray-300 focus:outline-none focus:border-orange-500 transition-colors">
        <option value="Technology">Technology</option>
        <option value="Design">Design</option>
        <option value="Lifestyle">Lifestyle</option>
        <option value="Business">Business</option>
        <option value="Health">Health</option>
        <option value="General">General</option>
      </select>
      <input id="post-cover" type="url" placeholder="Cover Image URL (e.g. Unsplash)" class="flex-1 px-3 py-1.5 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[10px] font-medium text-gray-900 dark:text-white placeholder:text-gray-400 focus:outline-none focus:border-orange-500 transition-colors" />
    </div>

    <!-- EasyMDE Textarea Container -->
    <div class="w-full prose-sm editor-container dark:text-white mt-2">
      <textarea id="markdown-editor" placeholder="Write your thoughts here..." class="w-full min-h-[200px] text-[12px] text-gray-700 dark:text-gray-300 placeholder:text-gray-400 focus:outline-none bg-transparent resize-none leading-relaxed"></textarea>
    </div>
  </div>
  
  <style is:global>
    .editor-container .editor-toolbar {
      border: 1px solid #f3f4f6;
      border-radius: 0.5rem 0.5rem 0 0;
      opacity: 1;
      padding: 0 5px;
    }
    .dark .editor-container .editor-toolbar {
      border-color: #1f2937;
      background-color: #111827;
    }
    .dark .editor-container .editor-toolbar button {
      color: #d1d5db;
    }
    .dark .editor-container .editor-toolbar button:hover,
    .dark .editor-container .editor-toolbar button.active {
      background-color: #374151;
      color: #fff;
    }
    .editor-container .editor-toolbar button {
      width: 24px;
      height: 24px;
      padding: 3px;
      margin: 2px;
    }
    .editor-container .CodeMirror {
      border: 1px solid #f3f4f6;
      border-radius: 0 0 0.5rem 0.5rem;
      border-top: none;
      min-height: 300px;
      font-size: 12px;
      font-family: inherit;
    }
    .dark .editor-container .CodeMirror {
      border-color: #1f2937;
      background-color: #111827;
      color: #f3f4f6;
    }
    .dark .editor-container .CodeMirror-cursor {
      border-left-color: #f3f4f6;
    }
    .editor-container .editor-statusbar {
      padding: 4px 8px;
      font-size: 10px;
      color: #9ca3af;
    }
  </style>

  <script src="https://unpkg.com/easymde/dist/easymde.min.js" is:inline></script>
  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      const titleInput = document.getElementById('post-title');
      const categorySelect = document.getElementById('post-category');
      const coverInput = document.getElementById('post-cover');
      
      // Initialize EasyMDE
      const easyMDE = new EasyMDE({ 
        element: document.getElementById('markdown-editor'),
        spellChecker: false,
        placeholder: "Write your thoughts here...",
        status: ["words"],
        toolbar: ["bold", "italic", "heading", "|", "quote", "unordered-list", "ordered-list", "|", "link", "image", "preview"]
      });

      // Load draft from localStorage
      const savedTitle = localStorage.getItem('pexih_draft_title');
      const savedContent = localStorage.getItem('pexih_draft_content');
      const savedCover = localStorage.getItem('pexih_draft_cover');
      
      if (savedTitle && titleInput) titleInput.value = savedTitle;
      if (savedContent) easyMDE.value(savedContent);
      if (savedCover && coverInput) coverInput.value = savedCover;

      // Auto-save function
      const saveDraft = () => {
        if (titleInput) localStorage.setItem('pexih_draft_title', titleInput.value);
        if (coverInput) localStorage.setItem('pexih_draft_cover', coverInput.value);
        localStorage.setItem('pexih_draft_content', easyMDE.value());
      };

      // Listen for changes
      if (titleInput) {
        titleInput.addEventListener('input', saveDraft);
      }
      if (coverInput) {
        coverInput.addEventListener('input', saveDraft);
      }
      easyMDE.codemirror.on('change', saveDraft);

      const publishBtn = document.getElementById('publish-btn');
      if (publishBtn) {
        publishBtn.addEventListener('click', async () => {
          const title = titleInput ? titleInput.value : '';
          const content = easyMDE.value();
          const img = coverInput ? coverInput.value : '';
          const category = categorySelect ? categorySelect.value : 'General';
          
          if (!title || !content) {
            window.toast("Please fill in title and content");
            return;
          }
          
          publishBtn.disabled = true;
          publishBtn.textContent = 'Publishing...';
          
          try {
            const backendUrl = document.body.dataset.backendUrl || 'https://pexih-api.vercel.app';
            // Because the frontend API route `/api/articles` proxy hasn't been implemented with img yet, we hit backend directly or assume proxy is just forwarding.
            const res = await fetch('/api/articles/create', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({
                title,
                content,
                category,
                img: img || `https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format,compress&fit=crop&w=400&q=80`
              })
            });
            
            if (res.ok) {
              // Clear draft on success
              localStorage.removeItem('pexih_draft_title');
              localStorage.removeItem('pexih_draft_content');
              localStorage.removeItem('pexih_draft_cover');
              
              window.toast("Post published!");
              setTimeout(() => {
                window.location.href = '/';
              }, 1000);
            } else {
              const data = await res.json();
              window.toast(data.error || "Failed to publish post");
              publishBtn.disabled = false;
              publishBtn.textContent = 'Publish';
            }
          } catch (e) {
            window.toast("Network error");
            publishBtn.disabled = false;
            publishBtn.textContent = 'Publish';
          }
        });
      }
    });
  </script>
</MobileLayout>
