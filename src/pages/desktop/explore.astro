---
import DesktopLayout from '../../layouts/DesktopLayout.astro';
import HeaderActions from '../../components/HeaderActions.astro';
import EmptyState from '../../components/EmptyState.astro';

// Fetch articles from the Backend API for SSR
let exploreArticles = [];
const backendUrl = import.meta.env.PUBLIC_BACKEND_URL || 'https://pexih-api.vercel.app';
try {
  const res = await fetch(`${backendUrl}/api/articles`);
  if (res.ok) {
    const data = await res.json();
    exploreArticles = data
      .sort((a, b) => (Number(b.views) || 0) - (Number(a.views) || 0))
      .slice(0, 10);
  } else {
    throw new Error('Failed to fetch from API');
  }
} catch (e) {
  console.error("Failed to fetch articles from API", e);
}

// Fallback to dummy data if API fails or returns empty
if (exploreArticles.length === 0) {
  exploreArticles = [1, 2, 3, 4, 5, 6].map((post) => ({
    id: String(post),
    title: `Understanding Minimalist Interfaces in Modern Apps ${post}`,
    content: "An in-depth look at how modern technology is reshaping our daily lives. The combination of design principles and structural minimalism creates highly focused and elegant user experiences.",
    author: { name: "Alex Rivers" },
    img: `https://images.unsplash.com/photo-${1550000000000 + post * 4}?auto=format,compress&fit=crop&w=800&q=80`,
    category: post % 2 === 0 ? "Design" : "Technology",
    readTime: "5 min read",
    views: "1.2k"
  }));
}

const featuredPost = exploreArticles[0];
const trendingPosts = exploreArticles.slice(1);

const cleanMarkdown = (text: string) => {
  if (!text) return "";
  return text.replace(/[#_*~`>\[\]\(\)]/g, '');
};
---
<DesktopLayout title="Explore - PEXIH">
  <!-- Header -->
  <div class="bg-white dark:bg-gray-900 border-b border-gray-100 dark:border-gray-800 pt-3 pb-2 px-5 flex items-center justify-between h-[53px] sticky top-0 z-50">
    <div class="flex items-center gap-2">
      <h1 class="text-[16px] font-bold text-gray-900 dark:text-white" data-i18n="nav.explore">Explore</h1>
    </div>
    <div class="flex items-center gap-3">
      <div class="relative">
        <input type="text" id="desktop-explore-search" placeholder="Search topics..." class="w-64 pl-9 pr-4 py-1.5 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[12px] focus:outline-none focus:ring-2 focus:ring-orange-500 focus:bg-white dark:focus:bg-gray-800 transition-all dark:text-white" autocomplete="off" />
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <div id="search-suggestions-dropdown" class="absolute left-0 right-0 top-full mt-1.5 bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-lg shadow-xl z-[100] max-h-64 overflow-y-auto hidden divide-y divide-gray-50 dark:divide-gray-750"></div>
      </div>
      <HeaderActions />
    </div>
  </div>

  <div class="p-8 max-w-7xl mx-auto space-y-8">
    <!-- Categories Filter Bar -->
    <div class="flex gap-2 pb-2 overflow-x-auto scrollbar-hide border-b border-gray-100 dark:border-gray-800">
      <button class="px-5 py-2 rounded-full bg-orange-600 text-white text-xs font-bold whitespace-nowrap transition-all duration-200 active:scale-95 ease-out">All Topics</button>
      <button class="px-5 py-2 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-xs font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 active:scale-95 ease-out">Technology</button>
      <button class="px-5 py-2 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-xs font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 active:scale-95 ease-out">Design</button>
      <button class="px-5 py-2 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-xs font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 active:scale-95 ease-out">Lifestyle</button>
    </div>

    <!-- Content Area -->
    <div class="explore-content-wrapper">
      <!-- Skeleton Container -->
      <div class="explore-skeleton hidden grid grid-cols-1 md:grid-cols-2 gap-6">
        {[1, 2, 3, 4].map(() => (
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm p-5 space-y-4">
            <div class="w-full aspect-[16/9] rounded-lg bg-gray-200 dark:bg-gray-800 animate-pulse"></div>
            <div class="space-y-3">
              <div class="w-1/3 h-3 bg-gray-200 dark:bg-gray-800 rounded animate-pulse"></div>
              <div class="w-3/4 h-5 bg-gray-200 dark:bg-gray-800 rounded animate-pulse"></div>
              <div class="w-full h-3 bg-gray-200 dark:bg-gray-800 rounded animate-pulse"></div>
            </div>
          </div>
        ))}
      </div>

      <!-- Real Content -->
      <div class="explore-actual-content space-y-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <!-- Left Side: Featured Article (spanning 1 col on lg) -->
          <div class="lg:col-span-1 space-y-4">
            <h3 class="text-sm font-black uppercase text-orange-600 tracking-wider">Featured Story</h3>
            <a href={"/desktop/article/" + featuredPost.id} class="block group bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden hover:border-orange-500 transition-all duration-200 hover:-translate-y-1 hover:shadow-md animate-fade-in" style="animation-delay: 0ms">
              <div class="aspect-[16/9] pexih-placeholder bg-gray-100 dark:bg-gray-800 overflow-hidden">
                <img 
                  src={featuredPost.img || "https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format,compress&fit=crop&w=800&q=80"} 
                  alt={"Featured: " + featuredPost.title} 
                  width="800"
                  height="450"
                  class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300 aspect-[16/9] opacity-0"
                  onload="this.classList.remove('opacity-0')"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  referrerpolicy="no-referrer"
                />
              </div>
              <div class="p-6 space-y-3">
                <span class="bg-orange-600 text-white text-[8px] font-bold px-2 py-0.5 rounded uppercase tracking-wider">{featuredPost.category || 'Featured'}</span>
                <h2 class="text-lg font-bold text-gray-900 dark:text-white group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors line-clamp-2">{featuredPost.title}</h2>
                <p class="text-xs text-gray-600 dark:text-gray-300 line-clamp-3">{featuredPost.content ? cleanMarkdown(featuredPost.content) : "Read this highly insightful article from our community."}</p>
                <p class="text-[10px] text-gray-400 dark:text-gray-500">{featuredPost.author?.name || 'Author'} • {featuredPost.readTime || '5 min read'}</p>
              </div>
            </a>
          </div>

          <!-- Right Side: Trending Feed (2-column layout as requested) -->
          <div class="lg:col-span-2 space-y-4">
            <h3 class="text-sm font-black uppercase text-gray-900 dark:text-white tracking-wider">Trending Now</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {trendingPosts.map((item, index) => (
                <a href={"/desktop/article/" + item.id} class="block group bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden hover:border-orange-500 transition-all duration-200 hover:-translate-y-1 hover:shadow-md animate-fade-in" style={`animation-delay: ${(index + 1) * 75}ms`}>
                  <div class="aspect-[16/9] pexih-placeholder bg-gray-100 dark:bg-gray-800 overflow-hidden">
                    <img 
                      src={item.img || "https://images.unsplash.com/photo-" + (1550000000000 + index * 3) + "?auto=format,compress&fit=crop&w=400&q=80"} 
                      alt={"Thumbnail for " + item.title} 
                      width="400"
                      height="225"
                      class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300 aspect-[16/9] opacity-0"
                      onload="this.classList.remove('opacity-0')"
                      loading="lazy"
                      decoding="async"
                      referrerpolicy="no-referrer"
                    />
                  </div>
                  <div class="p-4 space-y-2">
                    <span class="text-[9px] text-orange-600 dark:text-orange-500 font-bold uppercase tracking-wider">{item.category || 'Trending'}</span>
                    <h4 class="text-sm font-bold text-gray-900 dark:text-white line-clamp-2 group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors">{item.title}</h4>
                    <p class="text-[10px] text-gray-500 dark:text-gray-400">{item.author?.name || 'Author'} • {item.readTime || '5 min read'}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Empty state for search/filter -->
      <div class="explore-empty-state hidden py-12">
        <EmptyState 
          title="No Results Found" 
          description="We couldn't find any articles matching your search. Try different keywords or categories."
          icon={`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-600"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`}
        />
      </div>
      
      <!-- Infinite Scroll Sentinel -->
      <div id="desktop-explore-sentinel" data-backend-url={backendUrl} class="py-8 w-full opacity-0 transition-opacity">
        <div class="grid grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden animate-pulse">
            <div class="aspect-[16/9] bg-gray-200 dark:bg-gray-800"></div>
            <div class="p-4 space-y-3">
              <div class="w-16 h-2 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-full h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-3/4 h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-1/2 h-2 bg-gray-150 dark:bg-gray-850 rounded"></div>
            </div>
          </div>
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden animate-pulse">
            <div class="aspect-[16/9] bg-gray-200 dark:bg-gray-800"></div>
            <div class="p-4 space-y-3">
              <div class="w-16 h-2 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-full h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-3/4 h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-1/2 h-2 bg-gray-150 dark:bg-gray-850 rounded"></div>
            </div>
          </div>
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden animate-pulse hidden lg:block">
            <div class="aspect-[16/9] bg-gray-200 dark:bg-gray-800"></div>
            <div class="p-4 space-y-3">
              <div class="w-16 h-2 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-full h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-3/4 h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-1/2 h-2 bg-gray-150 dark:bg-gray-850 rounded"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</DesktopLayout>

<script>
  // Handle client-side category filtering and skeleton transition
  document.addEventListener('astro:page-load', () => {
    const categoryBtns = document.querySelectorAll('.max-w-7xl button');
    const skeleton = document.querySelector('.explore-skeleton');
    const content = document.querySelector('.explore-actual-content');
    const emptyState = document.querySelector('.explore-empty-state');
    const searchInput = document.getElementById('desktop-explore-search') as HTMLInputElement;

    function triggerStaggeredAnimation(container: HTMLElement | null) {
      if (!container) return;
      const items = container.querySelectorAll('.animate-fade-in');
      items.forEach((item: any, index: number) => {
        item.style.animation = 'none';
        void item.offsetWidth; // Force reflow
        item.style.animation = '';
        item.style.animationDelay = `${index * 75}ms`;
      });
    }

    // Trigger initially
    triggerStaggeredAnimation(content as HTMLElement);
    
    categoryBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        // Update active state
        categoryBtns.forEach(b => {
          b.className = 'px-5 py-2 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-xs font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 active:scale-95 ease-out';
        });
        const target = e.target as HTMLElement;
        target.className = 'px-5 py-2 rounded-full bg-orange-600 text-white text-xs font-bold whitespace-nowrap transition-all duration-200 active:scale-95 ease-out';
        
        // Show skeleton
        if (content && skeleton && emptyState) {
          content.classList.add('hidden');
          emptyState.classList.add('hidden');
          skeleton.classList.remove('hidden');
          
          // Simulate network request
          setTimeout(() => {
            skeleton.classList.add('hidden');
            
            // Just for demonstration, if "Lifestyle" is clicked, show empty state
            if (target.textContent?.trim() === 'Lifestyle') {
              emptyState.classList.remove('hidden');
            } else {
              content.classList.remove('hidden');
              triggerStaggeredAnimation(content as HTMLElement);
            }
          }, 450);
        }
      });
    });

    const suggestionsDropdown = document.getElementById('search-suggestions-dropdown');

    if (searchInput && suggestionsDropdown) {
      let debounceTimeout: any = null;

      // Click away closes suggestions
      document.addEventListener('click', (e) => {
        if (!searchInput.contains(e.target as Node) && !suggestionsDropdown.contains(e.target as Node)) {
          suggestionsDropdown.classList.add('hidden');
        }
      });

      searchInput.addEventListener('focus', () => {
        if (searchInput.value.trim().length >= 2) {
          suggestionsDropdown.classList.remove('hidden');
        }
      });

      searchInput.addEventListener('input', () => {
        const query = searchInput.value.trim();
        clearTimeout(debounceTimeout);

        if (query.length < 2) {
          suggestionsDropdown.innerHTML = '';
          suggestionsDropdown.classList.add('hidden');
          return;
        }

        // Show elegant searching indicator
        suggestionsDropdown.classList.remove('hidden');
        suggestionsDropdown.innerHTML = `
          <div class="p-3.5 text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider text-center flex items-center justify-center gap-1.5">
            <svg class="animate-spin h-3.5 w-3.5 text-orange-600" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Mencari...
          </div>
        `;

        debounceTimeout = setTimeout(async () => {
          try {
            const cacheKey = `pexih_search_desktop_${query.toLowerCase()}`;
            const cachedData = sessionStorage.getItem(cacheKey);
            let data;
            
            if (cachedData) {
              data = JSON.parse(cachedData);
            } else {
              const res = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
              if (!res.ok) throw new Error('Search failed');
              data = await res.json();
              sessionStorage.setItem(cacheKey, JSON.stringify(data));
            }

            if (data.length === 0) {
              suggestionsDropdown.innerHTML = `
                <div class="p-3.5 text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider text-center">
                  Tidak ada hasil
                </div>
              `;
              return;
            }

            suggestionsDropdown.innerHTML = '';
            data.forEach((item: any) => {
              const suggestionEl = document.createElement('a');
              suggestionEl.href = `/desktop/article/${item.id}`;
              suggestionEl.className = 'flex items-center gap-2.5 p-2.5 hover:bg-gray-50 dark:hover:bg-gray-750 transition-colors cursor-pointer text-left w-full block';
              suggestionEl.innerHTML = `
                <img src="${item.img}" class="w-10 h-10 object-cover rounded-md shrink-0 border border-gray-100 dark:border-gray-800" referrerpolicy="no-referrer" />
                <div class="min-w-0 flex-1">
                  <p class="text-[11px] font-bold text-gray-900 dark:text-white truncate leading-tight">${item.title}</p>
                  <p class="text-[8px] font-bold text-orange-600 dark:text-orange-500 uppercase tracking-wider mt-0.5">${item.category}</p>
                </div>
              `;
              suggestionsDropdown.appendChild(suggestionEl);
            });
          } catch (err) {
            console.error('Search error:', err);
            suggestionsDropdown.innerHTML = `
              <div class="p-3.5 text-[10px] font-bold text-red-500 uppercase tracking-wider text-center">
                Gagal memuat hasil
              </div>
            `;
          }
        }, 300);
      });
    }

    // Infinite Scrolling Logic
    const sentinel = document.getElementById('desktop-explore-sentinel');
    const articlesContainer = document.querySelector('.explore-actual-content > .grid');
    let currentPage = 1;
    let isLoading = false;
    let hasMore = true;
    
    if (sentinel && articlesContainer) {
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && !isLoading && hasMore) {
          loadMoreArticles();
        }
      }, { rootMargin: '150px' });
      
      observer.observe(sentinel);
      
      async function loadMoreArticles() {
        isLoading = true;
        sentinel.classList.remove('opacity-0');
        
        try {
          currentPage++;
          const cacheKey = `pexih_explore_desktop_page_${currentPage}`;
          const cachedData = sessionStorage.getItem(cacheKey);
          let newArticles;
          
          if (cachedData) {
            newArticles = JSON.parse(cachedData);
          } else {
            const backendUrl = sentinel.getAttribute('data-backend-url') || '';
            const res = await fetch(`${backendUrl}/api/articles?page=${currentPage}&limit=9`); 
            if (!res.ok) throw new Error('Failed');
            newArticles = await res.json();
            sessionStorage.setItem(cacheKey, JSON.stringify(newArticles));
          }
          
          if (newArticles.length === 0) {
            hasMore = false;
            sentinel.classList.add('hidden');
            return;
          }
          
          newArticles.forEach((item: any, index: number) => {
            const articleHtml = `
              <a href="/desktop/article/${item.id}" class="block group bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden hover:border-orange-500 transition-all duration-300 animate-fade-in" style="animation-delay: ${index * 75}ms">
                <div class="aspect-[16/9] pexih-placeholder bg-gray-100 dark:bg-gray-800 overflow-hidden">
                  <img 
                    src="${item.img || `https://images.unsplash.com/photo-${1550000000000 + Math.floor(Math.random() * 100)}?auto=format,compress&fit=crop&w=400&q=80`}" 
                    alt="Thumbnail for ${item.title}" 
                    width="400"
                    height="225"
                    class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300 aspect-[16/9] opacity-0"
                    onload="this.classList.remove('opacity-0')"
                    loading="lazy"
                    decoding="async"
                    referrerpolicy="no-referrer"
                  />
                </div>
                <div class="p-4 space-y-2">
                  <span class="text-[9px] text-orange-600 dark:text-orange-500 font-bold uppercase tracking-wider">${item.category || 'Trending'}</span>
                  <h4 class="text-sm font-bold text-gray-900 dark:text-white line-clamp-2 group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors">${item.title}</h4>
                  <p class="text-[10px] text-gray-500 dark:text-gray-400">${item.author?.name || 'Author'} • ${item.readTime || '5 min read'}</p>
                </div>
              </a>
            `;
            articlesContainer.insertAdjacentHTML('beforeend', articleHtml);
          });
        } catch (e) {
          console.error("Failed to load more articles", e);
        } finally {
          isLoading = false;
          sentinel.classList.add('opacity-0');
        }
      }
    }
  });
</script>
