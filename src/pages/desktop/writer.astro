---
import DesktopLayout from '../../layouts/DesktopLayout.astro';
import HeaderActions from '../../components/HeaderActions.astro';
---
<DesktopLayout title="New Post - PEXIH">
  <link rel="stylesheet" href="https://unpkg.com/easymde/dist/easymde.min.css">
  
  <!-- Header -->
  <div class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 px-8 py-5 flex items-center justify-between sticky top-0 z-50">
    <div>
      <h1 class="text-xl font-bold text-gray-900 dark:text-white">Create New Post</h1>
      <p class="text-sm text-gray-500 mt-1">Compose a new article and publish it to the community feed.</p>
    </div>
    <div class="flex items-center gap-3">
      <button id="desktop-publish-btn" class="bg-orange-600 hover:bg-orange-700 text-white px-5 py-2.5 rounded-lg text-xs font-bold transition-all duration-200 active:scale-95 ease-out shadow-sm shadow-orange-600/20">
        Publish Post
      </button>
      <HeaderActions />
    </div>
  </div>

  <div class="p-8 max-w-5xl mx-auto space-y-6 pb-24">
    <!-- Editor Card -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm p-8 space-y-6">
      <input id="desktop-post-title" type="text" placeholder="Enter post title here..." class="w-full text-2xl font-black text-gray-900 dark:text-white placeholder:text-gray-400 dark:placeholder:text-gray-600 focus:outline-none bg-transparent border-b border-gray-100 dark:border-gray-800 pb-4" />
      
      <!-- Category and Cover grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider mb-2">Topic Category</label>
          <select id="desktop-post-category" class="w-full px-4 py-2.5 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-xs focus:outline-none focus:border-orange-500 transition-colors dark:text-white">
            <option value="Technology">Technology</option>
            <option value="Design">Design</option>
            <option value="Lifestyle">Lifestyle</option>
            <option value="Web Dev">Web Dev</option>
            <option value="General">General</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider mb-2">Cover Image URL</label>
          <input id="desktop-post-cover" type="url" placeholder="https://images.unsplash.com/photo-..." class="w-full px-4 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-xs focus:outline-none focus:border-orange-500 transition-colors dark:text-white" />
        </div>
      </div>

      <!-- EasyMDE Textarea Container -->
      <div class="w-full prose dark:prose-invert max-w-none editor-container dark:text-white">
        <label class="block text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider mb-2">Content</label>
        <textarea id="desktop-markdown-editor" placeholder="Write your thoughts here..." class="w-full min-h-[300px] text-sm text-gray-700 dark:text-gray-300 placeholder:text-gray-400 focus:outline-none bg-transparent resize-none leading-relaxed"></textarea>
      </div>
    </div>
  </div>

  <style is:global>
    .editor-container .editor-toolbar {
      border: 1px solid #e5e7eb;
      border-radius: 0.5rem 0.5rem 0 0;
      opacity: 1;
      padding: 6px;
    }
    .dark .editor-container .editor-toolbar {
      border-color: #1f2937;
      background-color: #111827;
    }
    .dark .editor-container .editor-toolbar button {
      color: #d1d5db;
    }
    .dark .editor-container .editor-toolbar button:hover,
    .dark .editor-container .editor-toolbar button.active {
      background-color: #374151;
      color: #fff;
    }
    .editor-container .editor-toolbar button {
      width: 28px;
      height: 28px;
      padding: 4px;
      margin: 2px;
    }
    .editor-container .CodeMirror {
      border: 1px solid #e5e7eb;
      border-radius: 0 0 0.5rem 0.5rem;
      border-top: none;
      min-height: 400px;
      font-size: 14px;
      font-family: inherit;
    }
    .dark .editor-container .CodeMirror {
      border-color: #1f2937;
      background-color: #111827;
      color: #f3f4f6;
    }
    .dark .editor-container .CodeMirror-cursor {
      border-left-color: #f3f4f6;
    }
    .editor-container .editor-statusbar {
      padding: 6px 10px;
      font-size: 11px;
      color: #9ca3af;
    }
  </style>

  <script src="https://unpkg.com/easymde/dist/easymde.min.js" is:inline></script>
  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      const titleInput = document.getElementById('desktop-post-title');
      const coverInput = document.getElementById('desktop-post-cover');
      const categorySelect = document.getElementById('desktop-post-category');
      const publishBtn = document.getElementById('desktop-publish-btn');
      
      // Initialize EasyMDE
      const easyMDE = new EasyMDE({ 
        element: document.getElementById('desktop-markdown-editor'),
        spellChecker: false,
        placeholder: "Write your thoughts here...",
        status: ["words"],
        toolbar: ["bold", "italic", "heading", "|", "quote", "unordered-list", "ordered-list", "|", "link", "image", "preview", "side-by-side", "fullscreen"]
      });

      // Load draft from localStorage
      const savedTitle = localStorage.getItem('pexih_desktop_draft_title');
      const savedContent = localStorage.getItem('pexih_desktop_draft_content');
      const savedCover = localStorage.getItem('pexih_desktop_draft_cover');
      
      if (savedTitle && titleInput) titleInput.value = savedTitle;
      if (savedCover && coverInput) coverInput.value = savedCover;
      if (savedContent) easyMDE.value(savedContent);

      // Auto-save function
      const saveDraft = () => {
        if (titleInput) localStorage.setItem('pexih_desktop_draft_title', titleInput.value);
        if (coverInput) localStorage.setItem('pexih_desktop_draft_cover', coverInput.value);
        localStorage.setItem('pexih_desktop_draft_content', easyMDE.value());
      };

      if (titleInput) titleInput.addEventListener('input', saveDraft);
      if (coverInput) coverInput.addEventListener('input', saveDraft);
      easyMDE.codemirror.on('change', saveDraft);

      // Publish action
      if (publishBtn) {
        publishBtn.addEventListener('click', async () => {
          const title = titleInput?.value.trim();
          const content = easyMDE.value().trim();
          const img = coverInput?.value.trim() || 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format,compress&fit=crop&w=800&q=80';
          const category = categorySelect?.value || 'General';

          if (!title || !content) {
            window.toast('Please fill in both title and content');
            return;
          }

          publishBtn.disabled = true;
          publishBtn.textContent = 'Publishing...';

          try {
            const res = await fetch('/api/articles/create', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ title, content, img, category })
            });

            if (res.ok) {
              window.toast('Article published successfully!');
              localStorage.removeItem('pexih_desktop_draft_title');
              localStorage.removeItem('pexih_desktop_draft_content');
              localStorage.removeItem('pexih_desktop_draft_cover');
              setTimeout(() => {
                window.location.href = '/desktop';
              }, 1200);
            } else {
              const data = await res.json();
              window.toast(data.error || 'Failed to publish article');
              publishBtn.disabled = false;
              publishBtn.textContent = 'Publish Post';
            }
          } catch (error) {
            console.error('Error publishing article:', error);
            window.toast('Error occurred while publishing');
            publishBtn.disabled = false;
            publishBtn.textContent = 'Publish Post';
          }
        });
      }
    });
  </script>
</DesktopLayout>
