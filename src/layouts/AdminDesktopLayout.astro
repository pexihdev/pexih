---
import Layout from './Layout.astro';

interface Props {
	title?: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<Layout title={title}>
	<div class="flex h-screen overflow-hidden bg-gray-50 dark:bg-gray-900 w-full" style="padding-top: env(safe-area-inset-top); padding-bottom: env(safe-area-inset-bottom);">
		<aside id="admin-desktop-sidebar" class="w-64 bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800 sticky top-0 h-full flex flex-col shrink-0 transition-all duration-300">
			<script is:inline>
				(function() {
					if (localStorage.getItem('admin-sidebar-collapsed') === 'true') {
						const aside = document.currentScript.parentElement;
						aside.classList.remove('w-64');
						aside.classList.add('w-[70px]');
					}
				})();
			</script>
			<div class="p-5 flex items-center justify-between border-b border-gray-100 dark:border-gray-800 bg-gray-900">
				<div class="flex items-center gap-2 overflow-hidden brand-container">
					<div class="w-8 h-8 rounded-lg bg-orange-600 text-white flex items-center justify-center font-bold shrink-0">A</div>
					<span class="font-bold text-white whitespace-nowrap sidebar-text"><span translate="no" class="notranslate">PE<span class="text-orange-600">X</span>IH</span> Admin</span>
				</div>
				<button id="toggle-admin-sidebar" class="p-1 rounded-lg hover:bg-gray-800 text-gray-400 hover:text-white transition-colors cursor-pointer" aria-label="Toggle Sidebar">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg>
				</button>
			</div>
			
			<nav class="flex-1 py-4 px-3 space-y-1">
				<a href="/admin/desktop" class={`flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors ${currentPath === '/admin/desktop' ? 'bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-500 font-medium' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'}`}>
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
					<span class="text-sm sidebar-text">Dashboard</span>
				</a>
				<a href="/admin/desktop/analytics" class={`flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors ${currentPath.startsWith('/admin/desktop/analytics') ? 'bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-500 font-medium' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'}`}>
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/></svg>
					<span class="text-sm sidebar-text">Analytics</span>
				</a>
				<a href="/admin/desktop/users" class={`flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors ${currentPath.startsWith('/admin/desktop/users') ? 'bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-500 font-medium' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'}`}>
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
					<span class="text-sm sidebar-text">Users</span>
				</a>
				<a href="/admin/desktop/content" class={`flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors ${currentPath.startsWith('/admin/desktop/content') ? 'bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-500 font-medium' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'}`}>
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><line x1="10" x2="8" y1="9" y2="9"/></svg>
					<span class="text-sm sidebar-text">Content</span>
				</a>
				<a href="/admin/desktop/media" class={`flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors ${currentPath.startsWith('/admin/desktop/media') ? 'bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-500 font-medium' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'}`}>
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
					<span class="text-sm sidebar-text">Media Library</span>
				</a>
				<a href="/admin/desktop/categories" class={`flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors ${currentPath.startsWith('/admin/desktop/categories') ? 'bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-500 font-medium' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'}`}>
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="M12 2H2v10h10V2z"/><path d="M22 14h-10v8h10v-8z"/><path d="M12 14H2v8h10v-8z"/><path d="M22 2h-10v10h10V2z"/></svg>
					<span class="text-sm sidebar-text">Categories</span>
				</a>
				<a href="/admin/desktop/settings" class={`flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors ${currentPath.startsWith('/admin/desktop/settings') ? 'bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-500 font-medium' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'}`}>
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
					<span class="text-sm sidebar-text">Settings</span>
				</a>
			</nav>
			
			<div class="p-4 border-t border-gray-100 dark:border-gray-800">
				<a href="/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
					<span class="text-sm sidebar-text">Switch to Mobile Admin</span>
				</a>
				<a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors mt-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" x2="3" y1="12" y2="12"/></svg>
					<span class="text-sm sidebar-text">Back to App</span>
				</a>
			</div>
		</aside>

		<style is:global>
			/* When admin sidebar is collapsed */
			aside.w-\[70px\] {
				width: 70px !important;
			}
			aside.w-\[70px\] .sidebar-text {
				display: none !important;
			}
			aside.w-\[70px\] .brand-container {
				justify-content: center !important;
			}
			aside.w-\[70px\] .p-5 {
				padding-left: 0.5rem !important;
				padding-right: 0.5rem !important;
				flex-direction: column !important;
				align-items: center !important;
				justify-content: center !important;
				gap: 0.75rem !important;
			}
			aside.w-\[70px\] .p-4 {
				padding-left: 0.5rem !important;
				padding-right: 0.5rem !important;
			}
			aside.w-\[70px\] .p-4 a {
				justify-content: center !important;
				padding-left: 0.5rem !important;
				padding-right: 0.5rem !important;
				gap: 0 !important;
			}
			aside.w-\[70px\] nav {
				padding-left: 0.5rem !important;
				padding-right: 0.5rem !important;
			}
			aside.w-\[70px\] nav a {
				justify-content: center !important;
				padding-left: 0.5rem !important;
				padding-right: 0.5rem !important;
				gap: 0 !important;
			}
		</style>

		<script>
			function setupAdminSidebarToggle() {
				const aside = document.getElementById('admin-desktop-sidebar');
				const toggleBtn = document.getElementById('toggle-admin-sidebar');
				if (!aside || !toggleBtn) return;

				// Restore state from localStorage
				const isCurrentlyCollapsed = localStorage.getItem('admin-sidebar-collapsed') === 'true';
				if (isCurrentlyCollapsed) {
					aside.classList.remove('w-64');
					aside.classList.add('w-[70px]');
				} else {
					aside.classList.remove('w-[70px]');
					aside.classList.add('w-64');
				}

				toggleBtn.addEventListener('click', () => {
					const isCollapsed = aside.classList.contains('w-[70px]');
					if (isCollapsed) {
						aside.classList.remove('w-[70px]');
						aside.classList.add('w-64');
						localStorage.setItem('admin-sidebar-collapsed', 'false');
					} else {
						aside.classList.remove('w-64');
						aside.classList.add('w-[70px]');
						localStorage.setItem('admin-sidebar-collapsed', 'true');
					}
				});
			}

			// Run on initial load and on every page navigation
			setupAdminSidebarToggle();
			document.addEventListener('astro:page-load', setupAdminSidebarToggle);
		</script>
		
		<main class="flex-1 min-h-0 w-full flex flex-col overflow-y-auto bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100">
			<slot />
		</main>
	</div>
</Layout>
