---
import AdminMobileLayout from '../../layouts/AdminMobileLayout.astro';
---
<AdminMobileLayout title="Analytics">
  <div class="fixed top-0 w-full max-w-[400px] z-50">
    <div class="w-full h-[max(env(safe-area-inset-top),16px)] bg-gray-900"></div>
    <div class="bg-gray-900 text-white pt-3 pb-2 px-5 border-b border-gray-800 flex items-center justify-between">
      <h1 class="text-[16px] font-bold">Analytics</h1>
      <select aria-label="Time period" class="bg-gray-800 border border-gray-700 text-white px-2 py-1 rounded text-[10px] font-bold focus:outline-none">
        <option>7 Days</option>
        <option>30 Days</option>
      </select>
    </div>
  </div>

  <div class="" style="height: calc(52px + max(env(safe-area-inset-top), 16px));"></div>
  <div class="p-4 space-y-4">
    <!-- Chart -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 shadow-sm p-4">
      <h2 class="text-[12px] font-bold text-gray-900 dark:text-white mb-4">Traffic Overview</h2>
      
      <div class="h-32 flex items-end justify-between gap-1 border-b border-l border-gray-100 dark:border-gray-800 pb-1 pl-1">
        {[40, 60, 45, 80, 55, 90, 75].map((h) => (
          <div class="w-full bg-orange-600 rounded-t-sm" style={`height: ${h}%`}></div>
        ))}
      </div>
      <div class="flex justify-between mt-1 text-[8px] text-gray-400 dark:text-gray-500 font-medium">
        <span>Mon</span>
        <span>Tue</span>
        <span>Wed</span>
        <span>Thu</span>
        <span>Fri</span>
        <span>Sat</span>
        <span>Sun</span>
      </div>
    </div>
    
    <!-- Top Pages -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 shadow-sm p-4">
      <h2 class="text-[12px] font-bold text-gray-900 dark:text-white mb-3">Top Pages</h2>
      <div class="space-y-3">
        {[
          { path: '/explore/tech', views: '12.4k' },
          { path: '/post/future-of-web', views: '8.2k' },
          { path: '/profile/johndoe', views: '3.1k' }
        ].map((item, i) => (
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="text-[10px] font-bold text-gray-400 dark:text-gray-500">{i + 1}</span>
              <span class="text-[11px] text-gray-700 dark:text-gray-300 font-medium truncate max-w-[150px]">{item.path}</span>
            </div>
            <span class="text-[11px] font-bold text-gray-900 dark:text-white">{item.views}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</AdminMobileLayout>
