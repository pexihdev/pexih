---
import AdminDesktopLayout from '../../../layouts/AdminDesktopLayout.astro';
---
<AdminDesktopLayout title="Manage Users">
  <div class="bg-white dark:bg-gray-900 border-b border-gray-100 dark:border-gray-800 px-5 h-[52px] flex items-center justify-between sticky top-0 z-50">
    <div class="flex items-center gap-2">
      <h1 class="text-[16px] font-bold text-gray-900 dark:text-white">User Management</h1>
    </div>
    <div class="flex items-center gap-3">
      <div class="flex gap-2">
        <div class="relative">
          <input type="text" id="desktop-user-search" placeholder="Search by name or email..." class="w-64 pl-9 pr-4 py-1.5 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[12px] focus:outline-none focus:ring-2 focus:ring-orange-500 focus:bg-white dark:focus:bg-gray-900 transition-all dark:text-white" />
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        <select id="desktop-role-filter" class="px-3 py-1.5 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[12px] font-bold focus:outline-none focus:ring-2 focus:ring-orange-500 transition-colors dark:text-white">
          <option value="all">All Roles</option>
          <option value="Admin">Admin</option>
          <option value="Writer">Writer</option>
          <option value="User">User</option>
        </select>
      </div>
      <button class="bg-orange-600 text-white px-3 py-1.5 rounded-lg text-xs font-bold transition-colors hover:bg-orange-700">
        Add User
      </button>
    </div>
  </div>

  <div class="p-5">
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden">
      <table class="w-full text-left text-xs" id="desktop-users-table">
        <thead class="bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-800 text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">
          <tr>
            <th class="px-4 py-2">User</th>
            <th class="px-4 py-2">Role</th>
            <th class="px-4 py-2">Status</th>
            <th class="px-4 py-2">Joined Date</th>
            <th class="px-4 py-2 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800" id="desktop-user-list">
          <!-- Injected via JS -->
        </tbody>
      </table>
      
      <!-- Empty State -->
      <div id="desktop-empty-state" class="hidden text-center py-10">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-gray-300 dark:text-gray-700 mb-2"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
        <p class="text-sm font-bold text-gray-900 dark:text-white">No users found</p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Try adjusting your search or filters.</p>
      </div>
      
      <!-- Infinite Scroll Sentinel -->
      <div id="desktop-users-sentinel" class="py-4 opacity-0 transition-opacity w-full space-y-2">
        <div class="flex items-center justify-between p-4 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg animate-pulse">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gray-200 dark:bg-gray-800"></div>
            <div class="space-y-2">
              <div class="w-32 h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-24 h-2 bg-gray-150 dark:bg-gray-850 rounded"></div>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-16 h-4 bg-gray-200 dark:bg-gray-800 rounded-full"></div>
            <div class="w-20 h-4 bg-gray-200 dark:bg-gray-800 rounded-full"></div>
            <div class="w-8 h-8 rounded bg-gray-200 dark:bg-gray-800"></div>
          </div>
        </div>
        <div class="flex items-center justify-between p-4 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg animate-pulse">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gray-200 dark:bg-gray-800"></div>
            <div class="space-y-2">
              <div class="w-32 h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-24 h-2 bg-gray-150 dark:bg-gray-850 rounded"></div>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-16 h-4 bg-gray-200 dark:bg-gray-800 rounded-full"></div>
            <div class="w-20 h-4 bg-gray-200 dark:bg-gray-800 rounded-full"></div>
            <div class="w-8 h-8 rounded bg-gray-200 dark:bg-gray-800"></div>
          </div>
        </div>
      </div>
      
      <!-- List Count -->
      <div class="bg-gray-50 dark:bg-gray-800/50 border-t border-gray-200 dark:border-gray-800 px-4 py-1.5 flex items-center justify-between" id="desktop-pagination">
        <span class="text-[10px] text-gray-500 dark:text-gray-400 font-medium">Showing <span id="desktop-count" class="font-bold"></span> results</span>
      </div>
    </div>
  </div>

  <!-- Custom Confirmation Modal (Desktop) -->
  <div id="desktop-confirm-modal" class="fixed inset-0 z-[60] bg-black/50 backdrop-blur-sm hidden items-center justify-center p-4">
    <div class="bg-white dark:bg-gray-900 w-full max-w-[400px] rounded-xl shadow-2xl p-6 transform scale-95 opacity-0 transition-all duration-200" id="desktop-modal-content">
      <div class="flex justify-center mb-5">
        <div class="w-14 h-14 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center text-orange-600 dark:text-orange-500" id="desktop-modal-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
      </div>
      <h3 id="desktop-modal-title" class="text-lg font-bold text-gray-900 dark:text-white text-center mb-2">Confirm Action</h3>
      <p id="desktop-modal-desc" class="text-sm text-gray-500 dark:text-gray-400 text-center mb-8 leading-relaxed">Are you sure you want to proceed?</p>
      
      <div class="flex gap-3">
        <button id="desktop-modal-cancel" class="flex-1 py-2.5 rounded-lg border border-gray-200 dark:border-gray-700 text-sm font-bold text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
          Cancel
        </button>
        <button id="desktop-modal-confirm" class="flex-1 py-2.5 rounded-lg bg-orange-600 text-white text-sm font-bold hover:bg-orange-700 transition-colors">
          Yes, Proceed
        </button>
      </div>
    </div>
  </div>

  <script is:inline>
    const desktopUsers = [
      { id: 1, name: 'John Doe', email: 'john@example.com', role: 'Admin', status: 'Active', date: 'Oct 24, 2026' },
      { id: 2, name: 'Jane Smith', email: 'jane@example.com', role: 'Writer', status: 'Active', date: 'Oct 22, 2026' },
      { id: 3, name: 'Mike Ross', email: 'mike@example.com', role: 'User', status: 'Suspended', date: 'Sep 15, 2026' },
      { id: 4, name: 'Sarah Connor', email: 'sarah@example.com', role: 'User', status: 'Active', date: 'Aug 05, 2026' },
      { id: 5, name: 'Tom Hardy', email: 'tom@example.com', role: 'User', status: 'Pending', date: 'Nov 01, 2026' }
    ];

    let desktopCurrentAction = null;
    let desktopCurrentUser = null;

    function renderDesktopUsers() {
      const searchInput = document.getElementById('desktop-user-search').value.toLowerCase();
      const roleFilter = document.getElementById('desktop-role-filter').value;
      const listEl = document.getElementById('desktop-user-list');
      const emptyState = document.getElementById('desktop-empty-state');
      const tableEl = document.getElementById('desktop-users-table');
      const countEl = document.getElementById('desktop-count');
      const paginationEl = document.getElementById('desktop-pagination');
      
      const filtered = desktopUsers.filter(u => {
        const matchSearch = u.name.toLowerCase().includes(searchInput) || u.email.toLowerCase().includes(searchInput);
        const matchRole = roleFilter === 'all' || u.role === roleFilter;
        return matchSearch && matchRole;
      });

      if (filtered.length === 0) {
        tableEl.classList.add('hidden');
        paginationEl.classList.add('hidden');
        emptyState.classList.remove('hidden');
        return;
      }

      tableEl.classList.remove('hidden');
      paginationEl.classList.remove('hidden');
      emptyState.classList.add('hidden');
      
      countEl.innerText = filtered.length;
      
      listEl.innerHTML = filtered.map(user => `
        <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
          <td class="px-4 py-1.5">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center text-orange-700 dark:text-orange-500 font-bold text-xs">
                ${user.name.charAt(0)}
              </div>
              <div>
                <p class="font-bold text-gray-900 dark:text-white text-xs leading-none">${user.name}</p>
                <p class="text-[10px] text-gray-500 dark:text-gray-400 mt-0.5">${user.email}</p>
              </div>
            </div>
          </td>
          <td class="px-4 py-1.5">
            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-bold ${
 user.role === 'Admin' ? 'bg-purple-100 dark:bg-purple-900/30 text-purple-800 dark:text-purple-400' :
              user.role === 'Writer' ? 'bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-400' :
              'bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-300'
            }">
              ${user.role}
            </span>
          </td>
          <td class="px-4 py-1.5">
            <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[9px] font-bold ${
 user.status === 'Active' ? 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400' :
              user.status === 'Suspended' ? 'bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-400' :
              'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-400'
            }">
              <span class="w-1 h-1 rounded-full ${
 user.status === 'Active' ? 'bg-green-500' :
                user.status === 'Suspended' ? 'bg-red-500' :
                'bg-yellow-500'
              }"></span>
              ${user.status}
            </span>
          </td>
          <td class="px-4 py-1.5 text-gray-500 dark:text-gray-400 text-[10px]">
            ${user.date}
          </td>
          <td class="px-4 py-1.5 text-right">
            <div class="flex items-center justify-end gap-1">
              <button onclick="requestDesktopAction('suspend', ${user.id})" class="text-[10px] px-2 py-0.5 rounded bg-yellow-50 dark:bg-yellow-900/20 text-yellow-700 dark:text-yellow-500 font-bold hover:bg-yellow-100 dark:hover:bg-yellow-900/40 transition-colors">
                ${user.status === 'Suspended' ? 'Unsuspend' : 'Suspend'}
              </button>
              <button onclick="requestDesktopAction('delete', ${user.id})" class="text-[10px] px-2 py-0.5 rounded bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-500 font-bold hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors">
                Delete
              </button>
            </div>
          </td>
        </tr>
      `).join('');
    }

    // Modal Logic
    function requestDesktopAction(action, userId) {
      desktopCurrentUser = desktopUsers.find(u => u.id === userId);
      desktopCurrentAction = action;
      
      const modal = document.getElementById('desktop-confirm-modal');
      const modalContent = document.getElementById('desktop-modal-content');
      const title = document.getElementById('desktop-modal-title');
      const desc = document.getElementById('desktop-modal-desc');
      const confirmBtn = document.getElementById('desktop-modal-confirm');
      
      if (action === 'delete') {
        title.innerText = 'Delete User';
        desc.innerText = `Are you sure you want to permanently delete ${desktopCurrentUser.name}? This action cannot be undone.`;
        confirmBtn.className = 'flex-1 py-2.5 rounded-lg bg-red-600 text-white text-sm font-bold hover:bg-red-700 transition-colors';
        confirmBtn.innerText = 'Yes, Delete';
      } else {
        const isSuspended = desktopCurrentUser.status === 'Suspended';
        title.innerText = isSuspended ? 'Unsuspend User' : 'Suspend User';
        desc.innerText = `Are you sure you want to ${isSuspended ? 'unsuspend' : 'suspend'} ${desktopCurrentUser.name}?`;
        confirmBtn.className = 'flex-1 py-2.5 rounded-lg bg-yellow-500 text-white text-sm font-bold hover:bg-yellow-600 transition-colors';
        confirmBtn.innerText = isSuspended ? 'Yes, Unsuspend' : 'Yes, Suspend';
      }
      
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      // trigger reflow
      void modal.offsetWidth;
      modalContent.classList.remove('scale-95', 'opacity-0');
      modalContent.classList.add('scale-100', 'opacity-100');
    }

    function closeDesktopModal() {
      const modal = document.getElementById('desktop-confirm-modal');
      const modalContent = document.getElementById('desktop-modal-content');
      
      modalContent.classList.remove('scale-100', 'opacity-100');
      modalContent.classList.add('scale-95', 'opacity-0');
      
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        desktopCurrentAction = null;
        desktopCurrentUser = null;
      }, 200);
    }

    document.getElementById('desktop-modal-cancel').addEventListener('click', closeDesktopModal);
    document.getElementById('desktop-modal-confirm').addEventListener('click', async () => {
      const confirmBtn = document.getElementById('desktop-modal-confirm');
      confirmBtn.disabled = true;
      confirmBtn.innerText = 'Processing...';

      if (desktopCurrentAction === 'delete') {
        try {
          const res = await fetch(`/api/users/${desktopCurrentUser.id}`, { method: 'DELETE' });
          if (res.ok) {
            const index = desktopUsers.findIndex(u => u.id === desktopCurrentUser.id);
            if(index !== -1) desktopUsers.splice(index, 1);
            window.toast('User deleted successfully');
          } else {
            const err = await res.json();
            window.toast('Failed to delete user: ' + (err.error || 'Unknown'));
          }
        } catch (e) {
          window.toast('Error deleting user');
        }
      } else if (desktopCurrentAction === 'suspend') {
        const newStatus = desktopCurrentUser.status === 'Suspended' ? 'Active' : 'Suspended';
        try {
          const res = await fetch(`/api/users/${desktopCurrentUser.id}/status`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: newStatus })
          });
          if (res.ok) {
            desktopCurrentUser.status = newStatus;
            window.toast(`User ${newStatus === 'Active' ? 'unsuspended' : 'suspended'} successfully`);
          } else {
            const err = await res.json();
            window.toast('Failed to update status: ' + (err.error || 'Unknown'));
          }
        } catch (e) {
          window.toast('Error updating status');
        }
      }
      
      confirmBtn.disabled = false;
      closeDesktopModal();
      renderDesktopUsers();
    });

    document.getElementById('desktop-user-search').addEventListener('input', renderDesktopUsers);
    document.getElementById('desktop-role-filter').addEventListener('change', renderDesktopUsers);

    // Infinite Scrolling & API fetch
    let currentPage = 1;
    let isLoading = false;
    let hasMore = true;
    
    async function fetchUsers(page = 1) {
      try {
        const res = await fetch(`/api/users?page=${page}&limit=10`);
        if (!res.ok) return;
        const data = await res.json();
        
        if (data.length === 0) {
          hasMore = false;
          document.getElementById('desktop-users-sentinel')?.classList.add('hidden');
          return;
        }
        
        const formatted = data.map(u => ({
          id: u.id,
          name: u.name || u.username || 'User',
          email: u.email || '',
          role: u.role || 'User',
          status: u.status || 'Active',
          date: u.createdAt ? new Date(Number(u.createdAt)).toLocaleDateString() : 'Just now'
        }));
        
        if (page === 1) {
          desktopUsers.length = 0; // clear dummy
        }
        
        desktopUsers.push(...formatted);
        renderDesktopUsers();
      } catch (e) {
        console.error("Failed to fetch users", e);
      }
    }
    
    const sentinel = document.getElementById('desktop-users-sentinel');
    if (sentinel) {
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && !isLoading && hasMore) {
          isLoading = true;
          sentinel.classList.remove('opacity-0');
          currentPage++;
          fetchUsers(currentPage).finally(() => {
            isLoading = false;
            sentinel.classList.add('opacity-0');
          });
        }
      }, { rootMargin: '100px' });
      observer.observe(sentinel);
    }

    // Initial render
    fetchUsers(1);
    document.addEventListener('DOMContentLoaded', renderDesktopUsers);
  </script>
</AdminDesktopLayout>
