---
import AdminDesktopLayout from '../../../layouts/AdminDesktopLayout.astro';

let allArticles = [];
try {
  const backendUrl = import.meta.env.PUBLIC_BACKEND_URL || 'https://pexih-api.vercel.app';
  const res = await fetch(`${backendUrl}/api/articles`);
  if (res.ok) {
    allArticles = await res.json();
  }
} catch (e) {
  console.error("Failed to fetch articles", e);
}

const publishedCount = allArticles.filter(a => a.status === 'published' || a.status === 'approved').length;
const draftCount = allArticles.filter(a => a.status === 'draft').length;
---
<AdminDesktopLayout title="Content Management">
  <div class="bg-white dark:bg-gray-900 border-b border-gray-100 dark:border-gray-800 pt-3 pb-2 px-5 flex items-center justify-between h-[53px] sticky top-0 z-50" transition:name="desktop-header">
    <div class="flex items-center gap-2">
      <h1 class="text-[16px] font-bold text-gray-900 dark:text-white">Content Management</h1>
    </div>
    <div class="flex items-center gap-3">
      <div class="relative">
        <input 
          type="text" 
          id="search-input"
          placeholder="Search content..." 
          class="w-64 pl-9 pr-4 py-1.5 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[12px] focus:outline-none focus:ring-2 focus:ring-orange-500 focus:bg-white dark:focus:bg-gray-900 transition-all dark:text-white" 
        />
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </div>
      <a href="/admin/desktop/editor" class="bg-orange-600 text-white px-3 py-1.5 rounded-lg text-xs font-bold transition-colors hover:bg-orange-700 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
        New Post
      </a>
    </div>
  </div>

  <div class="p-5">
    <div class="flex gap-4 border-b border-gray-200 dark:border-gray-800 mb-4">
      <button id="tab-all" class="text-xs font-bold text-orange-600 dark:text-orange-500 border-b-2 border-orange-600 dark:border-orange-500 pb-2 px-1 transition-all">
        All Content ({allArticles.length})
      </button>
      <button id="tab-published" class="text-xs font-bold text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white pb-2 px-1 transition-all">
        Published ({publishedCount})
      </button>
      <button id="tab-draft" class="text-xs font-bold text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white pb-2 px-1 transition-all">
        Drafts <span id="draft-badge" class="bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 px-1.5 py-0.5 rounded-full text-[10px] ml-1">{draftCount}</span>
      </button>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden">
      <table class="w-full text-left text-xs">
        <thead class="bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-800 text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">
          <tr>
            <th class="px-4 py-2 w-10"><input type="checkbox" id="select-all" class="rounded border-gray-300 dark:border-gray-600 text-orange-600 focus:ring-orange-500 dark:bg-gray-700" /></th>
            <th class="px-4 py-2">Title</th>
            <th class="px-4 py-2">Author</th>
            <th class="px-4 py-2">Status</th>
            <th class="px-4 py-2">Date</th>
            <th class="px-4 py-2 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800" id="articles-table-body">
          {allArticles.length === 0 ? (
            <tr>
              <td colspan="6" class="px-4 py-8 text-center text-gray-400">No articles found. Create your first post!</td>
            </tr>
          ) : (
            allArticles.map((article) => {
              const isDraft = article.status === 'draft';
              const authorName = (article.author as any)?.name || article.externalAuthor || 'Admin';
              const viewsCount = article.views || '0';
              const dateString = new Date(article.createdAt).toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric'
              });
              const thumbnail = article.img || "https://images.unsplash.com/photo-1550000000000?auto=format&fit=crop&w=100&q=80";

              return (
                <tr 
                  class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group article-row"
                  data-status={article.status}
                  data-title={article.title.toLowerCase()}
                  data-author={authorName.toLowerCase()}
                  id={`article-row-${article.id}`}
                >
                  <td class="px-4 py-1.5"><input type="checkbox" class="row-select rounded border-gray-300 dark:border-gray-600 text-orange-600 focus:ring-orange-500 dark:bg-gray-700" /></td>
                  <td class="px-4 py-1.5">
                    <div class="flex items-center gap-2">
                      <div class="w-8 h-8 rounded bg-gray-100 dark:bg-gray-800 overflow-hidden shrink-0 aspect-square">
                        <img 
                          src={thumbnail} 
                          alt={article.title} 
                          width="32"
                          height="32"
                          class="w-full h-full object-cover aspect-square" 
                          loading="lazy" 
                          decoding="async"
                          referrerpolicy="no-referrer" 
                        />
                      </div>
                      <div>
                        <p class="font-bold text-gray-900 dark:text-white group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors line-clamp-1 text-xs">{article.title}</p>
                        <p class="text-[9px] text-gray-400 dark:text-gray-500 mt-0.5 flex items-center gap-1">
                          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h4l3-9 5 18 3-9h5"/></svg>
                          {viewsCount} views
                        </p>
                      </div>
                    </div>
                  </td>
                  <td class="px-4 py-1.5 text-gray-700 dark:text-gray-300 text-xs">{authorName}</td>
                  <td class="px-4 py-1.5">
                    <span class={`inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-bold ${
                      isDraft ? 'bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-300' : 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400'
                    }`}>
                      {article.status}
                    </span>
                  </td>
                  <td class="px-4 py-1.5 text-gray-500 dark:text-gray-400 text-[10px]">{dateString}</td>
                  <td class="px-4 py-1.5 text-right">
                    <div class="flex items-center justify-end gap-1">
                      {isDraft && (
                        <button 
                          class="p-1 text-gray-400 hover:text-green-600 dark:hover:text-green-500 publish-btn transition-colors rounded hover:bg-green-50 dark:hover:bg-green-900/30" 
                          data-id={article.id}
                          aria-label="Publish"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
                        </button>
                      )}
                      <a href={`/admin/desktop/editor?id=${article.id}`} class="p-1 text-gray-400 hover:text-orange-600 dark:hover:text-orange-500 transition-colors rounded hover:bg-orange-50 dark:hover:bg-orange-900/30" aria-label="Edit">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                      </a>
                      <button 
                        class="p-1 text-gray-400 hover:text-red-600 dark:hover:text-red-500 delete-btn transition-colors rounded hover:bg-red-50 dark:hover:bg-red-900/30" 
                        data-id={article.id}
                        aria-label="Delete"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                      </button>
                    </div>
                  </td>
                </tr>
              );
            })
          )}
        </tbody>
      </table>
      
      <!-- Pagination -->
      <div class="bg-gray-50 dark:bg-gray-800/50 border-t border-gray-200 dark:border-gray-800 px-4 py-2 flex items-center justify-between">
        <span class="text-[10px] text-gray-500 dark:text-gray-400" id="pagination-info">
          Showing 1 to {allArticles.length} of {allArticles.length} results
        </span>
        <div class="flex gap-1">
          <button class="px-2 py-0.5 rounded bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 text-gray-500 dark:text-gray-400 text-[10px] font-bold hover:bg-gray-50 dark:hover:bg-gray-600 disabled:opacity-50" disabled>Previous</button>
          <button class="px-2 py-0.5 rounded bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 text-[10px] font-bold hover:bg-gray-50 dark:hover:bg-gray-600 disabled:opacity-50" disabled>Next</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // 1. Tab and Search Filtering
      const tabAll = document.getElementById('tab-all');
      const tabPublished = document.getElementById('tab-published');
      const tabDraft = document.getElementById('tab-draft');
      const searchInput = document.getElementById('search-input') as HTMLInputElement;
      const rows = document.querySelectorAll('.article-row');
      
      let currentFilter = 'all';
      let searchQuery = '';

      function filterRows() {
        let visibleCount = 0;

        rows.forEach(row => {
          const status = row.getAttribute('data-status');
          const title = row.getAttribute('data-title') || '';
          const author = row.getAttribute('data-author') || '';
          
          const matchesSearch = title.includes(searchQuery) || author.includes(searchQuery);
          let matchesFilter = false;

          if (currentFilter === 'all') {
            matchesFilter = true;
          } else if (currentFilter === 'published') {
            matchesFilter = (status === 'published' || status === 'approved');
          } else if (currentFilter === 'draft') {
            matchesFilter = (status === 'draft');
          }

          if (matchesSearch && matchesFilter) {
            (row as HTMLElement).style.display = '';
            visibleCount++;
          } else {
            (row as HTMLElement).style.display = 'none';
          }
        });

        // Update pagination text
        const infoEl = document.getElementById('pagination-info');
        if (infoEl) {
          infoEl.textContent = `Showing 1 to ${visibleCount} of ${rows.length} results`;
        }
      }

      function handleTabClick(activeTab: HTMLElement, filterType: string) {
        [tabAll, tabPublished, tabDraft].forEach(tab => {
          if (tab) {
            tab.classList.remove('text-orange-600', 'dark:text-orange-500', 'border-b-2', 'border-orange-600', 'dark:border-orange-500');
            tab.classList.add('text-gray-500', 'dark:text-gray-400');
          }
        });

        activeTab.classList.remove('text-gray-500', 'dark:text-gray-400');
        activeTab.classList.add('text-orange-600', 'dark:text-orange-500', 'border-b-2', 'border-orange-600', 'dark:border-orange-500');

        currentFilter = filterType;
        filterRows();
      }

      if (tabAll) tabAll.addEventListener('click', () => handleTabClick(tabAll, 'all'));
      if (tabPublished) tabPublished.addEventListener('click', () => handleTabClick(tabPublished, 'published'));
      if (tabDraft) tabDraft.addEventListener('click', () => handleTabClick(tabDraft, 'draft'));

      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          searchQuery = (e.target as HTMLInputElement).value.toLowerCase();
          filterRows();
        });
      }

      // 2. Select All Checkbox
      const selectAllCheckbox = document.getElementById('select-all') as HTMLInputElement;
      if (selectAllCheckbox) {
        selectAllCheckbox.addEventListener('change', (e) => {
          const isChecked = (e.target as HTMLInputElement).checked;
          document.querySelectorAll('.row-select').forEach(cb => {
            (cb as HTMLInputElement).checked = isChecked;
          });
        });
      }

      // 3. Delete functionality
      const deleteButtons = document.querySelectorAll('.delete-btn');
      deleteButtons.forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const button = e.currentTarget as HTMLButtonElement;
          const articleId = button.getAttribute('data-id');
          if (!articleId) return;

          if (confirm('Are you sure you want to delete this article? This action cannot be undone.')) {
            try {
              const res = await fetch(`/api/articles?id=${articleId}`, {
                method: 'DELETE'
              });
              const data = await res.json();
              
              if (data.success) {
                if (window.toast) {
                  window.toast('Article deleted successfully');
                }
                const row = document.getElementById(`article-row-${articleId}`);
                if (row) {
                  row.style.opacity = '0';
                  setTimeout(() => {
                    row.remove();
                    filterRows();
                  }, 300);
                }
              } else {
                if (window.toast) {
                  window.toast(data.error || 'Failed to delete article');
                }
              }
            } catch (err) {
              console.error('Error deleting article:', err);
              if (window.toast) {
                window.toast('Error occurred while deleting');
              }
            }
          }
        });
      });
      // 4. Publish functionality
      const publishButtons = document.querySelectorAll('.publish-btn');
      publishButtons.forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const button = e.currentTarget as HTMLButtonElement;
          const articleId = button.getAttribute('data-id');
          if (!articleId) return;

          if (confirm('Publish this article?')) {
            try {
              const res = await fetch(`/api/articles?id=${articleId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: 'published' })
              });
              const data = await res.json();
              
              if (data.success) {
                if (window.toast) window.toast('Article published successfully');
                setTimeout(() => window.location.reload(), 500);
              } else {
                if (window.toast) window.toast(data.error || 'Failed to publish');
              }
            } catch (err) {
              console.error('Error publishing:', err);
              if (window.toast) window.toast('Error occurred while publishing');
            }
          }
        });
      });
    });
  </script>
</AdminDesktopLayout>
