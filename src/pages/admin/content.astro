---
import AdminMobileLayout from '../../layouts/AdminMobileLayout.astro';

let allArticles = [];
try {
  const backendUrl = import.meta.env.PUBLIC_BACKEND_URL || 'https://pexih-api.vercel.app';
  const res = await fetch(`${backendUrl}/api/articles`);
  if (res.ok) {
    allArticles = await res.json();
  }
} catch (e) {
  console.error("Failed to fetch articles", e);
}

// Count draft vs published articles
const publishedCount = allArticles.filter(a => a.status === 'published' || a.status === 'approved').length;
const draftCount = allArticles.filter(a => a.status === 'draft').length;
---
<AdminMobileLayout title="Content Management">
  <div class="fixed top-0 w-full max-w-[400px] z-50" transition:name="mobile-header">
    <div class="w-full bg-white dark:bg-gray-900" style="height: env(safe-area-inset-top);"></div>
    <div class="bg-white dark:bg-gray-900 pt-3 pb-2 px-5 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between h-[53px]">
      <h1 class="text-[16px] font-bold text-gray-900 dark:text-white">Manage Content</h1>
      <a href="/admin/editor" class="bg-orange-600 text-white px-3 py-1.5 rounded text-[10px] font-bold hover:bg-orange-700 transition-colors">
        New Post
      </a>
    </div>
  </div>

  <div class="shrink-0" style="height: calc(53px + env(safe-area-inset-top));"></div>
  <div class="p-4 pb-20 space-y-4">
    <!-- Filter tabs -->
    <div class="flex gap-4 border-b border-gray-200 dark:border-gray-800 pb-2">
      <button id="tab-all" class="text-[12px] font-bold text-orange-600 dark:text-orange-500 border-b-2 border-orange-600 dark:border-orange-500 pb-1 px-1 transition-all">
        All ({allArticles.length})
      </button>
      <button id="tab-published" class="text-[12px] font-bold text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white pb-1 px-1 transition-all">
        Published ({publishedCount})
      </button>
      <button id="tab-draft" class="text-[12px] font-bold text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white pb-1 px-1 transition-all">
        Drafts ({draftCount})
      </button>
    </div>

    <!-- Content List -->
    <div class="space-y-3" id="articles-list">
      {allArticles.length === 0 ? (
        <div class="py-12 text-center">
          <p class="text-xs text-gray-400">No articles found. Create your first post!</p>
        </div>
      ) : (
        allArticles.map((article) => {
          const isDraft = article.status === 'draft';
          const authorName = (article.author as any)?.name || article.externalAuthor || 'Admin';
          const viewsCount = article.views || '0';
          const thumbnail = article.img || "https://images.unsplash.com/photo-1550000000000?auto=format&fit=crop&w=200&q=80";
          
          return (
            <div 
              class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 shadow-sm overflow-hidden p-3 flex gap-3 article-item transition-all"
              data-status={article.status}
              id={`article-card-${article.id}`}
            >
              <div class="w-16 h-16 bg-gray-100 dark:bg-gray-800 rounded-lg shrink-0 overflow-hidden aspect-square">
                <img 
                  src={thumbnail} 
                  alt={article.title} 
                  width="64"
                  height="64"
                  class="w-full h-full object-cover aspect-square" 
                  loading="lazy" 
                  decoding="async"
                  referrerpolicy="no-referrer" 
                />
              </div>
              <div class="flex-1 min-w-0 flex flex-col justify-between">
                <div>
                  <h3 class="text-[12px] font-bold text-gray-900 dark:text-white leading-tight mb-1 line-clamp-2">{article.title}</h3>
                  <p class="text-[9px] text-gray-500 dark:text-gray-400">By {authorName} • {viewsCount} views</p>
                </div>
                <div class="flex items-center justify-between mt-2">
                  <span class={`inline-block px-2 py-0.5 rounded text-[8px] font-bold uppercase tracking-wider ${
                    isDraft 
                      ? 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400' 
                      : 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400'
                  }`}>
                    {article.status}
                  </span>
                  <div class="flex gap-2">
                    <a href={`/admin/editor?id=${article.id}`} class="text-gray-400 hover:text-orange-600 dark:hover:text-orange-500 p-1" aria-label="Edit">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                    </a>
                    <button 
                      class="text-gray-400 hover:text-red-600 dark:hover:text-red-500 delete-btn p-1" 
                      data-id={article.id}
                      aria-label="Delete"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          );
        })
      )}
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // 1. Tab filtering functionality
      const tabAll = document.getElementById('tab-all');
      const tabPublished = document.getElementById('tab-published');
      const tabDraft = document.getElementById('tab-draft');
      const articles = document.querySelectorAll('.article-item');

      function setActiveTab(activeTab: HTMLElement, filterType: string) {
        [tabAll, tabPublished, tabDraft].forEach(tab => {
          if (tab) {
            tab.classList.remove('text-orange-600', 'dark:text-orange-500', 'border-b-2', 'border-orange-600', 'dark:border-orange-500');
            tab.classList.add('text-gray-500', 'dark:text-gray-400');
          }
        });

        activeTab.classList.remove('text-gray-500', 'dark:text-gray-400');
        activeTab.classList.add('text-orange-600', 'dark:text-orange-500', 'border-b-2', 'border-orange-600', 'dark:border-orange-500');

        articles.forEach(item => {
          const status = item.getAttribute('data-status');
          if (filterType === 'all') {
            (item as HTMLElement).style.display = 'flex';
          } else if (filterType === 'published') {
            if (status === 'published' || status === 'approved') {
              (item as HTMLElement).style.display = 'flex';
            } else {
              (item as HTMLElement).style.display = 'none';
            }
          } else if (filterType === 'draft') {
            if (status === 'draft') {
              (item as HTMLElement).style.display = 'flex';
            } else {
              (item as HTMLElement).style.display = 'none';
            }
          }
        });
      }

      if (tabAll) tabAll.addEventListener('click', () => setActiveTab(tabAll, 'all'));
      if (tabPublished) tabPublished.addEventListener('click', () => setActiveTab(tabPublished, 'published'));
      if (tabDraft) tabDraft.addEventListener('click', () => setActiveTab(tabDraft, 'draft'));

      // 2. Delete functionality
      const deleteButtons = document.querySelectorAll('.delete-btn');
      deleteButtons.forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const button = e.currentTarget as HTMLButtonElement;
          const articleId = button.getAttribute('data-id');
          if (!articleId) return;

          if (confirm('Are you sure you want to delete this article? This action cannot be undone.')) {
            try {
              const res = await fetch(`/api/articles?id=${articleId}`, {
                method: 'DELETE'
              });
              const data = await res.json();
              
              if (data.success) {
                if (window.toast) {
                  window.toast('Article deleted successfully');
                }
                const card = document.getElementById(`article-card-${articleId}`);
                if (card) {
                  card.style.opacity = '0';
                  setTimeout(() => card.remove(), 300);
                }
              } else {
                if (window.toast) {
                  window.toast(data.error || 'Failed to delete article');
                }
              }
            } catch (err) {
              console.error('Error deleting article:', err);
              if (window.toast) {
                window.toast('Error occurred while deleting');
              }
            }
          }
        });
      });
    });
  </script>
</AdminMobileLayout>
