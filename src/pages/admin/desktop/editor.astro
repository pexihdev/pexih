              </button>
            </div>

            <button 
              id="start-upload-btn" 
              class="w-full py-2.5 bg-orange-600 hover:bg-orange-700 text-white rounded-xl text-sm font-bold transition-all active:scale-95 flex items-center justify-center gap-2 cursor-pointer"
