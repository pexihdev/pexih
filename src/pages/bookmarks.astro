---
import MobileLayout from '../layouts/MobileLayout.astro';
import HeaderActions from '../components/HeaderActions.astro';
import EmptyState from '../components/EmptyState.astro';
import ArticleSkeleton from '../components/ArticleSkeleton.astro';

const savedPosts = [1, 2, 3, 4]; // Change to [] to see empty state
---
<MobileLayout title="Saved Posts">
  <div class="fixed top-0 w-full max-w-[400px] z-50 bg-white dark:bg-gray-900" transition:name="mobile-header">
    <div class="w-full" style="height: env(safe-area-inset-top);"></div>
    <div class="pt-3 pb-2 px-5 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between h-[53px]">
      <h1 class="text-[16px] font-bold text-gray-900 dark:text-white" data-i18n="nav.bookmark">Saved</h1>
      <HeaderActions />
    </div>
  </div>

  <div class="shrink-0" style="height: calc(53px + env(safe-area-inset-top));"></div>
  <div class="p-4 space-y-4">
    <!-- Search Bar -->
    <div class="relative w-full">
      <input type="text" id="bookmarks-search-input" placeholder="Search saved posts..." class="w-full pl-9 pr-4 py-2 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-800 text-[11px] focus:outline-none focus:ring-1 focus:ring-orange-500 focus:bg-white dark:focus:bg-gray-900 transition-all dark:text-white" />
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    </div>

    <!-- Categories Dynamic Container -->
    <div class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide" id="bookmarks-categories-container">
      <!-- Generated via JS -->
    </div>

    <!-- List Posts -->
    <div class="article-transition-wrapper">
      <div class="skeleton-container hidden">
        <ArticleSkeleton count={4} />
      </div>
      
      <div class="actual-content-container space-y-3" id="bookmarks-list-container">
        <!-- Dynamic Bookmarks list loaded via JS -->
      </div>
      
      <!-- Empty state for regular bookmarks -->
      <div id="normal-empty-state" class="hidden">
        <EmptyState 
          title="No Bookmarks Yet"
          titleI18n="empty.noBookmarks"
          description="You haven't saved any articles. Explore and save your favorite posts to read them later."
          descriptionI18n="empty.noBookmarksDesc"
          icon={`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-600"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>`}
        >
          <a href="/explore" class="mt-4 px-5 py-2 bg-orange-600 text-white text-[10px] font-bold rounded-full hover:bg-orange-700 transition-colors" data-i18n="empty.explore">
            Explore Articles
          </a>
        </EmptyState>
      </div>

      <!-- Empty state for search/filter -->
      <div class="search-empty-state hidden">
        <EmptyState 
          title="No Results Found"
          titleI18n="empty.noResults"
          description="We couldn't find any articles matching your search. Try different keywords or categories."
          descriptionI18n="empty.noResultsDesc"
          icon={`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-600"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`}
        />
      </div>
    </div>
  </div>
</MobileLayout>

<script>
  import { toast } from 'sonner';
  import { marked } from 'marked';
  import ArticleSkeleton from '../components/ArticleSkeleton.astro';

  document.addEventListener('astro:page-load', () => {
    const listContainer = document.getElementById('bookmarks-list-container');
    const categoriesContainer = document.getElementById('bookmarks-categories-container');
    const skeleton = document.querySelector('.skeleton-container');
    const searchEmptyState = document.querySelector('.search-empty-state');
    const normalEmptyState = document.getElementById('normal-empty-state');
    const searchInput = document.getElementById('bookmarks-search-input') as HTMLInputElement;

    const currentLang = localStorage.getItem('language') || 'en';

    // Seed data
    const seedBookmarks = [
      {
        id: "1",
        title: "How to build intuitive mobile interfaces in 2026",
        category: "Design",
        img: "https://images.unsplash.com/photo-1507238691740-187a5b1d37b8?auto=format,compress&fit=crop&w=200&q=80",
        author: { name: "Jane Doe" },
        readTime: "10 min read",
        label: currentLang === 'id' ? "Dibaca Nanti" : "Read Later",
        savedAt: Date.now() - 3600000 * 2
      },
      {
        id: "2",
        title: "Exploring the Digital Frontier with Astro & Node.js",
        category: "Technology",
        img: "https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format,compress&fit=crop&w=200&q=80",
        author: { name: "Alex Rivers" },
        readTime: "5 min read",
        label: currentLang === 'id' ? "Penting" : "Important",
        savedAt: Date.now() - 3600000
      },
      {
        id: "3",
        title: "Mastering Fluid Grid Systems & Visual Hierarchy",
        category: "Development",
        img: "https://images.unsplash.com/photo-1531403009284-440f080d1e12?auto=format,compress&fit=crop&w=200&q=80",
        author: { name: "Sarah Conner" },
        readTime: "8 min read",
        label: currentLang === 'id' ? "Referensi" : "Reference",
        savedAt: Date.now()
      }
    ];

    let bookmarks = [];
    let activeFilter = "All";
    let searchQuery = "";

    async function initializeBookmarks() {
      // Load local first for immediate display
      try {
        const stored = localStorage.getItem('pexih-bookmarks');
        if (!stored) {
          localStorage.setItem('pexih-bookmarks', JSON.stringify(seedBookmarks));
          bookmarks = seedBookmarks;
        } else {
          bookmarks = JSON.parse(stored);
        }
      } catch (e) {
        bookmarks = seedBookmarks;
      }
      
      renderFilters();
      renderBookmarks();

      // Fetch from backend
      try {
        const res = await fetch('/api/bookmarks');
        if (res.ok) {
          const remoteBookmarks = await res.json();
          if (remoteBookmarks && remoteBookmarks.length > 0) {
            // Merge or replace. Let's map remote structure to local structure
            const mapped = remoteBookmarks.map((rb: any) => ({
              id: String(rb.id),
              title: rb.title,
              category: rb.category || 'General',
              img: rb.coverImage || 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format,compress&fit=crop&w=200&q=80',
              author: { name: rb.authorName || 'Pexih User' },
              readTime: rb.readingTime || '5 min read',
              label: currentLang === 'id' ? "Dibaca Nanti" : "Read Later",
              savedAt: rb.createdAt || Date.now()
            }));
            
            // Create a map to deduplicate by ID
            const map = new Map();
            mapped.forEach((b: any) => map.set(b.id, b));
            // Keep local overrides if they exist? Let's just override with local labels if we want, but server is truth
            bookmarks.forEach((b: any) => {
              if(!map.has(b.id)) map.set(b.id, b); // keep local ones not on server
            });
            
            bookmarks = Array.from(map.values()).sort((a: any, b: any) => b.savedAt - a.savedAt);
            saveBookmarks(bookmarks);
            renderFilters();
            renderBookmarks();
          }
        }
      } catch(e) {
        console.error('Failed to sync bookmarks', e);
      }
    }

    function saveBookmarks(b: any[]) {
      localStorage.setItem('pexih-bookmarks', JSON.stringify(b));
    }

    initializeBookmarks();

    function renderFilters() {
      if (!categoriesContainer) return;
      const labels = ["All", ...new Set(bookmarks.map(b => b.label))];
      
      categoriesContainer.innerHTML = labels.map(label => {
        const isActive = activeFilter === label;
        const btnClass = isActive 
          ? "px-4 py-1.5 rounded-full bg-orange-600 text-white text-[10px] font-bold whitespace-nowrap transition-all duration-200 active:scale-95 cursor-pointer"
          : "px-4 py-1.5 rounded-full bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-[10px] font-medium whitespace-nowrap border border-gray-100 dark:border-gray-700 transition-all duration-200 active:scale-95 cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700";
        
        let displayName = label;
        if (label === "All") displayName = currentLang === 'id' ? "Semua Koleksi" : "All Collections";
        
        return `<button class="${btnClass}" data-filter="${label}">${displayName}</button>`;
      }).join('');

      // Add listeners
      categoriesContainer.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = e.target as HTMLButtonElement;
          activeFilter = target.getAttribute('data-filter') || 'All';
          
          if (listContainer && skeleton && searchEmptyState) {
            listContainer.classList.add('hidden');
            searchEmptyState.classList.add('hidden');
            skeleton.classList.remove('hidden');
            
            setTimeout(() => {
              skeleton.classList.add('hidden');
              renderBookmarks();
              renderFilters(); // Update selected styles
            }, 300);
          }
        });
      });
    }

    function renderBookmarks() {
      if (!listContainer) return;

      let filtered = bookmarks;
      
      // Filter by category label
      if (activeFilter !== "All") {
        filtered = filtered.filter(b => b.label === activeFilter);
      }

      // Filter by search query
      if (searchQuery) {
        filtered = filtered.filter(b => b.title.toLowerCase().includes(searchQuery));
      }

      // Toggle display of empty states
      if (bookmarks.length === 0) {
        normalEmptyState?.classList.remove('hidden');
        listContainer.classList.add('hidden');
        searchEmptyState?.classList.add('hidden');
        return;
      } else {
        normalEmptyState?.classList.add('hidden');
      }

      if (filtered.length === 0) {
        searchEmptyState?.classList.remove('hidden');
        listContainer.classList.add('hidden');
        return;
      } else {
        searchEmptyState?.classList.add('hidden');
        listContainer.classList.remove('hidden');
      }

      listContainer.innerHTML = filtered.map((b, index) => {
        let badgeColor = "bg-orange-100 text-orange-600 dark:bg-orange-950/20 dark:text-orange-400 border border-orange-100/50 dark:border-orange-500/10";
        if (b.label === "Penting" || b.label === "Important") badgeColor = "bg-red-100 text-red-600 dark:bg-red-950/20 dark:text-red-400 border border-red-100/50 dark:border-red-500/10";
        else if (b.label === "Dibaca Nanti" || b.label === "Read Later") badgeColor = "bg-blue-100 text-blue-600 dark:bg-blue-950/20 dark:text-blue-400 border border-blue-100/50 dark:border-blue-500/10";
        else if (b.label === "Referensi" || b.label === "Reference") badgeColor = "bg-emerald-100 text-emerald-600 dark:bg-emerald-950/20 dark:text-emerald-400 border border-emerald-100/50 dark:border-emerald-500/10";

        return `
          <div class="flex gap-3 items-center group bg-white dark:bg-gray-900 p-2 rounded-xl border border-gray-100 dark:border-gray-800 hover:border-orange-500/50 transition-all duration-300 relative animate-fade-in" style="animation-delay: ${index * 75}ms">
            <a href="/article/${b.id}" class="w-16 h-16 rounded-lg overflow-hidden pexih-placeholder bg-gray-100 dark:bg-gray-800 shrink-0 aspect-square">
              <img 
                src="${b.img}" 
                alt="Thumbnail" 
                width="64"
                height="64"
                class="w-full h-full object-cover aspect-square transition-all duration-300 group-hover:scale-105 opacity-0" 
                onload="this.classList.remove('opacity-0')"
                loading="lazy"
                referrerpolicy="no-referrer" 
              />
            </a>
            <div class="flex-1 min-w-0 pr-6">
              <div class="flex items-center gap-1.5 mb-1 flex-wrap">
                <span class="text-[8px] uppercase font-bold text-gray-400">${b.category}</span>
                <span class="text-[8px] px-1.5 py-0.5 rounded-full font-bold ${badgeColor}">${b.label}</span>
              </div>
              <a href="/article/${b.id}" class="block">
                <h4 class="text-[12px] font-bold text-gray-900 dark:text-white leading-tight mb-1 group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors line-clamp-2">${b.title}</h4>
              </a>
              <div class="flex items-center gap-2 text-[9px] text-gray-500 dark:text-gray-400">
                <span class="font-medium text-gray-700 dark:text-gray-300">${b.author?.name || 'Jane Doe'}</span>
                <span>•</span>
                <span>${b.readTime || '5 min read'}</span>
              </div>
            </div>
            <button class="remove-bookmark-btn absolute right-2 top-1/2 -translate-y-1/2 p-2 text-orange-600 dark:text-orange-500 hover:text-red-500 dark:hover:text-red-400 transition-colors cursor-pointer" data-id="${b.id}" aria-label="Remove from saved">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
            </button>
          </div>
        `;
      }).join('');

      // Add listeners to remove buttons
      listContainer.querySelectorAll('.remove-bookmark-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          e.preventDefault();
          const targetId = (e.currentTarget as HTMLButtonElement).getAttribute('data-id');
          bookmarks = bookmarks.filter(b => b.id !== targetId);
          saveBookmarks(bookmarks);
          
          if (window.toast) {
            window.toast(currentLang === 'id' ? "Bookmark dihapus" : "Bookmark removed");
          }
          
          // Sync unbookmark to backend
          try {
            fetch('/api/interactions', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ articleId: targetId, interactionType: 'unbookmark' })
            });
          } catch (e) {
            console.error('Failed to log unbookmark interaction:', e);
          }
          
          renderFilters();
          renderBookmarks();
        });
      });
    }

    if (searchInput) {
      searchInput.addEventListener('input', () => {
        searchQuery = searchInput.value.toLowerCase().trim();
        renderBookmarks();
      });
    }

    renderFilters();
    renderBookmarks();
  });
</script>

