---
import MobileLayout from '../layouts/MobileLayout.astro';
import HeaderActions from '../components/HeaderActions.astro';
import EmptyState from '../components/EmptyState.astro';
import ArticleSkeleton from '../components/ArticleSkeleton.astro';

// Fetch articles from the Backend API for SSR
let feedArticles = [];
const backendUrl = import.meta.env.PUBLIC_BACKEND_URL || 'http://localhost:8080';
try {
  const res = await fetch(`${backendUrl}/api/articles`);
  if (res.ok) {
    const data = await res.json();
    feedArticles = data.slice(0, 5); // Limit to 5 for home feed
  } else {
    throw new Error('Failed to fetch from API');
  }
} catch (e) {
  console.error("Failed to fetch articles from API", e);
}

// Fallback to dummy data if API fails or returns empty
if (feedArticles.length === 0) {
  feedArticles = [1, 2, 3].map((post) => ({
    id: String(post),
    title: `Exploring the Digital Frontier ${post}`,
    content: "An in-depth look at how modern technology is reshaping our daily lives and what the future holds for us.",
    author: { name: "Alex Rivers" },
    img: `https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format,compress&fit=crop&w=800&q=80`,
    category: "Technology",
    readTime: "5 min read",
    views: "1.2k"
  }));
}
---
<MobileLayout title="Home">
  <div class="fixed top-0 w-full max-w-[400px] z-50">
    <div class="w-full h-[max(env(safe-area-inset-top),16px)] bg-white dark:bg-gray-900"></div>
    <div class="bg-white dark:bg-gray-900 pt-3 pb-2 px-5 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-full bg-orange-600 text-white flex items-center justify-center font-bold text-[14px]">P</div>
        <h1 class="text-[16px] font-bold text-gray-900 dark:text-white">PE<span class="text-orange-600">X</span>IH</h1>
      </div>
      <div class="flex items-center gap-1">
        <button aria-label="Notifications" class="w-8 h-8 rounded-full bg-gray-50 dark:bg-gray-800 flex items-center justify-center text-gray-600 dark:text-gray-300 hover:text-orange-600 dark:hover:text-orange-500 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
        </button>
        <HeaderActions />
      </div>
    </div>
  </div>

  <div class="" style="height: calc(52px + max(env(safe-area-inset-top), 16px));"></div>
  <div class="px-4 py-2 space-y-4">
    <!-- Story/Topics section -->
    <div class="flex gap-3 overflow-x-auto pb-2 scrollbar-hide topic-filters">
      {[1, 2, 3, 4, 5].map((item) => (
        <div class="flex flex-col items-center gap-1 shrink-0 cursor-pointer topic-item" data-topic={item}>
          <div class="w-14 h-14 rounded-full p-0.5 bg-gradient-to-tr from-gray-200 to-gray-300 dark:from-gray-700 dark:to-gray-800 transition-all duration-300 topic-ring">
            <div class="w-full h-full rounded-full border-2 border-white dark:border-gray-900 overflow-hidden pexih-placeholder bg-gray-100 dark:bg-gray-800">
              <img 
                src={`https://images.unsplash.com/photo-${1550000000000 + item}?auto=format,compress&fit=crop&w=150&q=80`} 
                alt={`Topic ${item} representation`} 
                width="150"
                height="150"
                class="w-full h-full object-cover aspect-square transition-opacity duration-300 opacity-0" 
                onload="this.classList.remove('opacity-0')"
                loading="lazy" 
                decoding="async"
                referrerpolicy="no-referrer" 
              />
            </div>
          </div>
          <span class="text-[9px] font-medium text-gray-700 dark:text-gray-300">Topic {item}</span>
        </div>
      ))}
    </div>

    <div class="article-transition-wrapper">
      <div class="skeleton-container hidden space-y-4">
        <!-- Render 2 big card skeletons for home feed -->
        {[1, 2].map(() => (
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 shadow-sm overflow-hidden space-y-3">
            <div class="p-3 flex items-center gap-2 border-b border-gray-100 dark:border-gray-800">
              <div class="w-8 h-8 rounded-full bg-gray-200 dark:bg-gray-800 animate-pulse"></div>
              <div class="space-y-1.5 flex-1">
                <div class="w-24 h-2.5 bg-gray-200 dark:bg-gray-800 rounded animate-pulse"></div>
                <div class="w-16 h-2 bg-gray-150 dark:bg-gray-850 rounded animate-pulse"></div>
              </div>
            </div>
            <div class="w-full aspect-[4/3] bg-gray-200 dark:bg-gray-800 animate-pulse"></div>
            <div class="p-3 space-y-2.5">
              <div class="flex gap-2 mb-2">
                <div class="w-5 h-5 rounded bg-gray-200 dark:bg-gray-800 animate-pulse"></div>
                <div class="w-5 h-5 rounded bg-gray-200 dark:bg-gray-800 animate-pulse"></div>
                <div class="w-5 h-5 rounded bg-gray-200 dark:bg-gray-800 animate-pulse ml-auto"></div>
              </div>
              <div class="w-11/12 h-3.5 bg-gray-200 dark:bg-gray-800 rounded animate-pulse"></div>
              <div class="w-full h-2.5 bg-gray-150 dark:bg-gray-850 rounded animate-pulse"></div>
            </div>
          </div>
        ))}
      </div>
      
      <!-- Feed List -->
      <div class="space-y-4 actual-content-container">
        {feedArticles.map((post, index) => (
          <article class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 shadow-sm overflow-hidden animate-fade-in" style={`animation-delay: ${index * 100}ms`}>
            <div class="p-3 flex items-center gap-2 border-b border-gray-100 dark:border-gray-800">
              <div class="w-8 h-8 rounded-full bg-orange-100 dark:bg-orange-900/30 overflow-hidden flex items-center justify-center text-orange-600 dark:text-orange-500 font-bold text-[10px]">
                {post.author?.name ? post.author.name.charAt(0).toUpperCase() : 'A'}
              </div>
              <div>
                <p class="text-[11px] font-bold text-gray-900 dark:text-white">{post.author?.name || 'Author Name'}</p>
                <p class="text-[9px] text-gray-500 dark:text-gray-400">{post.createdAt ? new Date(Number(post.createdAt)).toLocaleDateString() : 'Just now'}</p>
              </div>
            </div>
            
            <div class="aspect-[4/3] pexih-placeholder bg-gray-100 dark:bg-gray-800 relative">
              <img 
                src={post.img || `https://images.unsplash.com/photo-${1550000000000 + index * 5}?auto=format,compress&fit=crop&w=600&q=80`} 
                alt={`Cover image for ${post.title}`} 
                width="600"
                height="450"
                class="w-full h-full object-cover aspect-[4/3] transition-opacity duration-300 opacity-0" 
                onload="this.classList.remove('opacity-0')"
                loading={index === 0 ? "eager" : "lazy"} 
                fetchpriority={index === 0 ? "high" : "auto"}
                decoding="async"
                referrerpolicy="no-referrer" 
              />
            </div>
            
            <div class="p-3">
              <div class="flex items-center gap-3 mb-2">
                <button aria-label="Like" class="text-gray-600 dark:text-gray-400 hover:text-orange-600 dark:hover:text-orange-500 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                </button>
                <button aria-label="Comment" class="text-gray-600 dark:text-gray-400 hover:text-orange-600 dark:hover:text-orange-500 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </button>
                <button aria-label="Share" class="text-gray-600 dark:text-gray-400 hover:text-orange-600 dark:hover:text-orange-500 transition-colors ml-auto">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
                </button>
              </div>
              
              <a href={`/article/${post.id}`} class="block group">
                <h2 class="text-[12px] font-bold text-gray-900 dark:text-white mb-1 group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors">{post.title}</h2>
              </a>
              <p class="text-[10px] text-gray-600 dark:text-gray-400 line-clamp-2">{post.content ? (post.content.length > 100 ? post.content.substring(0, 100) + '...' : post.content) : "Discover new perspectives and insights from our community of writers and thinkers."}</p>
            </div>
          </article>
        ))}
      </div>
      
      <!-- Infinite Scroll Sentinel -->
      <div id="infinite-scroll-sentinel" data-backend-url={backendUrl} class="py-4 opacity-0 transition-opacity space-y-4 w-full">
        <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 shadow-sm p-3 animate-pulse">
          <div class="flex items-center gap-2 border-b border-gray-100 dark:border-gray-800 pb-3 mb-3">
            <div class="w-8 h-8 rounded-full bg-gray-200 dark:bg-gray-800"></div>
            <div class="space-y-1.5 flex-1">
              <div class="w-1/3 h-2.5 bg-gray-200 dark:bg-gray-800 rounded"></div>
              <div class="w-1/4 h-2 bg-gray-150 dark:bg-gray-850 rounded"></div>
            </div>
          </div>
          <div class="w-full aspect-[4/3] bg-gray-200 dark:bg-gray-800 rounded mb-3"></div>
          <div class="space-y-2">
            <div class="w-3/4 h-3.5 bg-gray-200 dark:bg-gray-800 rounded"></div>
            <div class="w-full h-2.5 bg-gray-150 dark:bg-gray-850 rounded"></div>
            <div class="w-5/6 h-2.5 bg-gray-150 dark:bg-gray-850 rounded"></div>
          </div>
        </div>
      </div>

      <!-- Empty state for search/filter -->
      <div class="search-empty-state hidden">
        <EmptyState 
          title="No Stories Found" 
          description="There are no stories in this topic yet. Be the first to share something!"
          icon={`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-600"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 9h8"/><path d="M8 13h4"/></svg>`}
        >
          <a href="/writer" class="mt-4 px-5 py-2 bg-orange-600 text-white text-[10px] font-bold rounded-full hover:bg-orange-700 transition-colors">
            Write a Story
          </a>
        </EmptyState>
      </div>
    </div>
  </div>
</MobileLayout>

<script>
  // Handle client-side category filtering and skeleton transition
  document.addEventListener('astro:page-load', () => {
    const topicItems = document.querySelectorAll('.topic-item');
    const skeleton = document.querySelector('.skeleton-container');
    const content = document.querySelector('.actual-content-container');
    const searchEmptyState = document.querySelector('.search-empty-state');

    function triggerStaggeredAnimation(container: HTMLElement | null) {
      if (!container) return;
      const items = container.querySelectorAll('.animate-fade-in');
      items.forEach((item: any, index: number) => {
        item.style.animation = 'none';
        void item.offsetWidth; // Force reflow
        item.style.animation = '';
        item.style.animationDelay = `${index * 75}ms`;
      });
    }

    // Trigger initially
    triggerStaggeredAnimation(content as HTMLElement);
    
    // Set first topic active by default
    if (topicItems.length > 0) {
      const firstRing = topicItems[0].querySelector('.topic-ring');
      if (firstRing) {
        firstRing.classList.remove('from-gray-200', 'to-gray-300', 'dark:from-gray-700', 'dark:to-gray-800');
        firstRing.classList.add('from-orange-400', 'to-orange-600');
      }
    }
    
    topicItems.forEach(item => {
      item.addEventListener('click', (e) => {
        // Update active state
        topicItems.forEach(b => {
          const ring = b.querySelector('.topic-ring');
          if (ring) {
            ring.classList.add('from-gray-200', 'to-gray-300', 'dark:from-gray-700', 'dark:to-gray-800');
            ring.classList.remove('from-orange-400', 'to-orange-600');
          }
        });
        
        const target = e.currentTarget as HTMLElement;
        const ring = target.querySelector('.topic-ring');
        if (ring) {
          ring.classList.remove('from-gray-200', 'to-gray-300', 'dark:from-gray-700', 'dark:to-gray-800');
          ring.classList.add('from-orange-400', 'to-orange-600');
        }
        
        // Show skeleton
        if (content && skeleton && searchEmptyState) {
          content.classList.add('hidden');
          searchEmptyState.classList.add('hidden');
          skeleton.classList.remove('hidden');
          
          // Simulate network request
          setTimeout(() => {
            skeleton.classList.add('hidden');
            
            // Demonstrate empty state for topic 4 and 5
            const topicId = target.getAttribute('data-topic');
            if (topicId === '4' || topicId === '5') {
              searchEmptyState.classList.remove('hidden');
            } else {
              content.classList.remove('hidden');
              triggerStaggeredAnimation(content as HTMLElement);
            }
          }, 600);
        }
      });
    });
    
    // Infinite Scrolling Logic
    const sentinel = document.getElementById('infinite-scroll-sentinel');
    let currentPage = 1;
    let isLoading = false;
    let hasMore = true;
    
    if (sentinel && content) {
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && !isLoading && hasMore) {
          loadMoreArticles();
        }
      }, { rootMargin: '100px' });
      
      observer.observe(sentinel);
      
      async function loadMoreArticles() {
        isLoading = true;
        sentinel.classList.remove('opacity-0');
        
        try {
          currentPage++;
          const cacheKey = `pexih_feed_page_${currentPage}`;
          const cachedData = sessionStorage.getItem(cacheKey);
          let newArticles;
          
          if (cachedData) {
            newArticles = JSON.parse(cachedData);
          } else {
            const backendUrl = sentinel.getAttribute('data-backend-url') || '';
            const res = await fetch(`${backendUrl}/api/articles?page=${currentPage}&limit=5`); // Fetch from backend API
            if (!res.ok) throw new Error('Failed');
            newArticles = await res.json();
            sessionStorage.setItem(cacheKey, JSON.stringify(newArticles));
          }
          
          if (newArticles.length === 0) {
            hasMore = false;
            sentinel.classList.add('hidden');
            return;
          }
          
          // Render new articles
          newArticles.forEach((post, index) => {
            const articleHtml = `
              <article class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 shadow-sm overflow-hidden animate-fade-in" style="animation-delay: ${index * 50}ms">
                <div class="p-3 flex items-center gap-2 border-b border-gray-100 dark:border-gray-800">
                  <div class="w-8 h-8 rounded-full bg-orange-100 dark:bg-orange-900/30 overflow-hidden flex items-center justify-center text-orange-600 dark:text-orange-500 font-bold text-[10px]">
                    ${post.author?.name ? post.author.name.charAt(0).toUpperCase() : 'A'}
                  </div>
                  <div>
                    <p class="text-[11px] font-bold text-gray-900 dark:text-white">${post.author?.name || 'Author Name'}</p>
                    <p class="text-[9px] text-gray-500 dark:text-gray-400">${post.createdAt ? new Date(Number(post.createdAt)).toLocaleDateString() : 'Just now'}</p>
                  </div>
                </div>
                
                <div class="aspect-[4/3] pexih-placeholder bg-gray-100 dark:bg-gray-800 relative">
                  <img 
                    src="${post.img || `https://images.unsplash.com/photo-${1550000000000 + Math.floor(Math.random() * 100)}?auto=format,compress&fit=crop&w=600&q=80`}" 
                    alt="Cover image for ${post.title}" 
                    width="600"
                    height="450"
                    class="w-full h-full object-cover aspect-[4/3] transition-opacity duration-300 opacity-0" 
                    onload="this.classList.remove('opacity-0')"
                    loading="lazy" 
                    fetchpriority="auto"
                    decoding="async"
                    referrerpolicy="no-referrer" 
                  />
                </div>
                
                <div class="p-3">
                  <div class="flex items-center gap-3 mb-2">
                    <button aria-label="Like" class="text-gray-600 dark:text-gray-400 hover:text-orange-600 dark:hover:text-orange-500 transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                    </button>
                    <button aria-label="Comment" class="text-gray-600 dark:text-gray-400 hover:text-orange-600 dark:hover:text-orange-500 transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    </button>
                    <button aria-label="Share" class="text-gray-600 dark:text-gray-400 hover:text-orange-600 dark:hover:text-orange-500 transition-colors ml-auto">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
                    </button>
                  </div>
                  
                  <a href="/article/${post.id}" class="block group">
                    <h2 class="text-[12px] font-bold text-gray-900 dark:text-white mb-1 group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors">${post.title}</h2>
                  </a>
                  <p class="text-[10px] text-gray-600 dark:text-gray-400 line-clamp-2">${post.content ? (post.content.length > 100 ? post.content.substring(0, 100) + '...' : post.content) : "Discover new perspectives and insights from our community of writers and thinkers."}</p>
                </div>
              </article>
            `;
            content.insertAdjacentHTML('beforeend', articleHtml);
          });
        } catch (e) {
          console.error("Failed to load more articles", e);
        } finally {
          isLoading = false;
          sentinel.classList.add('opacity-0');
        }
      }
    }
  });
</script>
