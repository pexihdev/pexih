---
import AdminMobileLayout from '../../layouts/AdminMobileLayout.astro';
---
<AdminMobileLayout title="Users">
  <div class="fixed top-0 w-full max-w-[400px] z-50" transition:name="mobile-header">
    <div class="w-full bg-white dark:bg-gray-900" style="height: env(safe-area-inset-top);"></div>
    <div class="bg-white dark:bg-gray-900 pt-3 pb-2 px-5 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between h-[53px]">
      <h1 class="text-[16px] font-bold text-gray-900 dark:text-white">Manage Users</h1>
    </div>
  </div>

  <div class="shrink-0" style="height: calc(53px + env(safe-area-inset-top));"></div>
  <div class="p-4 pb-24 space-y-4">
    <!-- Search and Filter -->
    <div class="flex gap-2">
      <div class="relative flex-1">
        <input type="text" id="user-search" placeholder="Search users..." class="w-full pl-9 pr-4 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[11px] focus:outline-none focus:ring-2 focus:ring-orange-500 transition-colors dark:text-white" />
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </div>
      <select id="role-filter" class="px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-[11px] font-bold focus:outline-none focus:ring-2 focus:ring-orange-500 transition-colors dark:text-white">
        <option value="all">All Roles</option>
        <option value="Admin">Admin</option>
        <option value="Writer">Writer</option>
        <option value="User">User</option>
      </select>
    </div>
    
    <!-- User List -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 shadow-sm overflow-hidden" id="user-list">
      <!-- Injected via JS -->
    </div>
    
    <!-- Empty State -->
    <div id="empty-state" class="hidden text-center py-8">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-gray-300 dark:text-gray-700 mb-3"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
      <p class="text-[11px] font-bold text-gray-900 dark:text-white">No users found</p>
      <p class="text-[10px] text-gray-500 dark:text-gray-400">Try adjusting your search or filters.</p>
    </div>
    
    <!-- Infinite Scroll Sentinel -->
    <div id="mobile-users-sentinel" class="py-4 opacity-0 transition-opacity w-full space-y-2">
      <div class="flex items-center gap-3 p-3 bg-white dark:bg-gray-900 border-b border-gray-100 dark:border-gray-800 animate-pulse">
        <div class="w-10 h-10 rounded-full bg-gray-200 dark:bg-gray-800"></div>
        <div class="flex-1 space-y-2">
          <div class="w-3/4 h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
          <div class="w-1/2 h-2 bg-gray-150 dark:bg-gray-850 rounded"></div>
        </div>
      </div>
      <div class="flex items-center gap-3 p-3 bg-white dark:bg-gray-900 border-b border-gray-100 dark:border-gray-800 animate-pulse">
        <div class="w-10 h-10 rounded-full bg-gray-200 dark:bg-gray-800"></div>
        <div class="flex-1 space-y-2">
          <div class="w-3/4 h-3 bg-gray-200 dark:bg-gray-800 rounded"></div>
          <div class="w-1/2 h-2 bg-gray-150 dark:bg-gray-850 rounded"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Custom Confirmation Modal -->
  <div id="confirm-modal" class="fixed inset-0 z-[60] bg-black/50 backdrop-blur-sm hidden items-center justify-center p-4">
    <div class="bg-white dark:bg-gray-900 w-full max-w-[320px] rounded-xl shadow-2xl p-5 transform scale-95 opacity-0 transition-all duration-200" id="modal-content">
      <div class="w-12 h-12 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center text-orange-600 dark:text-orange-500 mb-4 mx-auto" id="modal-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </div>
      <h3 id="modal-title" class="text-[16px] font-bold text-gray-900 dark:text-white text-center mb-2">Confirm Action</h3>
      <p id="modal-desc" class="text-[11px] text-gray-500 dark:text-gray-400 text-center mb-6 leading-relaxed">Are you sure you want to proceed?</p>
      
      <div class="flex gap-3">
        <button id="modal-cancel" class="flex-1 py-2.5 rounded-lg border border-gray-200 dark:border-gray-700 text-[11px] font-bold text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
          Cancel
        </button>
        <button id="modal-confirm" class="flex-1 py-2.5 rounded-lg bg-orange-600 text-white text-[11px] font-bold hover:bg-orange-700 transition-colors">
          Yes, Proceed
        </button>
      </div>
    </div>
  </div>

  <script is:inline>
    const users = [
      { id: 1, name: 'John Doe', email: 'john@example.com', role: 'Admin', status: 'Active' },
      { id: 2, name: 'Jane Smith', email: 'jane@example.com', role: 'Writer', status: 'Active' },
      { id: 3, name: 'Mike Ross', email: 'mike@example.com', role: 'User', status: 'Suspended' },
      { id: 4, name: 'Sarah Connor', email: 'sarah@example.com', role: 'User', status: 'Active' },
      { id: 5, name: 'Tom Hardy', email: 'tom@example.com', role: 'User', status: 'Active' }
    ];

    let currentAction = null;
    let currentUser = null;

    function renderUsers() {
      const searchInput = document.getElementById('user-search').value.toLowerCase();
      const roleFilter = document.getElementById('role-filter').value;
      const listEl = document.getElementById('user-list');
      const emptyState = document.getElementById('empty-state');
      
      const filtered = users.filter(u => {
        const matchSearch = u.name.toLowerCase().includes(searchInput) || u.email.toLowerCase().includes(searchInput);
        const matchRole = roleFilter === 'all' || u.role === roleFilter;
        return matchSearch && matchRole;
      });

      if (filtered.length === 0) {
        listEl.innerHTML = '';
        listEl.classList.add('hidden');
        emptyState.classList.remove('hidden');
        return;
      }

      listEl.classList.remove('hidden');
      emptyState.classList.add('hidden');
      
      listEl.innerHTML = filtered.map(user => `
        <div class="p-3 border-b border-gray-100 dark:border-gray-800 last:border-0 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center text-orange-700 dark:text-orange-500 font-bold text-[12px]">
                ${user.name.charAt(0)}
              </div>
              <div>
                <p class="text-[12px] font-bold text-gray-900 dark:text-white">${user.name}</p>
                <p class="text-[9px] text-gray-500 dark:text-gray-400">${user.email}</p>
              </div>
            </div>
            <div class="text-right flex flex-col items-end gap-1">
              <span class="inline-block px-2 py-0.5 rounded text-[8px] font-bold uppercase tracking-wider ${
 user.role === 'Admin' ? 'bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400' : 
                user.role === 'Writer' ? 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400' :
                'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300'
              }">${user.role}</span>
              <span class="inline-block px-2 py-0.5 rounded text-[8px] font-bold uppercase tracking-wider ${
 user.status === 'Active' ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400' : 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400'
              }">${user.status}</span>
            </div>
          </div>
          <div class="flex items-center gap-2 pt-2 border-t border-gray-50 dark:border-gray-800">
            <button onclick="requestAction('suspend', ${user.id})" class="flex-1 py-1.5 rounded bg-yellow-50 dark:bg-yellow-900/20 text-yellow-700 dark:text-yellow-500 text-[10px] font-bold hover:bg-yellow-100 dark:hover:bg-yellow-900/40 transition-colors">
              ${user.status === 'Suspended' ? 'Unsuspend' : 'Suspend'}
            </button>
            <button onclick="requestAction('delete', ${user.id})" class="flex-1 py-1.5 rounded bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-500 text-[10px] font-bold hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors">
              Delete
            </button>
          </div>
        </div>
      `).join('');
    }

    // Modal Logic
    function requestAction(action, userId) {
      currentUser = users.find(u => u.id === userId);
      currentAction = action;
      
      const modal = document.getElementById('confirm-modal');
      const modalContent = document.getElementById('modal-content');
      const title = document.getElementById('modal-title');
      const desc = document.getElementById('modal-desc');
      const confirmBtn = document.getElementById('modal-confirm');
      
      if (action === 'delete') {
        title.innerText = 'Delete User';
        desc.innerText = `Are you sure you want to permanently delete ${currentUser.name}? This action cannot be undone.`;
        confirmBtn.className = 'flex-1 py-2.5 rounded-lg bg-red-600 text-white text-[11px] font-bold hover:bg-red-700 transition-colors';
        confirmBtn.innerText = 'Yes, Delete';
      } else {
        const isSuspended = currentUser.status === 'Suspended';
        title.innerText = isSuspended ? 'Unsuspend User' : 'Suspend User';
        desc.innerText = `Are you sure you want to ${isSuspended ? 'unsuspend' : 'suspend'} ${currentUser.name}?`;
        confirmBtn.className = 'flex-1 py-2.5 rounded-lg bg-yellow-500 text-white text-[11px] font-bold hover:bg-yellow-600 transition-colors';
        confirmBtn.innerText = isSuspended ? 'Yes, Unsuspend' : 'Yes, Suspend';
      }
      
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      // trigger reflow
      void modal.offsetWidth;
      modalContent.classList.remove('scale-95', 'opacity-0');
      modalContent.classList.add('scale-100', 'opacity-100');
    }

    function closeModal() {
      const modal = document.getElementById('confirm-modal');
      const modalContent = document.getElementById('modal-content');
      
      modalContent.classList.remove('scale-100', 'opacity-100');
      modalContent.classList.add('scale-95', 'opacity-0');
      
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        currentAction = null;
        currentUser = null;
      }, 200);
    }

    document.getElementById('modal-cancel').addEventListener('click', closeModal);
    document.getElementById('modal-confirm').addEventListener('click', async () => {
      const confirmBtn = document.getElementById('modal-confirm');
      confirmBtn.disabled = true;
      confirmBtn.innerText = 'Processing...';

      if (currentAction === 'delete') {
        try {
          const res = await fetch(`/api/users/${currentUser.id}`, { method: 'DELETE' });
          if (res.ok) {
            const index = users.findIndex(u => u.id === currentUser.id);
            if(index !== -1) users.splice(index, 1);
            window.toast('User deleted successfully');
          } else {
            const err = await res.json();
            window.toast('Failed to delete user: ' + (err.error || 'Unknown'));
          }
        } catch (e) {
          window.toast('Error deleting user');
        }
      } else if (currentAction === 'suspend') {
        const newStatus = currentUser.status === 'Suspended' ? 'Active' : 'Suspended';
        try {
          const res = await fetch(`/api/users/${currentUser.id}/status`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: newStatus })
          });
          if (res.ok) {
            currentUser.status = newStatus;
            window.toast(`User ${newStatus === 'Active' ? 'unsuspended' : 'suspended'} successfully`);
          } else {
            const err = await res.json();
            window.toast('Failed to update status: ' + (err.error || 'Unknown'));
          }
        } catch (e) {
          window.toast('Error updating status');
        }
      }
      
      confirmBtn.disabled = false;
      closeModal();
      renderUsers();
    });

    document.getElementById('user-search').addEventListener('input', renderUsers);
    document.getElementById('role-filter').addEventListener('change', renderUsers);

    // Infinite Scrolling & API fetch
    let currentPage = 1;
    let isLoading = false;
    let hasMore = true;
    
    async function fetchUsers(page = 1) {
      try {
        const res = await fetch(`/api/users?page=${page}&limit=10`);
        if (!res.ok) return;
        const data = await res.json();
        
        if (data.length === 0) {
          hasMore = false;
          document.getElementById('mobile-users-sentinel')?.classList.add('hidden');
          return;
        }
        
        const formatted = data.map(u => ({
          id: u.id,
          name: u.name || u.username || 'User',
          email: u.email || '',
          role: u.role || 'User',
          status: u.status || 'Active',
          date: u.createdAt ? new Date(Number(u.createdAt)).toLocaleDateString() : 'Just now'
        }));
        
        if (page === 1) {
          users.length = 0; // clear dummy
        }
        
        users.push(...formatted);
        renderUsers();
      } catch (e) {
        console.error("Failed to fetch users", e);
      }
    }
    
    const sentinel = document.getElementById('mobile-users-sentinel');
    if (sentinel) {
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && !isLoading && hasMore) {
          isLoading = true;
          sentinel.classList.remove('opacity-0');
          currentPage++;
          fetchUsers(currentPage).finally(() => {
            isLoading = false;
            sentinel.classList.add('opacity-0');
          });
        }
      }, { rootMargin: '100px' });
      observer.observe(sentinel);
    }

    // Initial render
    fetchUsers(1);
    document.addEventListener('DOMContentLoaded', renderUsers);
  </script>
</AdminMobileLayout>
