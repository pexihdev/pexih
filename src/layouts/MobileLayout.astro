---
import Layout from './Layout.astro';
import BottomNav from '../components/BottomNav.astro';

interface Props {
	title?: string;
	showBottomNav?: boolean;
	description?: string;
	image?: string;
	type?: string;
	url?: string;
	publishedTime?: string;
	author?: string;
	schema?: object;
}

const { title, showBottomNav = true, ...seoProps } = Astro.props;
---

<Layout title={title} {...seoProps}>
	<main class="fixed inset-0 w-full max-w-[400px] mx-auto flex flex-col bg-white dark:bg-gray-900 shadow-sm font-sans overflow-y-auto overflow-x-hidden overscroll-y-none relative" id="mobile-main-wrapper" style={`overflow: hidden !important; height: 100vh !important; max-height: 100vh !important; height: 100dvh !important; max-height: 100dvh !important; padding-bottom: ${showBottomNav ? 'calc(72px + env(safe-area-inset-bottom))' : 'calc(20px + env(safe-area-inset-bottom))'} !important;`}>
		<div id="mobile-scroll-container" class="flex-1 h-full min-h-0 max-h-full overflow-y-auto overflow-x-hidden overscroll-y-none relative w-full flex flex-col" style="-webkit-overflow-scrolling: touch; touch-action: pan-y; height: 100% !important; max-height: 100% !important;">
			<!-- PTR Indicator -->
			<div id="ptr-indicator" class="absolute left-0 w-full flex items-center justify-center z-40 opacity-0 pointer-events-none" style="top: calc(52px + env(safe-area-inset-top)); transform: translateY(-20px);">
				<div class="w-8 h-8 rounded-full bg-white dark:bg-gray-800 shadow-md flex items-center justify-center border border-gray-100 dark:border-gray-700">
					<svg id="ptr-spinner" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-orange-600"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
				</div>
			</div>

			<div id="mobile-content-wrapper" class="w-full relative flex flex-col min-h-full">
				<slot />
			</div>
		</div>
		{showBottomNav && <BottomNav />}
		
		<!-- Scroll To Top FAB -->
		<button 
			id="scroll-to-top-fab"
			aria-label="Scroll to top" 
			class="fixed bottom-[70px] right-4 w-10 h-10 bg-orange-600 text-white rounded-full shadow-lg flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300 z-40 hover:bg-orange-700 active:scale-95"
			style="transform: translateY(20px);"
		>
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
		</button>
	</main>

	<script is:inline>
		(function() {
			const handleMobileHeader = (doc) => {
				const scrollContainer = doc.getElementById('mobile-scroll-container');
				const mainWrapper = doc.getElementById('mobile-main-wrapper');
				if (scrollContainer && mainWrapper) {
					const header = scrollContainer.querySelector('.fixed.top-0');
					if (header) {
						header.classList.remove('fixed');
						header.classList.add('absolute');
						mainWrapper.insertBefore(header, scrollContainer);
					}
				}
			};

			if (!window._mobileHeaderInitialized) {
				window._mobileHeaderInitialized = true;
				
				document.addEventListener('astro:before-swap', (e) => {
					handleMobileHeader(e.newDocument);
				});

				document.addEventListener('astro:page-load', () => {
					handleMobileHeader(document);
					
					const scrollContainer = document.getElementById('mobile-scroll-container');
					const mainWrapper = document.getElementById('mobile-main-wrapper');
					const fab = document.getElementById('scroll-to-top-fab');
					
					if (scrollContainer && fab) {
						scrollContainer.addEventListener('scroll', () => {
							if (scrollContainer.scrollTop > 300) {
								fab.classList.remove('opacity-0', 'pointer-events-none');
								fab.style.transform = 'translateY(0)';
							} else {
								fab.classList.add('opacity-0', 'pointer-events-none');
								fab.style.transform = 'translateY(20px)';
							}
						});

						fab.addEventListener('click', () => {
							scrollContainer.scrollTo({ top: 0, behavior: 'smooth' });
						});
					}

					// Pull to Refresh Logic (Only Home & Explore)
					const path = window.location.pathname.replace(/\/$/, '') || '/';
					if (['/', '/explore'].includes(path) && scrollContainer) {
				const contentWrapper = document.getElementById('mobile-content-wrapper');
				const ptrIndicator = document.getElementById('ptr-indicator');
				const ptrSpinner = document.getElementById('ptr-spinner');
				
				let startY = 0;
				let currentY = 0;
				let isPulling = false;
				let isRefreshing = false;
				const maxPull = 80;
				const threshold = 50;
				
				scrollContainer.addEventListener('touchstart', (e) => {
					if (scrollContainer.scrollTop <= 0 && !isRefreshing) {
						startY = e.touches[0].clientY;
						isPulling = true;
						contentWrapper.style.transition = 'none';
						ptrIndicator.style.transition = 'none';
					}
				}, { passive: true });

				scrollContainer.addEventListener('touchmove', (e) => {
					if (!isPulling || isRefreshing) return;
					currentY = e.touches[0].clientY;
					const dy = currentY - startY;
					
					if (dy > 0 && scrollContainer.scrollTop <= 0) {
						const pullDistance = Math.min(dy * 0.4, maxPull);
						contentWrapper.style.transform = `translateY(${pullDistance}px)`;
						ptrIndicator.style.opacity = Math.min(pullDistance / threshold, 1).toString();
						ptrIndicator.style.transform = `translateY(${pullDistance - 30}px)`;
						ptrSpinner.style.transform = `rotate(${pullDistance * 4}deg)`;
					} else if (dy < 0) {
						isPulling = false;
					}
				}, { passive: true });

				scrollContainer.addEventListener('touchend', () => {
					if (!isPulling || isRefreshing) return;
					isPulling = false;
					
					const dy = currentY - startY;
					const pullDistance = Math.min(dy * 0.4, maxPull);
					
					contentWrapper.style.transition = 'transform 0.3s ease-out';
					ptrIndicator.style.transition = 'transform 0.3s ease-out, opacity 0.3s ease-out';
					
					if (pullDistance > threshold) {
						isRefreshing = true;
						contentWrapper.style.transform = `translateY(${threshold}px)`;
						ptrIndicator.style.transform = `translateY(${threshold - 30}px)`;
						ptrSpinner.classList.add('animate-spin');
						
						// Clear session cache for fresh data
						Object.keys(sessionStorage).forEach(key => {
							if (path === '/' && key.startsWith('pexih_feed_page_')) {
								sessionStorage.removeItem(key);
							} else if (path === '/explore' && key.startsWith('pexih_explore_page_')) {
								sessionStorage.removeItem(key);
							}
						});
						
						setTimeout(() => {
							window.location.reload();
						}, 600);
					} else {
						contentWrapper.style.transform = '';
						ptrIndicator.style.transform = 'translateY(-20px)';
						ptrIndicator.style.opacity = '0';
					}
				});
			}

			// Bookmark logic
			const updateBookmarkIcons = () => {
				try {
					const bookmarks = JSON.parse(localStorage.getItem('pexih-bookmarks') || '[]');
					const savedIds = new Set(bookmarks.map((b) => b.id));
					document.querySelectorAll('.bookmark-btn').forEach(btn => {
						const id = btn.getAttribute('data-bookmark-id');
						const icon = btn.querySelector('.bookmark-icon');
						if (id && icon) {
							if (savedIds.has(id)) {
								icon.setAttribute('fill', 'currentColor');
								btn.classList.add('!text-orange-600', 'dark:!text-orange-500');
							} else {
								icon.setAttribute('fill', 'none');
								btn.classList.remove('!text-orange-600', 'dark:!text-orange-500');
							}
						}
					});
				} catch(e) {}
			};

			updateBookmarkIcons();

			// Event delegation for dynamically added bookmark buttons
			document.addEventListener('click', (e) => {
				const btn = e.target.closest('.bookmark-btn');
				if (!btn) return;
				
				e.preventDefault();
				e.stopPropagation();
				try {
					const id = btn.getAttribute('data-bookmark-id');
					if (!id) return;
					let bookmarks = JSON.parse(localStorage.getItem('pexih-bookmarks') || '[]');
					const index = bookmarks.findIndex((b) => b.id === id);
					
					if (index > -1) {
						bookmarks.splice(index, 1);
						if (window.toast) window.toast('Bookmark removed');
					} else {
						bookmarks.push({
							id,
							title: btn.getAttribute('data-bookmark-title'),
							category: btn.getAttribute('data-bookmark-category'),
							img: btn.getAttribute('data-bookmark-img'),
							author: { name: btn.getAttribute('data-bookmark-author') },
							readTime: btn.getAttribute('data-bookmark-readtime') || '5 min read',
							label: 'Read Later',
							savedAt: Date.now()
						});
						if (window.toast) window.toast('Article saved');
					}
					localStorage.setItem('pexih-bookmarks', JSON.stringify(bookmarks));
					updateBookmarkIcons();
				} catch(err) {
					console.error('Bookmark error:', err);
				}
			});
		}); // End astro:page-load
		} // end if initialized
		})();
	</script>
</Layout>
