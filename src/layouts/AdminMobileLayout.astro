---
import Layout from './Layout.astro';
import AdminBottomNav from '../components/AdminBottomNav.astro';

interface Props {
	title?: string;
	showBottomNav?: boolean;
}

const { title, showBottomNav = true } = Astro.props;
---

<Layout title={title}>
	<main class="fixed inset-0 w-full max-w-[400px] mx-auto flex flex-col bg-white dark:bg-gray-900 shadow-sm font-sans overflow-y-auto overflow-x-hidden relative" id="admin-mobile-main-wrapper" style={`overflow: hidden !important; height: 100vh !important; max-height: 100vh !important; height: 100dvh !important; max-height: 100dvh !important; padding-bottom: ${showBottomNav ? 'calc(72px + env(safe-area-inset-bottom))' : 'calc(20px + env(safe-area-inset-bottom))'} !important;`}>
		<div id="admin-mobile-scroll-container" class="flex-1 h-full min-h-0 max-h-full overflow-y-auto overflow-x-hidden relative w-full flex flex-col" style="-webkit-overflow-scrolling: touch; touch-action: pan-y; height: 100% !important; max-height: 100% !important;">
			<slot />
		</div>
		{showBottomNav && <AdminBottomNav />}
	</main>

	<script is:inline>
		(function() {
			const handleAdminMobileHeader = (doc) => {
				const scrollContainer = doc.getElementById('admin-mobile-scroll-container');
				const mainWrapper = doc.getElementById('admin-mobile-main-wrapper');
				if (scrollContainer && mainWrapper) {
					const header = scrollContainer.querySelector('.fixed.top-0');
					if (header) {
						header.classList.remove('fixed');
						header.classList.add('absolute');
						mainWrapper.insertBefore(header, scrollContainer);
					}
				}
			};

			if (!window._adminMobileHeaderInitialized) {
				window._adminMobileHeaderInitialized = true;
				
				document.addEventListener('astro:before-swap', (e) => {
					handleAdminMobileHeader(e.newDocument);
				});

				document.addEventListener('astro:page-load', () => {
					handleAdminMobileHeader(document);
				});
			}
		})();
	</script>
</Layout>
