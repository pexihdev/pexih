---
import Layout from './Layout.astro';
import AdminBottomNav from '../components/AdminBottomNav.astro';

interface Props {
	title?: string;
	showBottomNav?: boolean;
}

const { title, showBottomNav = true } = Astro.props;
---

<Layout title={title}>
	<main class={`fixed inset-0 w-full max-w-[400px] mx-auto flex flex-col bg-white dark:bg-gray-900 shadow-sm font-sans overflow-y-auto overflow-x-hidden relative ${showBottomNav ? 'pb-[52px]' : ''}`} id="admin-mobile-main-wrapper" style="overflow: hidden !important;">
		<div id="admin-mobile-scroll-container" class="flex-1 h-full min-h-0 max-h-full overflow-y-auto overflow-x-hidden relative w-full flex flex-col" style="-webkit-overflow-scrolling: touch; touch-action: pan-y;">
			<slot />
		</div>
		{showBottomNav && <AdminBottomNav />}
	</main>

	<script is:inline>
		document.addEventListener('astro:page-load', () => {
			const scrollContainer = document.getElementById('admin-mobile-scroll-container');
			const mainWrapper = document.getElementById('admin-mobile-main-wrapper');
			if (scrollContainer && mainWrapper) {
				const header = scrollContainer.querySelector('.fixed.top-0');
				if (header) {
					header.classList.remove('fixed');
					header.classList.add('absolute');
					mainWrapper.insertBefore(header, scrollContainer);
				}
			}
		});
	</script>
</Layout>
